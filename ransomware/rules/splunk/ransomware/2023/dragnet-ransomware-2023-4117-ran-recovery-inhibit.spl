| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4117 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: e7a52919-2014-5c28-9423-d460c7829229"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
