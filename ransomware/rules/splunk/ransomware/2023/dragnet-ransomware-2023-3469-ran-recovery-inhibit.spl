| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3469 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 8f22fde5-fb8d-5ca8-b2c4-8c75a5190a83"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
