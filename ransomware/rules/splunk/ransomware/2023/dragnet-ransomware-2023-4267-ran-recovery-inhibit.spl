| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4267 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 7b17b8b5-5826-5714-a9fc-b2481c6765bf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
