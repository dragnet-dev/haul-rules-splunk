| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3578 — Recovery Inhibition (noescape)"
| comment "Status: experimental | Level: high | ID: f63d03de-009f-56fe-b4f9-7b5af2ecef6b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
