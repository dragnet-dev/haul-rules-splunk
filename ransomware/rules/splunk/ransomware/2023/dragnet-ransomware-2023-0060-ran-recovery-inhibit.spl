| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0060 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 94bc6e6b-da89-59ec-b63c-a0c53e8c586a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
