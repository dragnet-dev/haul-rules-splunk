| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5342 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: a7aa0b3b-50b1-5b3a-9c74-afadeaab5c1a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
