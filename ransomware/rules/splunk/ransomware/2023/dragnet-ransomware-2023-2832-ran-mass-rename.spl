| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2832 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: d5c003a7-5882-57fb-bebc-5fc14b90b3a6"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
