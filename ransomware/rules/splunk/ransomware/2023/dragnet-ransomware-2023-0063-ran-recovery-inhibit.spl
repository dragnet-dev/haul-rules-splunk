| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0063 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: c2e52eac-985d-5e26-bebf-9b479454a054"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
