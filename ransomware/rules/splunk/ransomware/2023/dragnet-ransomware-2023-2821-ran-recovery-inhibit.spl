| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2821 — Recovery Inhibition (malas)"
| comment "Status: experimental | Level: high | ID: b3a85bb2-b208-568c-8523-e27ee8c35102"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
