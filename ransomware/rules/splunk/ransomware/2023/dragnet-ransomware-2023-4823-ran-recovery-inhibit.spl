| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4823 — Recovery Inhibition (royal)"
| comment "Status: experimental | Level: high | ID: 3d822c90-253a-57ca-a072-110f31fc88cc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
