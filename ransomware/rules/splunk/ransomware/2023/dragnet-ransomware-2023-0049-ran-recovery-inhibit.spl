| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0049 — Recovery Inhibition (raworld)"
| comment "Status: experimental | Level: high | ID: f87e5168-eb0b-5b49-ac88-746f44453cd3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
