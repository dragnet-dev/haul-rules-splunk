| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0186 — Recovery Inhibition (donutleaks)"
| comment "Status: experimental | Level: high | ID: 2bf842d7-1531-5f02-825c-2e59e8727ea4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
