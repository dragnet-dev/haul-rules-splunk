| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4703 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 59466159-531d-55db-87a1-6ebf52d29fc3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
