| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2136 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 5fd0855c-4641-53b5-bebe-5a4f60c173fb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
