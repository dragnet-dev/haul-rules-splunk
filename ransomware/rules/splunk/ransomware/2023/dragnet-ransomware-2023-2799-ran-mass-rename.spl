| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2799 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: df879836-7744-59e5-8971-d0d8d271ae03"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
