| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5134 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: ba91a9d6-c4dd-51c8-8842-1457dc305656"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
