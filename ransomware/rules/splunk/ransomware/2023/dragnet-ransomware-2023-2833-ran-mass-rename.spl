| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2833 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: f7722edd-f5d0-550c-9087-3a97f5664e7f"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
