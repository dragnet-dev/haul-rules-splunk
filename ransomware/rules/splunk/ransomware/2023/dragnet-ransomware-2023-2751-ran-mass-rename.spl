| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2751 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 21ff074b-e5cb-5507-b69a-a6fac8a3fa18"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
