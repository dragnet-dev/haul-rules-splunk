| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0345 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: e2ee4384-ec31-5ac9-a872-5f2068cafa8e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
