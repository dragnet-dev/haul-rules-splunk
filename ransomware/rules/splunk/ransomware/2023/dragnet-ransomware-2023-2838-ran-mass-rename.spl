| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2838 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 5bb8716d-41ba-5427-a61b-2a09bb3ffaff"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
