| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4774 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: e01b9ae7-204d-50de-8d9a-da19dee67f9f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
