| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2637 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 81a9a477-f461-5b6f-a782-da13b01297c8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
