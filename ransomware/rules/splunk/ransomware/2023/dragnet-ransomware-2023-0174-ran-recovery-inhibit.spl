| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0174 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 003ee22a-2c74-5fdb-b09f-10f4a4886059"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
