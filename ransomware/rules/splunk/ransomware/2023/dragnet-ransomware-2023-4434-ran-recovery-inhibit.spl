| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4434 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 946da6d8-ff39-5b68-b773-72c7f071e27d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
