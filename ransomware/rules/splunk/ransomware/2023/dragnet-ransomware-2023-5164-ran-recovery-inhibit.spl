| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5164 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 4455e191-2060-57f4-9caf-e49513d36712"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
