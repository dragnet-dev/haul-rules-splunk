| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3308 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 840ffffb-dd5b-5ca4-9a08-c277ec702a3f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
