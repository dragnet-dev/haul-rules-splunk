| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3857 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 2d93ae41-d7e3-5801-b841-3729091747a9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
