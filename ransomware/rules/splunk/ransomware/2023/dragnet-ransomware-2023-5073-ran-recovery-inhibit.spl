| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5073 — Recovery Inhibition (everest)"
| comment "Status: experimental | Level: high | ID: 739e7f8e-4f4a-51b9-ad73-2c0b743ed92b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
