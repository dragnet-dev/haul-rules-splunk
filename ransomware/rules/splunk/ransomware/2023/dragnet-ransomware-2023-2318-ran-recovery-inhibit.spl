| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2318 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 0b2ade35-6a34-563c-86bd-dc33b75bdf18"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
