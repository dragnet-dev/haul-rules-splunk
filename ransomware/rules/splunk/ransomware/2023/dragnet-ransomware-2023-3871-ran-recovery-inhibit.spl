| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3871 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: c20a6378-a29c-59f2-b77b-9d78d45cfb08"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
