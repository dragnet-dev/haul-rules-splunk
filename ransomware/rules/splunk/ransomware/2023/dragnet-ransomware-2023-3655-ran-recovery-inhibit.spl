| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3655 — Recovery Inhibition (moneymessage)"
| comment "Status: experimental | Level: high | ID: 671da738-5294-5cfa-99da-b84229ca1abf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
