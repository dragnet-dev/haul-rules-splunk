| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0864 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 4c3e3548-c5f3-57bd-87ea-6fffad4f3f07"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
