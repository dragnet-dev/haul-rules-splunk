| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3354 — Recovery Inhibition (darkpower)"
| comment "Status: experimental | Level: high | ID: d1ffa92b-8524-5841-b79c-ce9941f40239"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
