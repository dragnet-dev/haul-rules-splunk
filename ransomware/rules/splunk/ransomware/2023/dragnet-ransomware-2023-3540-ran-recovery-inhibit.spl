| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3540 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 0f304bcf-6df6-5b33-b9a7-df85cde65e1a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
