| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3827 — Recovery Inhibition (siegedsec)"
| comment "Status: experimental | Level: high | ID: 5b4f6051-8298-584b-990c-c83d887954a3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
