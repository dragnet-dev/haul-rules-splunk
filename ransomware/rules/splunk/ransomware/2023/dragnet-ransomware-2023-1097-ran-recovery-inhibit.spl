| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1097 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: e2f0738c-0308-5264-bcf5-472852a7bf2a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
