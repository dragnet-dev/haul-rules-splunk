| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0887 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 79e82900-c9b2-53f4-a41e-5324a558b8d8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
