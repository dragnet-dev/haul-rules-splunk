| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0465 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 8ad00079-1ed0-59c1-a8e5-b22eaebab5df"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
