| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1891 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 23eb0520-0b85-5b70-baca-991276d17c32"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
