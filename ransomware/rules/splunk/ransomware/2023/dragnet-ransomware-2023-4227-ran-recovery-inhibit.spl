| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4227 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: ede58e56-ca0f-5bff-a7a0-13d3adec3269"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
