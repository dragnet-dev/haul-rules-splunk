| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1042 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 50a5863f-d005-5164-a4b4-0ed8b9eba14b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
