| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2851 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 356081fa-6807-5e67-b6fa-8c9366339cf3"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
