| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1298 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 505b19c9-6f3a-5c19-aefa-f6b97e82eb7f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
