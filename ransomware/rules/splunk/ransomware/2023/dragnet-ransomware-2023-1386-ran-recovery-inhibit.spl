| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1386 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 4d4c38ba-24f6-5da7-b426-1f29ccf08ba9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
