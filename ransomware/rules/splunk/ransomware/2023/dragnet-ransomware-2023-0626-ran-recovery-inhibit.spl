| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0626 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: fa4d59ed-cc16-5b0f-aed0-65dab07dc365"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
