| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4888 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: d926cf0e-f956-564b-ab37-103d3ab67ce7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
