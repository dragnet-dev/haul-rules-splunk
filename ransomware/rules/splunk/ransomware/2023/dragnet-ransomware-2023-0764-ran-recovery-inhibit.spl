| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0764 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 3c0cff81-c394-55f2-9af3-c72448285ed2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
