| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0305 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: e117870a-e755-5f6d-8082-44a9c03d3288"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
