| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0124 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: d4b7be26-81c9-5769-970e-5a93a66300d9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
