| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5371 — Recovery Inhibition (donutleaks)"
| comment "Status: experimental | Level: high | ID: 47fd808f-5754-5d6e-bea0-83b3de9ecce9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
