| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1376 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 17832d15-7de3-5eba-92c0-bbdc2237931b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
