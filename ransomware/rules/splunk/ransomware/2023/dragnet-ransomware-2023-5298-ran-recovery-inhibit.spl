| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5298 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 902a8ea9-560d-5477-a5a1-429fc8c7b73d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
