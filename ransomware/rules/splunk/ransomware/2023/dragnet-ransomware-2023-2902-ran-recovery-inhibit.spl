| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2902 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 799632e8-5b8d-554b-b054-7f7298e62bc6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
