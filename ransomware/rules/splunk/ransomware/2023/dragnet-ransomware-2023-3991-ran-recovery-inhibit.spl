| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3991 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: d832e0f6-93c7-5f61-b424-f1e9687f278f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
