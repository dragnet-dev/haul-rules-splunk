| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5065 — Recovery Inhibition (siegedsec)"
| comment "Status: experimental | Level: high | ID: a4e00a1b-5252-5c55-a6d9-9a27fc5bf414"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
