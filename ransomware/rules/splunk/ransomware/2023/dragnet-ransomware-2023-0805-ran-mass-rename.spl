| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0805 — Mass File Rename (lockbit3)"
| comment "Status: experimental | Level: high | ID: 115b88ca-375d-5350-b621-98e03d0227db"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
