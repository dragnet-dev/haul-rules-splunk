| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4526 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 12798616-eb49-536d-9209-7f4b7a20302d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
