| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2170 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 432b1ac7-5a63-5e4d-bd4f-3328d42f17e1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
