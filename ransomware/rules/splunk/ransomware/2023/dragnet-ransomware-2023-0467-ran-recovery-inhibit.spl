| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0467 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 5f22a28c-03a7-5d3b-b8fc-983795e9334b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
