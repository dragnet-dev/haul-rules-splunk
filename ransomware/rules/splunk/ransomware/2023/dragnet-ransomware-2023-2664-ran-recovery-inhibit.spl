| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2664 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 3f52bce7-f389-5d95-bb52-f04f11d09f67"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
