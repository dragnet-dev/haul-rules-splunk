| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1784 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 3413bf8e-8da1-596c-bfbc-003267e89882"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
