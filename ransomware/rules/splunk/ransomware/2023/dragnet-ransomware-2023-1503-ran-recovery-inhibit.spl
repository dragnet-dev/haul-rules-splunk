| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1503 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 0c5be97e-bb94-59c8-9b33-54398a24d429"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
