| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2071 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 3fe3f9e5-8862-5535-b8d5-95824e0491fb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
