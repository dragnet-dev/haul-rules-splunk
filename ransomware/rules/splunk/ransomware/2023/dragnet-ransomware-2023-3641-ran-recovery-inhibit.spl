| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3641 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: bd546e99-298d-56da-9d88-4f7957df262b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
| table _time, host, process, parent_process, CommandLine
| head 1000
