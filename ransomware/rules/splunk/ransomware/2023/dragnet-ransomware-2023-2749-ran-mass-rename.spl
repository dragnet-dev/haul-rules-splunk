| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2749 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 28655eab-0f56-56ac-8aaf-00a4f24bf40f"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
