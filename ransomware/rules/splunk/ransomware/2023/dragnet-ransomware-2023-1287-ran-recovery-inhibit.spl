| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1287 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 315d922e-29e8-5c9e-85e8-009afb4b7c92"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
