| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5341 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 08be4b4f-08ef-5367-806e-a23a945b44bc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
