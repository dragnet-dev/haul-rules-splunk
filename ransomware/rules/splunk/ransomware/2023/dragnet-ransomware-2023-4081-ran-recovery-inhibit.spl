| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4081 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 1f9ecf33-2955-553a-84c6-58fc475358d0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
