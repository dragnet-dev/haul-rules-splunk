| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5035 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 7c64bf4f-d48b-558c-9397-2ee652d881d3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
