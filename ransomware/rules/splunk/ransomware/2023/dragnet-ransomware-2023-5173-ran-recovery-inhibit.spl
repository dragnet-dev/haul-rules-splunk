| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5173 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 34a18fb4-fa28-5ed8-93a4-2848d28455ef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
