| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3410 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 2fd50b85-2c32-5ac3-a873-e84d5c30d01f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
