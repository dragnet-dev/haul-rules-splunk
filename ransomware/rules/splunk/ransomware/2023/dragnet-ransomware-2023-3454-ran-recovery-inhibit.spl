| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3454 — Recovery Inhibition (cuba)"
| comment "Status: experimental | Level: high | ID: e262def1-06cd-5023-a2ef-aebb49faaac0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
