| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5276 — Recovery Inhibition (underground)"
| comment "Status: experimental | Level: high | ID: 53aba14f-adbc-5bec-a583-33b7240f1543"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
