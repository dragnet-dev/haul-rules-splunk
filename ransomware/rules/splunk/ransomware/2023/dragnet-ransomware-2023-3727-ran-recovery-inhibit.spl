| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3727 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: 291dc7cb-ab98-5571-9643-8f487b8e3139"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
