| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3023 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 55484f95-6433-5c34-97c8-f6c55dd74356"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
