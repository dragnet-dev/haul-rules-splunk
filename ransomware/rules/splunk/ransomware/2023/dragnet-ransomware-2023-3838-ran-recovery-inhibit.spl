| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3838 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 915c6fb1-a770-5ae7-8757-ad2a3cbd95a3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
