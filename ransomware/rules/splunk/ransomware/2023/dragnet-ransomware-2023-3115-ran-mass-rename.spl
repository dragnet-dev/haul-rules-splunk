| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3115 — Mass File Rename (lockbit3)"
| comment "Status: experimental | Level: high | ID: 084ec59e-25fb-542e-a542-b87b940f067e"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
