| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1131 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 23764d35-3507-5e5a-94ae-6ef2cfdf5e30"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
