| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5092 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: db7f6b9f-d21d-5e45-ad04-e5130d3e603b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
