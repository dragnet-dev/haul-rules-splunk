| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0024 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 83c2a88e-824f-52ef-91b8-7a8e6ebbea80"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
