| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4103 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 07c63e22-15f7-521b-a762-2c480e4ddf42"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
