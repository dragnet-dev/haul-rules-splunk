| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3702 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: d844571f-4c6f-577a-afd5-3dd4df870451"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
