| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2415 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 93f0580b-78d6-5921-be9e-a07bb5290b97"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
