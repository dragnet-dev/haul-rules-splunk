| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4981 — Recovery Inhibition (werewolves)"
| comment "Status: experimental | Level: high | ID: 7f480f7c-fd1d-5e2a-8966-f2914aa49807"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
