| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1195 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 068e4f81-9058-565e-ad51-6283925edd21"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
