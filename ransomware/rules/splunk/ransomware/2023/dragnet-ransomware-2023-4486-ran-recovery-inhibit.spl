| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4486 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 758a4a14-1eb1-5066-8234-85ba8f9d5785"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
