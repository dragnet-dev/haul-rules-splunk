| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3781 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: e13223e7-d8fc-5638-8fe4-f89d1d643a54"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
