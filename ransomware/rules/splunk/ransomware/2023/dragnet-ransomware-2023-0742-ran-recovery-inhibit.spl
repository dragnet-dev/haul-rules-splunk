| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0742 — Recovery Inhibition (noescape)"
| comment "Status: experimental | Level: high | ID: 6cb024ce-5676-500a-b7f5-5142a8b472ee"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
