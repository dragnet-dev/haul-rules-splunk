| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1244 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 43b096fd-ae1c-5757-ad70-2db2dcb4541a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
