| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2964 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 660b397f-6f1b-5e39-b757-46bce8563507"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
