| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2177 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 6996eb9d-e0fd-509d-a0c6-7ea277c8a3eb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
