| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2342 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: ddaaaf4a-72a5-568c-a68c-597cccf47176"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
