| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2897 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: ceafce21-26c4-5059-ae39-621465da1a3e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
