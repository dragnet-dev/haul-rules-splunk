| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0820 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: 27789b8d-a0c6-5d6f-89bb-ba61abb1bf6a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
