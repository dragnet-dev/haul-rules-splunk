| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2477 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 282985fc-7c02-5680-b83f-9d262101fdb5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
