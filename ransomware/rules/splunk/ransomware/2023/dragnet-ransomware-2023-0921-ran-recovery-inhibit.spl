| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0921 — Recovery Inhibition (snatch)"
| comment "Status: experimental | Level: high | ID: 8ed2691d-dbde-512f-b01f-19daaa4ba4bb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
