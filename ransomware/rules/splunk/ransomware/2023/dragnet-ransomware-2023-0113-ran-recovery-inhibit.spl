| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0113 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 7ed7bf88-6949-5e81-aadf-d6ca5c9ebe57"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
