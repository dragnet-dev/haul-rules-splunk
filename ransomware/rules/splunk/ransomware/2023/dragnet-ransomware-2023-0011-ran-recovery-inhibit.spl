| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0011 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 850b3bc1-4447-58af-8842-9a84f27effbf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
