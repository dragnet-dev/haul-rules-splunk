| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4958 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: cb648b8a-eae2-56e3-acb1-2f8c112f08b0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
