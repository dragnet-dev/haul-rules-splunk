| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1438 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 1b37bd75-0987-543f-84ef-9d324202a4d1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
