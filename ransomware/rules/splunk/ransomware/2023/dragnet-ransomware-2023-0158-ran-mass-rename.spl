| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0158 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: a4945c2d-f646-5fbb-aa8e-cfd4d1800454"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
