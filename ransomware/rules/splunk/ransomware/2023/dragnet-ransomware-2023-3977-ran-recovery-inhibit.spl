| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3977 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: e8ced413-1855-5af5-842a-a51d32ed0416"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
