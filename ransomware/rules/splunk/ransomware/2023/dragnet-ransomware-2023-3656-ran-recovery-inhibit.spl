| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3656 — Recovery Inhibition (moneymessage)"
| comment "Status: experimental | Level: high | ID: 1bd99292-0c97-5450-8160-e3fe673bd9ed"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
