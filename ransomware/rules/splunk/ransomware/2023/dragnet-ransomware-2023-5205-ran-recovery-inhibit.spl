| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5205 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: de47ecb9-b837-5e26-8aab-6cfd4eb0bbbc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
