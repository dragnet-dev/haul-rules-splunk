| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0475 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: c1b76fce-e1d9-50d7-877a-2d153e031a71"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
