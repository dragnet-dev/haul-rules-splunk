| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2591 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 8b364e29-68a8-5d06-af4d-d4384d8cddbf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
