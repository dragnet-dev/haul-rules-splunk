| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0527 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: 98ec1b8c-d690-5428-acc4-4a5be8dc9734"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
