| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4824 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 916966a0-c387-57cc-bbca-e843dae5e37d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
