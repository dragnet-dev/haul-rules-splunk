| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1999 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 909a8f65-7fce-5405-b9d0-72a2c00799fb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
