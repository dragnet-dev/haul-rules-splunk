| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2407 — Recovery Inhibition (ragnarlocker)"
| comment "Status: experimental | Level: high | ID: 7944905a-43d6-5978-b4df-bb91dc143b6b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
