| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4667 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 396ae513-f065-5f5c-b3f0-d01a1133253f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
