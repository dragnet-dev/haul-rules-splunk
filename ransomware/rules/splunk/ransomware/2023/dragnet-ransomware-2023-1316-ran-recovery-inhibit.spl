| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1316 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: 29b27a12-4716-54e6-8de6-fd669afe9893"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
