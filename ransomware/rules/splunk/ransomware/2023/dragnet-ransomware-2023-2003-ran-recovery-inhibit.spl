| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2003 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 7656aa2f-878d-5227-a5de-af60050d29dc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
