| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1397 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: ee7ded95-a04d-5d39-8ea9-6f2e822d5f72"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
