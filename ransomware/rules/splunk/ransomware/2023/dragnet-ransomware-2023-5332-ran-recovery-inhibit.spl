| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5332 — Recovery Inhibition (dunghill)"
| comment "Status: experimental | Level: high | ID: 4f4fb2e4-207b-52ac-9e3b-769b6c1c29a7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
