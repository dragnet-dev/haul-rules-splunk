| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2496 — Recovery Inhibition (werewolves)"
| comment "Status: experimental | Level: high | ID: 2d7b2e3b-0496-553f-b605-5a03865da2f9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
