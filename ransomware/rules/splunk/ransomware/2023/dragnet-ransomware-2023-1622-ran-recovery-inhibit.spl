| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1622 — Recovery Inhibition (thegentlemen)"
| comment "Status: experimental | Level: high | ID: c879019f-8ec5-5dcb-9437-46d86a526aa8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
