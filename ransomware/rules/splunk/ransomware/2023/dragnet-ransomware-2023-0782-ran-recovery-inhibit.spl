| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0782 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 1abea8eb-5670-5f54-a9ba-b6cbb07357e9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
