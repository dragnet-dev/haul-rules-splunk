| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1152 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: ba11f7ae-6ffb-59e9-bb03-f0e3676b40db"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
