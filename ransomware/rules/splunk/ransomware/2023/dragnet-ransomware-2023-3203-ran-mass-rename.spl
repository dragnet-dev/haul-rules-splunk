| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3203 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 0ca44959-8d32-5026-9684-96d4299fc0e5"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
