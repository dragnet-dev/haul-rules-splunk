| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0221 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: b12b449a-29ec-5b0f-b752-ce3419aa4035"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
