| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3829 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 1a132e27-2dd7-5ce2-a791-36f83e014f84"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
