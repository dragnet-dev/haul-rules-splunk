| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2240 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 54a9971a-14a4-53e2-89d8-7d4681fa7b15"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
