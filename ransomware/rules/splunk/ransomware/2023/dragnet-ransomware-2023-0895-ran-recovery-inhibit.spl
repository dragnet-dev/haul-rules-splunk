| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0895 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 1f396d91-ada6-5f7f-b182-ed69e0b26df7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
