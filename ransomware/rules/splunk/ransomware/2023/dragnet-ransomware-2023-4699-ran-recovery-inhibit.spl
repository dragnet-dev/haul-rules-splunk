| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4699 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: c446d054-6de1-54b4-84bc-154bb2fea72c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
