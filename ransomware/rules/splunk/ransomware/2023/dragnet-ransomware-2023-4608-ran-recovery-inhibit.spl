| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4608 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 16d084a3-ee35-5be0-89aa-4d79ebfde056"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
