| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2804 — Recovery Inhibition (malas)"
| comment "Status: experimental | Level: high | ID: 0c8feb57-d295-5c5d-b4d7-5eb6814a4d0b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
