| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5175 — Recovery Inhibition (mallox)"
| comment "Status: experimental | Level: high | ID: f273f8ff-d002-52af-8b0d-e0a5db0d5cd3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
