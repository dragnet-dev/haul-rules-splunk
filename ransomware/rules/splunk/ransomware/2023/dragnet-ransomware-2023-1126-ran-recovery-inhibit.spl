| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1126 — Recovery Inhibition (royal)"
| comment "Status: experimental | Level: high | ID: a81c96b9-1ab1-5f3c-9216-bbde7e6bbf9f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
