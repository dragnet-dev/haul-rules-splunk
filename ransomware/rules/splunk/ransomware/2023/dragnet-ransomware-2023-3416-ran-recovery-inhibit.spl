| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3416 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 33aeb4d7-009f-5f72-99e4-3b78e33a9e45"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
