| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3963 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: db384a9b-4737-5267-8d17-dfe30965f3da"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
