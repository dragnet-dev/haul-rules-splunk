| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4046 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 413c5ae8-5e76-5a2a-bbb4-b4e2ab026ac7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
