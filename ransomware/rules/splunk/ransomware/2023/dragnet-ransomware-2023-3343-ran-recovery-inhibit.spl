| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3343 — Recovery Inhibition (ransomhouse)"
| comment "Status: experimental | Level: high | ID: b68d054d-ba00-5786-ab64-87d04f0d5996"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
