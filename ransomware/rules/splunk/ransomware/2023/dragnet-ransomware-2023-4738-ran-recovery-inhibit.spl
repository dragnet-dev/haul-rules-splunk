| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4738 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 8fc2dc80-690a-50cc-a870-d7bf0830c20b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
