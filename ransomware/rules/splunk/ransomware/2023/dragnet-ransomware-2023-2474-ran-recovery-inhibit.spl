| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2474 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 1d95652b-6eec-55b2-9ca3-b8b0d7335cd4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
