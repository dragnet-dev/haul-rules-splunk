| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2992 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: c0d7ac31-04cf-5f2a-b80e-6a0405e2990d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
