| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4583 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 43b53722-0104-5cd7-be5f-333de14bc015"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
