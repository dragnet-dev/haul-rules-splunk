| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4510 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: ebeac3e4-75ee-5c9a-97a3-4aac61d4ba05"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
