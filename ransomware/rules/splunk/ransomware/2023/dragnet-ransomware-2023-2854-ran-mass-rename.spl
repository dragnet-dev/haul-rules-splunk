| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2854 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: f23a23d3-ca32-5532-8c66-6d12ff41309e"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
