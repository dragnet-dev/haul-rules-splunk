| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5294 — Recovery Inhibition (meow)"
| comment "Status: experimental | Level: high | ID: f6fcaf0a-bada-5e4a-b548-a18ee3d0f180"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
