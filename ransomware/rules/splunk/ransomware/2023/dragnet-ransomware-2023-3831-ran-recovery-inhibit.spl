| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3831 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: b38ef322-e51a-5577-ad0f-711b6acf3b4b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
