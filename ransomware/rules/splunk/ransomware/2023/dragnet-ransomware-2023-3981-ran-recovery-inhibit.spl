| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3981 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 7f77e984-14aa-5778-b321-96a758ab54ed"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
