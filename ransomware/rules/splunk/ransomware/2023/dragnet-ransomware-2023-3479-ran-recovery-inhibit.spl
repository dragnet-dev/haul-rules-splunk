| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3479 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: d599afa1-3104-58d1-8225-dbb6c17d1f7b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
