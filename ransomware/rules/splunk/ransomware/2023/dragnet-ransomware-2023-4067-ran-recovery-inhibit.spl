| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4067 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 179b67d8-7f59-5565-afb4-757825553511"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
