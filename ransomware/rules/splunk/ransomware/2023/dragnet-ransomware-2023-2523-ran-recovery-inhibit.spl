| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2523 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 7d8780f8-371b-5c8c-85db-88c07cb41921"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
