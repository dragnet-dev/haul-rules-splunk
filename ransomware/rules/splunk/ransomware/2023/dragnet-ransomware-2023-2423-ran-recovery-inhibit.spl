| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2423 — Recovery Inhibition (medusalocker)"
| comment "Status: experimental | Level: high | ID: adcfb778-89fe-5bfc-a4c3-77e547b180e9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
