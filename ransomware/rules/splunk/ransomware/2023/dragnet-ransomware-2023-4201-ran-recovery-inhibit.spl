| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4201 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 93b40632-2ee7-5381-972e-600189954cae"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
