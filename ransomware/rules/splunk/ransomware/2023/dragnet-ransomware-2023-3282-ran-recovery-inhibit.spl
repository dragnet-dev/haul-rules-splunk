| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3282 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 2d8fa465-de55-58c2-9f8a-b6ff5d5f7d8e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
