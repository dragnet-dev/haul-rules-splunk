| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4005 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 34d41662-0553-52c9-b295-85a31ebbffe6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
