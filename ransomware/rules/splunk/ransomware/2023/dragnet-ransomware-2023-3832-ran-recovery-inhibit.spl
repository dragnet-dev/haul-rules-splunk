| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3832 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 16773fbc-7263-50f7-b61a-330f09b02f41"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
