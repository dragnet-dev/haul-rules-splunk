| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3150 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 59551490-0e11-539f-b9e6-beedaf54bacc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
