| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1053 — Recovery Inhibition (threeam)"
| comment "Status: experimental | Level: high | ID: 4026af55-bc24-5782-a6a9-07396fb492b7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
