| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4272 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: d3b3298a-b60a-5e0e-9a45-d3e22b93a8b4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
