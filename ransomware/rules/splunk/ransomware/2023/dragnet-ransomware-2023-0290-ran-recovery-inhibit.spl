| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0290 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 9e003a74-7eec-5380-bc9f-f70bc8ade33e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
