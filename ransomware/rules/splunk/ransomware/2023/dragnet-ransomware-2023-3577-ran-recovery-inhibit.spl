| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3577 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: a533f1bd-1371-54ca-9f2a-7b4461e285c3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
