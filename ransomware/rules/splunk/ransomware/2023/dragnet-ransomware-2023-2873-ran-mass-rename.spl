| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2873 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 7268205b-2462-50cc-a5fd-328f5a8d16a0"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
