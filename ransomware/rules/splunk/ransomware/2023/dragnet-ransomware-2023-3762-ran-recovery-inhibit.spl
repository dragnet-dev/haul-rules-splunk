| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3762 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 1ea234e7-5de6-5dda-a8c0-861e318633c8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
