| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1228 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 3d241535-1d4e-572b-9c56-0254d105fd3b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
