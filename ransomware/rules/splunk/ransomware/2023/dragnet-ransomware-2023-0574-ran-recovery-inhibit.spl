| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0574 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 058506cb-dcb4-5123-afb4-1cc1cba8dfd7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
