| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4484 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 6e7fa978-aedd-5c60-94b9-913b497a30f1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
