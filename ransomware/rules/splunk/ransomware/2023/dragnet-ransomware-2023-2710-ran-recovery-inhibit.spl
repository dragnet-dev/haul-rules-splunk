| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2710 — Recovery Inhibition (royal)"
| comment "Status: experimental | Level: high | ID: c19aedd9-3c93-5fd4-b85b-db500335f19e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
