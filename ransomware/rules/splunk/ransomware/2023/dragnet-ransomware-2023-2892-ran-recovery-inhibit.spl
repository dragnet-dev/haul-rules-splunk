| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2892 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 50438c4e-61c2-55ae-b5a0-8d63c51306a0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
