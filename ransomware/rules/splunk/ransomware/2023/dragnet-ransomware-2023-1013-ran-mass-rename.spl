| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1013 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: 97058b06-58bf-59c1-a6bc-61504ad8b7b6"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
