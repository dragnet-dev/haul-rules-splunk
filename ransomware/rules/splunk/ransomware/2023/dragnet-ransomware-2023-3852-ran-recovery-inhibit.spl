| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3852 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: e7e61f5c-f19b-5012-aee5-e5bca7719ef1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
