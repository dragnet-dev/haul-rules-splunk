| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0752 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 7c90cdca-1e3d-55bd-86e6-d30306bfe8b7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
