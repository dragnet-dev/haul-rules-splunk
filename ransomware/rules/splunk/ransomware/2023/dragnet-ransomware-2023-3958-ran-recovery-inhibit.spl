| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3958 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: ef1cab4d-8a7d-52c3-8238-916e3b24df77"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
