| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4531 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 799c78d7-a289-580a-9cc3-8bb8713df41e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
