| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0138 — Mass File Rename (monti)"
| comment "Status: experimental | Level: high | ID: 1a4a8e12-8631-59b4-91f2-44d56dcff95b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
