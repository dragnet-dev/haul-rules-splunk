| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4108 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 8908ddaf-f2b5-512e-90ad-fd9541ff6fb1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
