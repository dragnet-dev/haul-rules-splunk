| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3012 — Mass File Rename (stormous)"
| comment "Status: experimental | Level: high | ID: 2b8a4d55-cc07-565a-bddd-f571d486e3ec"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
