| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0364 — Recovery Inhibition (noescape)"
| comment "Status: experimental | Level: high | ID: e1304cf9-e63e-5179-aa8f-f3bae743e643"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
