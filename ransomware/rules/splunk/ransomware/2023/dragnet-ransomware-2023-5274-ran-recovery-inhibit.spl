| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5274 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 82af0c59-644d-5502-8e23-1687e0b2d508"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
