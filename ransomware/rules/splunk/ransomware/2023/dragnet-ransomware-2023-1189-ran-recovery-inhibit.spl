| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1189 — Recovery Inhibition (noescape)"
| comment "Status: experimental | Level: high | ID: 37cf3768-9e25-5904-882f-f717b8a058c0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
