| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0714 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 6b130403-8c01-59e7-a63f-9ac052e06b67"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
