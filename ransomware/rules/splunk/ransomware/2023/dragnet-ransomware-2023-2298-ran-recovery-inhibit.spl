| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2298 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: d51c8cd5-c3fe-56b6-b841-85982b713171"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
