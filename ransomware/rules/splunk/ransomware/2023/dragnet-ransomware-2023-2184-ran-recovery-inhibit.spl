| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2184 — Recovery Inhibition (noescape)"
| comment "Status: experimental | Level: high | ID: 132d4e75-fc6f-53bf-8bfa-0041c06de59d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
