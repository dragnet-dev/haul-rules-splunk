| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4098 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 1c123df1-2b4f-57af-acfc-b7c91ec4e83c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
