| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2826 — Recovery Inhibition (malas)"
| comment "Status: experimental | Level: high | ID: 627ad40e-8fd5-5c05-a37f-20c81190380c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
