| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4254 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: d7fd6096-2203-51d0-aa28-7fdfdb0ef7e9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
