| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3274 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 75105482-08c2-57aa-8144-d08d0a960a68"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
