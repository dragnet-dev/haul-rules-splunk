| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2169 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 7503b8cb-34bc-5817-8a26-7b3a606a42b3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
