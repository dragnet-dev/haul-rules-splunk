| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1893 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 3fbbe62c-a38f-597c-b2e3-a59086329192"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
