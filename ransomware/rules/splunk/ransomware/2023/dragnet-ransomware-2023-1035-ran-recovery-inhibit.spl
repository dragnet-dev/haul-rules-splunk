| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1035 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: c7d41ec6-9695-5544-8d35-8e7ee46c04bd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
