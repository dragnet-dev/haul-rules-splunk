| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3741 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 024fda28-649b-57d3-8453-f3d9484cce88"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
