| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4439 — Recovery Inhibition (royal)"
| comment "Status: experimental | Level: high | ID: 9bb0fb29-cb69-522e-92cc-eb39403ed55e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
