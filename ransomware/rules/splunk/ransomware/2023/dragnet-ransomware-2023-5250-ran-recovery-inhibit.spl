| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5250 — Recovery Inhibition (ransomed)"
| comment "Status: experimental | Level: high | ID: e19412c7-de03-53a3-b092-efdd569ed08f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
