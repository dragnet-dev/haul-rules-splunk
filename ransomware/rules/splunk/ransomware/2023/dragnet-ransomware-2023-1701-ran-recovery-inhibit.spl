| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1701 — Recovery Inhibition (ragnarlocker)"
| comment "Status: experimental | Level: high | ID: d5da285e-73b8-5e75-bcf9-a1d6de5179e8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
