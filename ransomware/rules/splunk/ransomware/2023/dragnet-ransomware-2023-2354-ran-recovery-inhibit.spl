| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2354 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: cbb961fa-e320-54d2-a84b-cb6f8fee01e6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
