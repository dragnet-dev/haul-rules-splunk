| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4178 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: bb02c08e-d223-5a70-909b-064fceb01bbc"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
