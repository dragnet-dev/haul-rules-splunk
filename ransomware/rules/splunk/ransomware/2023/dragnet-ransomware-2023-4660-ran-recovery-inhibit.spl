| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4660 — Recovery Inhibition (cuba)"
| comment "Status: experimental | Level: high | ID: 6f12fea5-5c78-545b-8c4f-9fddd1faedcc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
