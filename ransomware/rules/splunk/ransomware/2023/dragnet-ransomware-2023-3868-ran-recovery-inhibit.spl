| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3868 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 62451534-fca9-530e-9d89-6eaa6f972d90"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
