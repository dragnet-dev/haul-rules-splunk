| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0808 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: e3e4ee7b-9d54-545d-bc2b-485a5f937c9f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
