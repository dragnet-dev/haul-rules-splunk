| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5103 — Recovery Inhibition (noescape)"
| comment "Status: experimental | Level: high | ID: c027875a-f78d-5b64-8a75-162eb65151b2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
