| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2379 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 790c1576-c7fa-5ffe-a56f-862c56ca300f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
