| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3106 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 429412c7-1876-53fa-afc7-ce28277e5278"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
