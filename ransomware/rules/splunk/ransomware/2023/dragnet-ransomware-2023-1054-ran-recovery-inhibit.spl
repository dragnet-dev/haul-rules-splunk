| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1054 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: ac042665-b6d9-571a-9be3-de7cb7656996"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
