| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0889 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: c8ab1d87-5fa9-5f8f-aa9e-7ae7625b12ac"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
