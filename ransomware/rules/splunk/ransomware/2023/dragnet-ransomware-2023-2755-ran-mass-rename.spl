| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2755 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: e989355b-c064-55c2-8462-094eacd1629e"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
