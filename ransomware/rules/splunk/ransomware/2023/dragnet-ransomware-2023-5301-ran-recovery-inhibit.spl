| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5301 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 61db0359-ed25-5825-8be4-272839fbf4c2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
