| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2209 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: e32425b6-ab54-5c35-9eec-3170dfab5cbf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
