| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2190 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: f0407d69-f86c-5e64-b937-611f062b19fd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
