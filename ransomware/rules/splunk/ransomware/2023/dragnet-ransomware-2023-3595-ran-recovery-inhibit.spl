| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3595 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: a12a6f56-6fa7-5463-9bd9-01ee7cd2ba60"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
