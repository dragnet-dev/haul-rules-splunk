| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4367 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: b92c829c-d4f1-5828-a642-71b8bffa3d5d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
