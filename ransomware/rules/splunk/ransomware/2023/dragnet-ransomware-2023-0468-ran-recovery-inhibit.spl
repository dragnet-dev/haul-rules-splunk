| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0468 — Recovery Inhibition (royal)"
| comment "Status: experimental | Level: high | ID: 84275c74-38a4-564d-88e1-334600241c2c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
