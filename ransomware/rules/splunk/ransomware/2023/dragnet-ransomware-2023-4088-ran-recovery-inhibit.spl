| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4088 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 13b8e3c1-4ba3-5ea3-90df-dd59d6126c74"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
