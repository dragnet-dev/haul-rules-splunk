| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3607 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: f83f057c-9aaa-5ed8-b7b6-922d9154010a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
