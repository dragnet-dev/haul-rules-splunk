| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2887 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 5e3ddf11-a652-5985-b1a5-efea3b2fa077"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
