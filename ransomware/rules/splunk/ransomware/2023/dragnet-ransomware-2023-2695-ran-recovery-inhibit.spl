| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2695 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: ae3e8803-b5af-57f4-938f-106ba17435d2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
