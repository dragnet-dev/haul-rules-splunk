| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1755 — Recovery Inhibition (threeam)"
| comment "Status: experimental | Level: high | ID: 10b6547e-f361-58e0-aa1c-f32a0b126c2d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
