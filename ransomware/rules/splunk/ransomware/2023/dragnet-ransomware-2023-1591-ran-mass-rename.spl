| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1591 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: 95ea6c94-0d79-5cdb-be7c-7dbf732ea499"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
