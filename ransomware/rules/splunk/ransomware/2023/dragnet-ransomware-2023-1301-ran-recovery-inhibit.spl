| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1301 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 3ef9248b-70f4-52c1-a083-a1b793715d47"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
