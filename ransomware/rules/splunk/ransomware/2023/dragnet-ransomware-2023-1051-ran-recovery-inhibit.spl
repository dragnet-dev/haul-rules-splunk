| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1051 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: c3640878-3685-5458-bf49-c8cd48933673"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
