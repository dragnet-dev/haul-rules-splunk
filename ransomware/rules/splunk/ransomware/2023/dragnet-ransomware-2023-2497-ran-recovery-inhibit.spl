| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2497 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: a1b79eda-4db4-5e18-823d-b1bad52bb980"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
