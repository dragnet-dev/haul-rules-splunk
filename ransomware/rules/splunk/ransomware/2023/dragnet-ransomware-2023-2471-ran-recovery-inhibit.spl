| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2471 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: f645e187-c0bc-5b1f-9437-f7991ba3dc0a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
