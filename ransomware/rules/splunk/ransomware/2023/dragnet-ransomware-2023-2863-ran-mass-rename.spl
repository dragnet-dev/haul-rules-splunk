| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2863 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: e6ac078a-7c7d-5608-8d06-a9db27bead5f"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
