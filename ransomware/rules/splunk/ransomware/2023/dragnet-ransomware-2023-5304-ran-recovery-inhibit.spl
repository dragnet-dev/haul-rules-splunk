| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5304 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 5d7b46de-91e7-5981-a912-3b7fc462a88f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
