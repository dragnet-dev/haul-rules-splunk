| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0443 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: b287235d-a189-596f-ab0c-f69c1bf96b99"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
