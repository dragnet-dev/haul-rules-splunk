| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2702 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 61a0a2ce-7389-5c56-9a99-ba0270213ef2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
