| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1215 — Recovery Inhibition (yurei)"
| comment "Status: experimental | Level: high | ID: e6b17247-c5da-524f-b0a9-b63026de4281"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
