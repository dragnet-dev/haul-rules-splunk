| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5310 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 7f536d97-eb92-5cd7-ab5f-32f47d78600d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
