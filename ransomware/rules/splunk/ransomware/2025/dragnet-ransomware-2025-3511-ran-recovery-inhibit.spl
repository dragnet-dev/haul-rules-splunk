| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3511 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: e3b6dff5-d879-5d96-a421-4849073b7156"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
