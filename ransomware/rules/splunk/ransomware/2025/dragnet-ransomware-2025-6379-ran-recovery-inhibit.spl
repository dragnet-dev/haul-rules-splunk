| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6379 — Recovery Inhibition (everest)"
| comment "Status: experimental | Level: high | ID: 6b267322-e2de-56d8-a96f-10c7fa90e418"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
