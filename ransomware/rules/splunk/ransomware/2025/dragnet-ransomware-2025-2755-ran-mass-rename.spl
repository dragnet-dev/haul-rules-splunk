| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2755 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: da782ca9-3fe5-5898-90c4-aad34378c392"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
