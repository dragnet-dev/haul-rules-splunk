| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6097 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 52ec7b00-64f8-5f50-a4bc-8f95558dd37f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
