| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2310 — Recovery Inhibition (termite)"
| comment "Status: experimental | Level: high | ID: d61c8b4d-7a89-53eb-8908-eda427a0772e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
