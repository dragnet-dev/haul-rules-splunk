| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2451 — Recovery Inhibition (thegentlemen)"
| comment "Status: experimental | Level: high | ID: 96647326-c955-53b2-8d60-f6464026b5fa"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
