| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2765 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: a8ecb20a-7081-5753-b126-29fabd2d26d1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
