| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7667 — Recovery Inhibition (BrainCipher)"
| comment "Status: experimental | Level: high | ID: 1515786a-d3af-59c2-9527-3de676f81111"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
