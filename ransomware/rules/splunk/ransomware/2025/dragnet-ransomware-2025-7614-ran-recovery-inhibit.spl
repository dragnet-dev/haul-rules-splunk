| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7614 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: 32d043be-8b05-5a79-aa16-543affecd890"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
