| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1588 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: ba554a2c-a474-500a-b72f-30c74d6637e9"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
