| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1508 — Recovery Inhibition (interlock)"
| comment "Status: experimental | Level: high | ID: 733bd571-e665-5583-8f43-3880b7456a57"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
