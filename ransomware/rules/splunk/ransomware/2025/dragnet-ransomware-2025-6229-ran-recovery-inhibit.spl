| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6229 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: a33211e2-e231-5fc4-a3fe-53c0a03bfa49"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
