| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1974 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: 2efb2fda-ee4a-5971-aec2-1ac4aa5e9b01"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
