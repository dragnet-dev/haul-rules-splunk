| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3574 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 18baa832-df7f-5d48-9246-4aad6a70be9d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
