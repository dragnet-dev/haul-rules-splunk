| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7576 — Recovery Inhibition (nova)"
| comment "Status: experimental | Level: high | ID: 642c3d99-30d3-50f1-8724-da2160e6ba95"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
