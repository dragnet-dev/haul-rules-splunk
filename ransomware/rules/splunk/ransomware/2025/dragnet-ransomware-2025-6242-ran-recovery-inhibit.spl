| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6242 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 3d426a4a-f5ed-5c4f-8dd5-62fa779664b4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
