| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1733 — Recovery Inhibition (arcusmedia)"
| comment "Status: experimental | Level: high | ID: fa98a3ac-d696-5086-90e3-3b50d7a81b6a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
