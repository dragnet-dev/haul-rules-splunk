| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3392 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 300a4a32-f3b8-51f2-a502-289df249de67"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
