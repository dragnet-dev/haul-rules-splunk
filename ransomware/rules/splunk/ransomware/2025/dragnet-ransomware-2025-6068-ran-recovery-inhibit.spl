| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6068 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: 291a0fa4-ceca-5226-ba99-75a71789a0f5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
