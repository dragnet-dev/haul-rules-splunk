| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7889 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 8933cdb3-1655-5965-aacb-18ebcb5c0306"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
