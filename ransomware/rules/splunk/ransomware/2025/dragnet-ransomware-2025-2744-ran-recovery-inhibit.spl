| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2744 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: e8f45e0d-5a2d-5077-baf3-c7f359df9a82"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
