| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5429 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: 094bf86f-8035-50c7-bf9c-53b8de85b78f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
