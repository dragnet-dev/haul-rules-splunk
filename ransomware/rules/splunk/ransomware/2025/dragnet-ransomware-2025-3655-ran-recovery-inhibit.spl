| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3655 — Recovery Inhibition (nova)"
| comment "Status: experimental | Level: high | ID: 5ce5a59f-b01f-5bd0-ab5b-bf8f6424c45f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
