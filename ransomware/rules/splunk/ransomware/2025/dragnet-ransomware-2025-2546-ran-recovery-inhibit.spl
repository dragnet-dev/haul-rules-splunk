| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2546 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 225ff4b7-84e4-5d56-a343-d8d2ffbea37d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
