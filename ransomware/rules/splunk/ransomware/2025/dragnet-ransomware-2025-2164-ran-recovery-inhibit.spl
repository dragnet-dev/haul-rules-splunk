| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2164 — Recovery Inhibition (nova)"
| comment "Status: experimental | Level: high | ID: 5ec6160d-0d98-5a09-91a4-bfd1b88d16ef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
