| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3464 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 43315625-a877-51f9-bd17-1740ba0f7858"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
