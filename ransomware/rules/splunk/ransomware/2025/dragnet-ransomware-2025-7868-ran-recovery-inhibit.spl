| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7868 — Recovery Inhibition (J)"
| comment "Status: experimental | Level: high | ID: 7c4a7593-05dd-53dd-9a28-641c09ec7efe"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
