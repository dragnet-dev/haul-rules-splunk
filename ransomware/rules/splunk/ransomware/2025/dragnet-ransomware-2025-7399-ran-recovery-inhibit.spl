| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7399 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 0c43ce67-02d2-520e-bcfd-e1ee9d6075d5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
