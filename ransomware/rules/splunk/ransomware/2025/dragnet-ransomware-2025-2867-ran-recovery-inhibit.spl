| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2867 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 1a84aa2c-0b7f-5ae5-82ce-381ef67d348e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
