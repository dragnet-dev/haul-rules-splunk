| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0609 — Recovery Inhibition (apos)"
| comment "Status: experimental | Level: high | ID: 706a6b6b-8c7a-529e-986d-70a16efccc74"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
