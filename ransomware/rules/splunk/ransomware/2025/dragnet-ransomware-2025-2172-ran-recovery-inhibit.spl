| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2172 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 4c45564c-1cc7-58be-960f-5300cc793a0a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
