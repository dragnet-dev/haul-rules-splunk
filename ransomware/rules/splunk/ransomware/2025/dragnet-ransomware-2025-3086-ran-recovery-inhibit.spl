| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3086 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: c1525d54-fa7f-528b-85e9-1ed7c549463e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
