| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2767 — Recovery Inhibition (nitrogen)"
| comment "Status: experimental | Level: high | ID: e82d99ad-e502-52a6-8ba4-5afb992afead"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
