| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7374 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: adbfefff-6d99-593e-bf92-c0ffd0e12e70"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
