| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3238 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: ed837b67-c938-5d37-8d1a-e2d923c2280f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
