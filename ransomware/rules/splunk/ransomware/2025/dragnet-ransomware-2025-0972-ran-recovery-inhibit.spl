| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0972 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: a6dbd8c8-3332-501b-ba46-ec0cc50c068e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
