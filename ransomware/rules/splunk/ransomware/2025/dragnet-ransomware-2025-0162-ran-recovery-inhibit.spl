| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0162 — Recovery Inhibition (ransomhouse)"
| comment "Status: experimental | Level: high | ID: 2562ff24-bb59-5389-8bcb-27a63c72344b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
