| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0301 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: c0e80e4e-78c7-51fd-a7c2-d0ed8348e27d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
