| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6491 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 71167949-a936-5644-bdef-fc2e8ae1b581"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
