| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1734 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 459467b3-bb07-5012-850a-50344a47abcb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
