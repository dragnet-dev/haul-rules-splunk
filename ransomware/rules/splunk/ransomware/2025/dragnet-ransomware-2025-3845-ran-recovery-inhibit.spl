| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3845 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 4b45cfd8-23cd-541e-8753-ccd0489d595b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
