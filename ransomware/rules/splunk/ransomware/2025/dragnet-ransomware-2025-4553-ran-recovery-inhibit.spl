| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4553 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 1edc5c45-1c37-5fad-9f2b-44f1dceeebe7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
