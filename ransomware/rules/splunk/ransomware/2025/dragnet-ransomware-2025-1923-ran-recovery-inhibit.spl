| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1923 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 6c800bfd-57d4-5dbc-ba81-0147a8838719"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
