| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5093 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: 09fdec81-0c1f-54a0-a996-ef1bfdbc45d8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
