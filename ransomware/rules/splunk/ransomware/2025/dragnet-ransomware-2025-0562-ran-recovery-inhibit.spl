| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0562 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 0b2e2ff5-47f5-503f-827a-566b9dded7f5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
