| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2064 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: 4526acf4-7613-5850-8522-a5fcbfb3ab7c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
