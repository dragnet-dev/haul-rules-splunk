| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0453 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: f2cd8597-461e-5e4f-bb8b-51f3d051bc49"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
