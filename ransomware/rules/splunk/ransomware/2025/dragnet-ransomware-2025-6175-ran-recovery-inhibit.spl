| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6175 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: 20a1e2f9-dd19-5f7c-b127-0ffbb7efaad0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
