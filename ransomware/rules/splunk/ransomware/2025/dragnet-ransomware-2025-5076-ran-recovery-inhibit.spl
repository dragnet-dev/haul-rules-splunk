| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5076 — Recovery Inhibition (GDLockerSec)"
| comment "Status: experimental | Level: high | ID: 90ee6214-732e-5f63-8377-fc347e31dacc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
