| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6643 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 13a9c46c-dbea-5697-9d78-0915744353f5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
