| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0859 — Recovery Inhibition (pear)"
| comment "Status: experimental | Level: high | ID: af6e8530-c3ce-5944-849d-7fd9c66c2632"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
