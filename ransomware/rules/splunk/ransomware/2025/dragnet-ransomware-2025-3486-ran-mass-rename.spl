| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3486 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: d4483393-d82e-5d3b-be4c-a891cec543a9"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
