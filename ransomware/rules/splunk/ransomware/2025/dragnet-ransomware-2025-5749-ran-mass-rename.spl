| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5749 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 992896e6-3d34-505b-b31a-4c1984b63551"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
