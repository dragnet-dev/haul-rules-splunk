| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0809 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 1c2105a6-1942-5de2-9a4d-68be8d30a373"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
