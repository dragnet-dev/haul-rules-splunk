| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6791 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 4aed708d-13dc-5652-8b50-627abacb856a"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
