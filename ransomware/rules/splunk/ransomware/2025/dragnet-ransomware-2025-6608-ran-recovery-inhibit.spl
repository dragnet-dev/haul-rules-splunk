| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6608 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 2aae483b-738c-5fb5-896b-e868a8abb930"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
