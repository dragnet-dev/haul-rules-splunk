| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1029 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: bab8c5be-1207-5cbb-b743-10653f2bdd82"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
