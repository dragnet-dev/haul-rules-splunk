| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2850 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 23bf5bde-39bf-5c38-a1df-6b6ab6983dae"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
