| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7274 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 28b26e07-3ac4-5192-a3af-b1a45cedbc72"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
