| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5807 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 767508df-6c0b-5fe6-bd8d-2accd46845f2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
