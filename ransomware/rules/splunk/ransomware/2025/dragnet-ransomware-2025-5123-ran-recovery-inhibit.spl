| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5123 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: c79567d0-fc08-53a8-8ae5-a6973f783e14"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
