| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7319 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: ebca574c-45c8-5ae5-b7c0-af6f60af4d94"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
