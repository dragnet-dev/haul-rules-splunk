| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2780 — Recovery Inhibition (rhysida)"
| comment "Status: experimental | Level: high | ID: e980c606-fa87-5d6f-a6bf-5883da269595"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
