| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6249 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 92685f47-9c1e-50e9-aaf7-43572bf6c570"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
