| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7189 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: c9cee5ec-5379-58b5-852e-1d5884c39d7e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
