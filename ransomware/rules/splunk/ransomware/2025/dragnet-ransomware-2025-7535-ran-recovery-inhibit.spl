| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7535 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 8fc84308-47d9-5a8a-84e1-37892b9675d3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
