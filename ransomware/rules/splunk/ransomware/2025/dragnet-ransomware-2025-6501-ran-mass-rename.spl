| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6501 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 2efb3d57-6f70-5c26-a19a-160b244704dc"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
