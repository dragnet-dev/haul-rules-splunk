| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4354 — Recovery Inhibition (payoutsking)"
| comment "Status: experimental | Level: high | ID: 3d794221-a7ca-5f3a-8b8b-edfed7e14dfa"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
