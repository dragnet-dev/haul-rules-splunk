| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4055 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 05efb252-9550-5cbf-a5bf-37c6f9cad5da"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
