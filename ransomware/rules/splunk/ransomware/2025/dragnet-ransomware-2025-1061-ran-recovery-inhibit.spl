| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1061 — Recovery Inhibition (J)"
| comment "Status: experimental | Level: high | ID: e07b2886-fe53-5963-a108-4381fa985fef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
