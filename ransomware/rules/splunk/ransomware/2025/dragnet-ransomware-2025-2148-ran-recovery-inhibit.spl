| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2148 — Recovery Inhibition (J)"
| comment "Status: experimental | Level: high | ID: bfc0ce71-6959-5d42-a111-9e7c79fadb83"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
