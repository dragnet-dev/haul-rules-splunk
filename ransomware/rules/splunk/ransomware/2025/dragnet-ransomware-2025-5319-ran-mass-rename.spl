| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5319 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: ffdc19fd-2945-5726-a566-519cd5d4b53c"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
