| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7418 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 7260324c-2645-58bb-a6f0-2e9da8ac7934"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
