| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1771 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: 251f05f1-7eac-535a-9187-9dd26445e857"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
