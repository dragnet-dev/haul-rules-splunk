| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6547 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 2a1f4225-812c-59fd-9e42-fe5fa64688ac"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
