| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0723 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: a68e65c4-6d6d-5998-b6ef-10d13a3c08bf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
