| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1179 — Recovery Inhibition (cicada3301)"
| comment "Status: experimental | Level: high | ID: a997f6c4-968c-5b4a-b698-84e7ed5f70b6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
