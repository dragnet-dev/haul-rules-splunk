| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7700 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 5938b109-ea79-5fb2-b936-23ca9b8b6802"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
