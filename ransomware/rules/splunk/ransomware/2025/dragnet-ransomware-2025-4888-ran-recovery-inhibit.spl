| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4888 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: a1a09464-f1ac-5f79-8e4d-0cc55b4865f8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
