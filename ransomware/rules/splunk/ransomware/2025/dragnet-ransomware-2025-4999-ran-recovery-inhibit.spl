| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4999 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: eecd91fe-e161-53e6-93ec-b6b5d9d25314"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
