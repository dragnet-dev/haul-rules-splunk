| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7695 — Recovery Inhibition (nova)"
| comment "Status: experimental | Level: high | ID: 58f7fdfc-7b40-5574-bb55-7ac7c2ea26bf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
