| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3644 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 3be91338-04f3-5908-b7b5-7e88a66aafbd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
