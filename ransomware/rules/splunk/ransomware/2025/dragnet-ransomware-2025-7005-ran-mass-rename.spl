| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7005 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: de70d42c-d0dc-5176-8422-833fbb10f0c3"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
