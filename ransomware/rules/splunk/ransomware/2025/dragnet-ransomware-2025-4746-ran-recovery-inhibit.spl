| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4746 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: beba05c9-6656-57e1-aeb2-1444ced4ea47"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
