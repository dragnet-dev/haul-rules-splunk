| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2218 — Mass File Rename (qilin)"
| comment "Status: experimental | Level: high | ID: b6ed4d47-43ac-53dc-9654-1bdcfb778e12"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
