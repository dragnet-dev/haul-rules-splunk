| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1245 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: bde786dd-2892-57f5-8a6a-a7227aaff947"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
