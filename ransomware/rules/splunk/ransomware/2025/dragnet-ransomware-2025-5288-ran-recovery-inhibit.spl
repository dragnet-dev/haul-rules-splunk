| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5288 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 630cbf1d-1805-5745-ba4e-2756bc654c2c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
