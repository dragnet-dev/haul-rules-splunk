| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7839 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: 4bb67d19-455a-5345-9e22-f8f23dda6667"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
