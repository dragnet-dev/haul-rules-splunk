| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3658 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 0a4ed541-500a-5d64-a4c3-26e173a39f33"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
