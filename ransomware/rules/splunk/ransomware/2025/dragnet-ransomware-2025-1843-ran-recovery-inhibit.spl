| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1843 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 91c1c7d6-c149-5d79-958c-65a98280e77d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
