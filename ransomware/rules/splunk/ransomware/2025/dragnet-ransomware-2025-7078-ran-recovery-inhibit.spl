| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7078 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: 4154bc3f-a6ef-5c06-a3ab-2e0fb3fd6f81"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
