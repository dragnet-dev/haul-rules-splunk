| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4277 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: b8ce755c-c14a-53b6-8e3c-556a6abad89f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
