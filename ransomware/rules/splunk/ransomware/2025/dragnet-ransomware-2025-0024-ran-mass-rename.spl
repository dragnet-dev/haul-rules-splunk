| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0024 — Mass File Rename (gunra)"
| comment "Status: experimental | Level: high | ID: 5aa52d3e-1da4-5633-bee6-3264af9df353"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
