| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2762 — Recovery Inhibition (ransomhouse)"
| comment "Status: experimental | Level: high | ID: fa2f065e-14ce-5fbe-bc7f-a7ae6e6664a8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
