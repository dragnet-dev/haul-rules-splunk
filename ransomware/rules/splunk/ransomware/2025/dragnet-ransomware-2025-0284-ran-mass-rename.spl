| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0284 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: f540c094-d93b-51a4-a7ea-b4053203a1d5"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
