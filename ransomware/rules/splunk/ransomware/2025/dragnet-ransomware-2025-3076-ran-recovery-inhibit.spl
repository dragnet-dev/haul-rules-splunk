| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3076 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 5ed34d24-3312-5577-805d-a0a9b067e173"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
