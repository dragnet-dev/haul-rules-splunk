| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2352 — Recovery Inhibition (arcusmedia)"
| comment "Status: experimental | Level: high | ID: 0c91962b-8dcc-559f-a73d-a90c851b4a9b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
