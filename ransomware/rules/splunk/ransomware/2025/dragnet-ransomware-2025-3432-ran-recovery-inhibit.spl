| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3432 — Recovery Inhibition (secp0)"
| comment "Status: experimental | Level: high | ID: 64c29ba4-ac31-58fe-ab28-64cd02d23611"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
