| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4521 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 12831b39-6d63-59bd-9497-dbf0a5cb6c66"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
