| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4127 — Recovery Inhibition (blackshrantac)"
| comment "Status: experimental | Level: high | ID: 07d041e0-8203-5da1-8bc7-7a6c9967bd85"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
