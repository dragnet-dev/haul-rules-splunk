| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7344 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 79a71254-7c67-5171-8e45-64edc4fd1bc3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
