| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7908 — Recovery Inhibition (BrainCipher)"
| comment "Status: experimental | Level: high | ID: 84ed427e-cf61-5932-b9be-9d727424c111"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
