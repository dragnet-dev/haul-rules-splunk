| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0811 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: fc6f273c-bdcd-5182-b500-2e7b2b1510b4"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
