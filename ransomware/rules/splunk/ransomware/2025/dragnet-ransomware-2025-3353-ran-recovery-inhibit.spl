| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3353 — Recovery Inhibition (everest)"
| comment "Status: experimental | Level: high | ID: f19827a4-62de-52e3-aa5d-e8f3ec0bb7f3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
