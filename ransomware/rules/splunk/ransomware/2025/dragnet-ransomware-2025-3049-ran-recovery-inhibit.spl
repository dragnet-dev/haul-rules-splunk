| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3049 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 50353591-c14a-584d-b4f9-c4bff514579e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
