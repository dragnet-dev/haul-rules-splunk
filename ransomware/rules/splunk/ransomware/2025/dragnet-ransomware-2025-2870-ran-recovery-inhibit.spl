| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2870 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 3486ecca-36c6-5173-9be1-b7c077b9c270"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
