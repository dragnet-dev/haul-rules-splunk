| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2383 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 8f1a172f-34c6-53f5-94bb-a2fc090995bb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
