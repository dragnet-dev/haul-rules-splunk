| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3010 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 6477c0b9-b7a1-5556-bf48-b2daadf4d177"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
