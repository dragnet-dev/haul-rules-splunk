| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0513 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 5a158ba4-d630-54c9-bed1-e374ca7405f6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
