| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0467 — Recovery Inhibition (obscura)"
| comment "Status: experimental | Level: high | ID: d0ab79b7-cd6e-507b-894a-be6b4fc96965"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
