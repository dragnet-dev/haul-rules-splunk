| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1311 — Recovery Inhibition (kairos)"
| comment "Status: experimental | Level: high | ID: cc5c4152-1ded-5488-bba1-489460264041"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
