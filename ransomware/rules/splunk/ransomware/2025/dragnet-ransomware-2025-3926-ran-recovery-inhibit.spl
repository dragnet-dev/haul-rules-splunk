| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3926 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: e4aac1fa-fc5b-586a-9b85-111e0e3b26dc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
