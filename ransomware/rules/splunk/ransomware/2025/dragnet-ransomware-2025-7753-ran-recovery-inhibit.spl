| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7753 — Recovery Inhibition (handala)"
| comment "Status: experimental | Level: high | ID: c89c7507-b743-5490-a1aa-52cb003eed41"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
