| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3967 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: ef23e377-f29a-50e1-978d-370458d0a459"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
