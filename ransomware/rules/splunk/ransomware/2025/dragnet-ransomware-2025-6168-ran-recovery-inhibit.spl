| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6168 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 1e460c76-9e1c-5a86-addd-0fb6e3dcb1a8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
