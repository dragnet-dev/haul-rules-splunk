| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3877 — Recovery Inhibition (payoutsking)"
| comment "Status: experimental | Level: high | ID: 5a566e9c-5c68-5168-a4ac-7cad2d5d4113"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
