| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2899 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 09c6d029-eae9-51b0-9e92-c8323e19226f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
