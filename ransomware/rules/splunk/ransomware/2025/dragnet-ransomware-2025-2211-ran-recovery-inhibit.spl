| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2211 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: 477283a4-33b9-5ad9-aa78-e9c70c4b1e1b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
