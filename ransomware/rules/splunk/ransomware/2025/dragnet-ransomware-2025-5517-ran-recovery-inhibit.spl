| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5517 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: c2cf76dd-9bb3-5105-9289-967d14b414b4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
