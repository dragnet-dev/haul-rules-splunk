| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6530 — Recovery Inhibition (everest)"
| comment "Status: experimental | Level: high | ID: 67bd456d-17ab-53f1-8294-6b52b0765023"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
