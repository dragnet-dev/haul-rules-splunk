| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2730 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: cc3d66ef-0be9-5621-a752-3cae3e003a55"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
