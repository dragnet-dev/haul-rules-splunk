| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1072 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: fa0baf3b-d423-5a8e-9de6-14c9462d6fae"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
