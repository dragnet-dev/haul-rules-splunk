| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3507 — Recovery Inhibition (direwolf)"
| comment "Status: experimental | Level: high | ID: 8bc79ad7-bcd4-54db-b8d9-8391800cdddc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
