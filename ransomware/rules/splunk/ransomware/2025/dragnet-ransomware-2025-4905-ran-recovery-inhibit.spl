| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4905 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: d702b622-2f4f-5950-9da1-3e9e93832f4e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
