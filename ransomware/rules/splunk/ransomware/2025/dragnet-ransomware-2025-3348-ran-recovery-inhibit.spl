| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3348 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: eedc2894-e6e0-5d9f-813a-99084975a2e0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
