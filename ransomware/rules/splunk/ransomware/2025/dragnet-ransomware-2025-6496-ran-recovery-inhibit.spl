| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6496 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 06a2d185-eb57-539b-a2e0-e6f847f2cbbd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
