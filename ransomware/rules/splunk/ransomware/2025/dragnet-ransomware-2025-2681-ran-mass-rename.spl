| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2681 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 279c376e-22aa-5ae2-be89-7a43b45e9818"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
