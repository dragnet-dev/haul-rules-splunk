| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3937 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 524375d7-1d63-56ea-bbcf-2b3e9dee6239"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
