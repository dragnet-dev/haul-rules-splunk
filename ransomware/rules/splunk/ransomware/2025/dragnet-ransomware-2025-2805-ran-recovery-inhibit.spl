| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2805 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 38664040-5a92-59c3-8458-667995ba9c05"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
