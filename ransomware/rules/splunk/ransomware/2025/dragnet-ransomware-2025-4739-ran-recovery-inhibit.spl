| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4739 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: e782254a-36e1-5fe6-a5f5-88f803cbe312"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
