| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3928 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 5c4f01b3-3c4b-585f-8ce1-676ba5e7d878"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
