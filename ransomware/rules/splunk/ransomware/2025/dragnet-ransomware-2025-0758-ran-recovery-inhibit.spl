| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0758 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: d57312e1-4875-5d9e-b76c-184a26be9344"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
