| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2931 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: c134063d-289f-5fde-9340-e0f475f3577c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
