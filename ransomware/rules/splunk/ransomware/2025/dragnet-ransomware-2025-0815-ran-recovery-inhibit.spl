| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0815 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 265b4b83-7a44-5edc-b543-e804b91948ef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
