| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1651 — Recovery Inhibition (IMNCrew)"
| comment "Status: experimental | Level: high | ID: 16846e7f-3dee-5f97-8a87-cb66129aa95b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
