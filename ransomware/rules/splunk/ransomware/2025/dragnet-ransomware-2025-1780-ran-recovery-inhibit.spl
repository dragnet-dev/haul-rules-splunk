| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1780 — Recovery Inhibition (bqtlock)"
| comment "Status: experimental | Level: high | ID: 5f5be3fb-724b-5f6d-afce-724f5415e8f2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
