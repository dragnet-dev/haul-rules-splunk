| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7872 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 24862f32-7c9a-54ab-a2c2-6e340a8de970"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
