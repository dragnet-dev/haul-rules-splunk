| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0304 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: ae6ac2b9-980a-59c6-95fd-868c974e0d76"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
