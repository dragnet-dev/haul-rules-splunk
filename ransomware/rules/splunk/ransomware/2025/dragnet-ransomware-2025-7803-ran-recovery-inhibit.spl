| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7803 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 01bfa643-74be-5589-b5c5-75d429106cb9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
