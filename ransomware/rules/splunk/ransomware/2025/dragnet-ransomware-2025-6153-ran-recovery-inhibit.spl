| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6153 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: c2c97ab8-1c75-5340-81a2-dc7e1d57adc0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
