| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0460 — Recovery Inhibition (J)"
| comment "Status: experimental | Level: high | ID: 386c885e-df1c-5a81-92ec-804457daa6d3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
