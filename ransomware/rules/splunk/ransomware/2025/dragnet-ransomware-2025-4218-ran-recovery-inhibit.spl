| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4218 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 2fc35355-6cd2-55b2-b3e2-2c0de049bee2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
