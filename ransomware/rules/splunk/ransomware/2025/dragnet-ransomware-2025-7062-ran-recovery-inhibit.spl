| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7062 — Recovery Inhibition (devman)"
| comment "Status: experimental | Level: high | ID: fe4c59ce-7604-587e-94e5-63dd20ad576a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
