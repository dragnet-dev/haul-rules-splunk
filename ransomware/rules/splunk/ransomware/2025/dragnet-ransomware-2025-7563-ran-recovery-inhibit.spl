| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7563 — Recovery Inhibition (nova)"
| comment "Status: experimental | Level: high | ID: b75203dd-b7a2-5ab2-acbd-4535a51995b5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
