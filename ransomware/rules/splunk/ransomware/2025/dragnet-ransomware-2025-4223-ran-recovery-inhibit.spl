| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4223 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: d1f9f853-5dab-5abb-9298-7206cdc14e38"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
