| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1791 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 875b6a8b-2abe-584e-a420-95da2762fca8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
