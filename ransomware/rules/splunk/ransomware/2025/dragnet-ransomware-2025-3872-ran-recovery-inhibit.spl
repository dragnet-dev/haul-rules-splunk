| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3872 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 0d03c8fa-25ef-5647-8e4d-e1b4b5dde52b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
