| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1344 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 949b881d-3bc7-5fbf-86b3-27a310124df9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
