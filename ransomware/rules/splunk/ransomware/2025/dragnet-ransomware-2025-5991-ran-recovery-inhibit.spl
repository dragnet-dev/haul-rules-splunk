| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5991 — Recovery Inhibition (chaos)"
| comment "Status: experimental | Level: high | ID: 7553a47a-df18-5745-acab-8f92b66b1f11"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
