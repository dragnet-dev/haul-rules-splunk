| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3583 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: afd45ee7-3364-5eb4-87cd-5d57414bc420"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
