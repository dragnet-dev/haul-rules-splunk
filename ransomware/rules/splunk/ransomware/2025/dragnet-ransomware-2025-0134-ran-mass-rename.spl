| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0134 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 7a0471b6-63bf-5992-a278-dee11e410e8d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
