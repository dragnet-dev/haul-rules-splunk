| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1544 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: a3537c4a-f7d9-5b36-88ef-7cce78e66fda"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
