| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0410 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: a7b0850c-5f72-5e54-8d50-a72032a28b6b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
