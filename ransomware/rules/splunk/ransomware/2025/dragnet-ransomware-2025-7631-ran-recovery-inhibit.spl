| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7631 — Recovery Inhibition (pear)"
| comment "Status: experimental | Level: high | ID: ec79c278-f5dc-51b4-805a-fa5c69f9ce02"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
