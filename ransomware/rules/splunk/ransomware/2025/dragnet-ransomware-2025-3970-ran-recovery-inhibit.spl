| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3970 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: e3499231-de7f-5b05-b0e7-f68917fc6b8a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
