| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6398 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: 320ef905-a090-5641-8a28-bcd56e66adb5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
