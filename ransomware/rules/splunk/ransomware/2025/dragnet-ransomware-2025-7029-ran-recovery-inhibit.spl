| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7029 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: cbbde531-9571-5c40-89a3-7185141bb176"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
