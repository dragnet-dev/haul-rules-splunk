| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1071 — Recovery Inhibition (obscura)"
| comment "Status: experimental | Level: high | ID: 6594f6ca-4d2a-513d-a01b-075b20cf7f03"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
