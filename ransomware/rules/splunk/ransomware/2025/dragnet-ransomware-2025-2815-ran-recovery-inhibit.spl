| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2815 — Recovery Inhibition (warlock)"
| comment "Status: experimental | Level: high | ID: 3c2ce7a3-121b-57d8-ba8f-6aa64c406960"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
