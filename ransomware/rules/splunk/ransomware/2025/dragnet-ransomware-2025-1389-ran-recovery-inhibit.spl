| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1389 — Recovery Inhibition (direwolf)"
| comment "Status: experimental | Level: high | ID: 9e7b7e1f-1b17-5dd0-85ff-9143913081e9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
