| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3121 — Recovery Inhibition (blacklock)"
| comment "Status: experimental | Level: high | ID: 42837b93-5420-5487-b5d8-4d3cac6875b4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
