| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1218 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 7ed05562-5b57-5989-bacc-c26fabe1ad5f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
