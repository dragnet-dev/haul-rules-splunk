| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7325 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 45a3575f-a049-5215-82d5-8b1092bdbd40"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
