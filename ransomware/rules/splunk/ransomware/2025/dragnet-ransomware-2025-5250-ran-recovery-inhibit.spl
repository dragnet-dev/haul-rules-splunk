| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5250 — Recovery Inhibition (sinobi)"
| comment "Status: experimental | Level: high | ID: 52769340-d52a-5cfe-b588-f1ce8d973b31"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
