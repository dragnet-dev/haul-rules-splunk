| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6487 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 303f1eb7-55c7-5ec0-ba21-088cffa54392"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
