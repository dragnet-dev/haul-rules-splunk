| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5334 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 8883bc38-5920-5334-83bc-a4ea7489653a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
