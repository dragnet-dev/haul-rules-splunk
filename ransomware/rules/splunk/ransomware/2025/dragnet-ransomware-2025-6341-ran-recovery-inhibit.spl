| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6341 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 65ccd558-211c-52c5-8286-fd60324947cb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
