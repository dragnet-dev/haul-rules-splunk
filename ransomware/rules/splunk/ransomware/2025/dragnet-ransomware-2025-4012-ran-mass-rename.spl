| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4012 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 6bcd4166-fe5a-5118-a8e1-da9c3b7608a0"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
