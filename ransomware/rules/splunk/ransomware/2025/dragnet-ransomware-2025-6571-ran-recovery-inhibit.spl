| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6571 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: 3c1fcd76-c9f8-59d9-a6a3-a0b8d716590e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
