| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5969 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: f45be597-ab76-5d4c-b5ff-277468e432a4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
