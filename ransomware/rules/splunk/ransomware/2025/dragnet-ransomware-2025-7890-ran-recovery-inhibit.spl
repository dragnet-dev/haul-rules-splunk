| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7890 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 58a25732-06a5-5746-9a1a-fd7c56912f05"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
