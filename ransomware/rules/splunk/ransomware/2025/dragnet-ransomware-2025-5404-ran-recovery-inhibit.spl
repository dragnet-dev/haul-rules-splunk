| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5404 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 469043d2-7e91-5de1-9eff-baf81602f08c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
