| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7359 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 3fb54da7-7c54-5092-9f04-92b727dcb3da"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
