| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7534 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 5b922935-ee8d-5bb8-ada5-beb00a049f9e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
