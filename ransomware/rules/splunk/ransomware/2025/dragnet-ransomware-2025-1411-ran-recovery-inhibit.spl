| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1411 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 8d7a7ae0-6ab5-5c10-b213-c1cac1b7e1c0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
