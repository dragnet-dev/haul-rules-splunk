| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1727 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 30e66c04-eae9-5f91-81fa-0928e1795863"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
