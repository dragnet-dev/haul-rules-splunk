| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5664 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: bca1e52e-4f56-5a3b-8562-28f72f9fad1c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
