| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4975 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 07a0932a-fda0-5cd7-b4a2-54142d6d2472"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
