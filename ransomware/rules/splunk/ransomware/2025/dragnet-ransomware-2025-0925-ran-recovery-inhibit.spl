| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0925 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 87218936-a5eb-5564-a879-0a59e38d2d1d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
