| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1285 — Mass File Rename (incransom)"
| comment "Status: experimental | Level: high | ID: a92b6c50-6740-5ce6-b15e-0d678defce7e"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
