| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7605 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 48b26ae1-cc06-5a60-a2be-eeabaf7758e1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
