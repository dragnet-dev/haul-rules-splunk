| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0349 — Recovery Inhibition (crazyhunter)"
| comment "Status: experimental | Level: high | ID: a789bc5f-d0ed-5b52-809d-e457cdf93558"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
