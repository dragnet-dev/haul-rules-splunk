| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5816 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 5dee6067-428d-5d7a-a93e-fb07e2b72448"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
