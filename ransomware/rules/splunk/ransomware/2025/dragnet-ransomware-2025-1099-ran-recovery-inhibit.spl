| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1099 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 4a9c347a-84ca-5754-b9da-e04279073ce7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
