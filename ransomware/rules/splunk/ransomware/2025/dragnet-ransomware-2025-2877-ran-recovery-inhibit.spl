| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2877 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: dff1d64c-acf5-5b1b-8d5a-75efe49f7a43"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
