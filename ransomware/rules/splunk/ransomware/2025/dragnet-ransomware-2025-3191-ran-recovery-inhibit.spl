| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3191 — Recovery Inhibition (chaos)"
| comment "Status: experimental | Level: high | ID: c1a1a00e-9c58-5f42-97d5-700f0f467165"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
