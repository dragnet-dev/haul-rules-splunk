| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3636 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: 25f3665c-f5b5-500f-b5a7-0472151f6f7e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
