| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1794 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: f58696d2-5579-5dcc-82e3-783d02fb7c1e"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
