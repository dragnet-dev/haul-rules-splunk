| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7588 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: 35599b10-1519-5028-9cd7-87265f70a052"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
