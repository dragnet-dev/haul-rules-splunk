| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7174 — Recovery Inhibition (blacknevas)"
| comment "Status: experimental | Level: high | ID: 852576b5-872f-5bbc-a10c-adb1ebc41c1f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
