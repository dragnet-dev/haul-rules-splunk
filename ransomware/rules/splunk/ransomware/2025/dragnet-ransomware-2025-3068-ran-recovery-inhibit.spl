| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3068 — Recovery Inhibition (everest)"
| comment "Status: experimental | Level: high | ID: f2a5cd38-8409-511b-9bc8-9a1b56ff84a7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
