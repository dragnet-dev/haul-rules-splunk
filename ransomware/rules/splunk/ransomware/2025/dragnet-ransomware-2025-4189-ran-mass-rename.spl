| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4189 — Mass File Rename (qilin)"
| comment "Status: experimental | Level: high | ID: aa383c3e-0b33-5172-98be-9213e06131e1"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
