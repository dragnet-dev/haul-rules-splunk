| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3506 — Recovery Inhibition (shinyhunters)"
| comment "Status: experimental | Level: high | ID: 03a774d8-7e27-525e-ba3d-b6cf06c101b0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
