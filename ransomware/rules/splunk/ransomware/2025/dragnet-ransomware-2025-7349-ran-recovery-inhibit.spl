| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7349 — Recovery Inhibition (devman)"
| comment "Status: experimental | Level: high | ID: 619904d6-1354-57ea-a8bc-66264dd1cd50"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
