| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5362 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 3e896620-a0ca-5e39-8ed3-b1fab378f87e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
