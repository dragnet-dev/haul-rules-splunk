| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2741 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: ace079f2-a2c0-5782-bf4a-063a87bce5ae"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
