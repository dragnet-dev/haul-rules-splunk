| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2333 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 6c8c6c6a-3902-5b32-9ad2-c3e68e5bc61f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
