| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1615 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: 3b44a712-d362-521e-838c-b5a93605b1ff"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
