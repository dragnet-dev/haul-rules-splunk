| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5315 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: e0a65547-8afe-563e-94fa-dd69529d79bc"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
