| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6804 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: d4e6de06-3201-5098-9f09-dbabfa1ec3e8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
