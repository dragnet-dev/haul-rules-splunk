| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1518 — Recovery Inhibition (flocker)"
| comment "Status: experimental | Level: high | ID: c15679a4-ca93-5e76-a761-d718d13a6b05"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
