| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5605 — Recovery Inhibition (kairos)"
| comment "Status: experimental | Level: high | ID: 671e3fbe-9206-53a2-bd5d-2916935ec80b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
