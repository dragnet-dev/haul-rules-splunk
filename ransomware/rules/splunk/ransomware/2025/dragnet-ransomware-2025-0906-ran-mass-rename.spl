| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0906 — Mass File Rename (incransom)"
| comment "Status: experimental | Level: high | ID: 7db8db93-2177-503a-98e7-beed4d319ba7"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
