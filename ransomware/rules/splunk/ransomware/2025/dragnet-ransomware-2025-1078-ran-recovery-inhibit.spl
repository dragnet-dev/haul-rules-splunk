| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1078 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: d594315e-c83a-5452-841d-2a2c38ff598d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
