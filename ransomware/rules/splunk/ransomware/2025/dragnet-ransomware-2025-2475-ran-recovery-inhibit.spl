| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2475 — Recovery Inhibition (thegentlemen)"
| comment "Status: experimental | Level: high | ID: 00f6d239-b9fb-5ca2-9196-28ad36bddb88"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
