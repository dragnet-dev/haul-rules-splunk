| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6495 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: b67165e9-34ad-56fe-91fa-40813742b114"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
