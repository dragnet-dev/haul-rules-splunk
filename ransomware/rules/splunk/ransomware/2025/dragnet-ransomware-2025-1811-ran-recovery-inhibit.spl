| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1811 — Recovery Inhibition (arcusmedia)"
| comment "Status: experimental | Level: high | ID: 8bbcf89f-0790-5478-a1ee-31284b75dbc9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
