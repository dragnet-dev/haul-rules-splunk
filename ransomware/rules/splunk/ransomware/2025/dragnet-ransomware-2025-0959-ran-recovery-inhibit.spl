| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0959 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: 27e19527-50c6-577b-9958-795e815f0d81"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
