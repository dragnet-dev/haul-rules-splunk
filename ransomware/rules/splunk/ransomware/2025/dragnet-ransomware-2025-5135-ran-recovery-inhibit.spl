| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5135 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 43b0339c-858c-506b-ac59-95c4bad14f1c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
