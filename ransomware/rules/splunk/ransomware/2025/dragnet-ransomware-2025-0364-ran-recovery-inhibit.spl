| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0364 — Recovery Inhibition (funksec)"
| comment "Status: experimental | Level: high | ID: 60b3bd50-bbce-5d80-8969-eac94fd59b6c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
