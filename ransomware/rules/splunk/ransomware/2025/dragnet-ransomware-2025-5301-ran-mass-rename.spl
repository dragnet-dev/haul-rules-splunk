| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5301 — Mass File Rename (flocker)"
| comment "Status: experimental | Level: high | ID: 9964ad89-969e-5395-b1c8-d220281f3362"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
