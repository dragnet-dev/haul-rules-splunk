| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5199 — Recovery Inhibition (sinobi)"
| comment "Status: experimental | Level: high | ID: 108f14b3-0484-5d7c-a086-5fc45ac5a8f6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
