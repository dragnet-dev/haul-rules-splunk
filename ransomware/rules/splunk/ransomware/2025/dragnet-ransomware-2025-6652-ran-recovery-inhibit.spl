| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6652 — Recovery Inhibition (blackshrantac)"
| comment "Status: experimental | Level: high | ID: f50d0a52-8477-58c5-81de-760cffe67734"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
