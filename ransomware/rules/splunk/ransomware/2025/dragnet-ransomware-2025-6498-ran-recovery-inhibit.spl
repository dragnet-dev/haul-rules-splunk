| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6498 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 84fce6d5-2b84-5ee3-a37e-25cfdeeb3560"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
