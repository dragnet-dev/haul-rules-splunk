| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2697 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: ec2c9082-b598-565a-91e7-7cc16a86b791"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
