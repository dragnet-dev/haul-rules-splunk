| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2737 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 5f3ec982-e648-5150-b453-ef157749599b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
