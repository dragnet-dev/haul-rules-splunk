| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0133 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 8dbc49f3-aef7-5da6-a42d-71bb51ad2d1b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
