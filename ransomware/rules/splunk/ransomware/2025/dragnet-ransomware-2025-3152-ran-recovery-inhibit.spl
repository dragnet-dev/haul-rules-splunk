| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3152 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 541190c7-322d-57c0-b5ef-806520caf07e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
