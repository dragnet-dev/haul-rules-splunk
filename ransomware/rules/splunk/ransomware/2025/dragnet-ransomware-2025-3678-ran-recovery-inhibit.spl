| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3678 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: d94087a3-7237-5b3b-8547-554686c79c64"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
