| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6420 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 6036e977-182c-53f9-bcfa-1bf03b599aba"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
