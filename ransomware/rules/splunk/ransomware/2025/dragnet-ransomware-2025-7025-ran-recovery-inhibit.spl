| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7025 — Recovery Inhibition (kairos)"
| comment "Status: experimental | Level: high | ID: 3bec8102-656f-52d3-b164-7e08651121f3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
