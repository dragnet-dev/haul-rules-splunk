| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4774 — Recovery Inhibition (beast)"
| comment "Status: experimental | Level: high | ID: d5094e69-a0cb-5e70-adac-6fdf67a45c74"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
