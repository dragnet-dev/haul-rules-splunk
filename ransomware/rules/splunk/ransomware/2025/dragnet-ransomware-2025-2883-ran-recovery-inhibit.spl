| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2883 — Recovery Inhibition (pear)"
| comment "Status: experimental | Level: high | ID: cc991e36-5ba4-5ce5-8bf4-c1d0530d3c78"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
