| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7913 — Recovery Inhibition (kazu)"
| comment "Status: experimental | Level: high | ID: 64097d37-b03d-5b63-a41e-020e697a8332"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
