| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6708 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 2f6b9060-2000-57d7-9afe-f3a9aa468d12"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
