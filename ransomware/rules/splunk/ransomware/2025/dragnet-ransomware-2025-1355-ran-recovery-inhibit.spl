| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1355 — Recovery Inhibition (devman)"
| comment "Status: experimental | Level: high | ID: 1b971bc1-7341-51bf-be6b-1527f3767740"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
