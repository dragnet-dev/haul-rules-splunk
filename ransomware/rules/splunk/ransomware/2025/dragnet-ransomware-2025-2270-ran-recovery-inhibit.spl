| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2270 — Recovery Inhibition (kairos)"
| comment "Status: experimental | Level: high | ID: 78ae3435-7559-5962-9703-2c698b8c44a0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
