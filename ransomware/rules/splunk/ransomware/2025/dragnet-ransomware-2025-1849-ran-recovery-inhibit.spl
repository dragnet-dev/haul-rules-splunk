| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1849 — Recovery Inhibition (brotherhood)"
| comment "Status: experimental | Level: high | ID: ae93f00a-464e-5c5b-a06a-4ab99fea01ec"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
