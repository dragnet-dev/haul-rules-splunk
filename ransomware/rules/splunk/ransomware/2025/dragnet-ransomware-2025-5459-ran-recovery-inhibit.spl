| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5459 — Recovery Inhibition (nova)"
| comment "Status: experimental | Level: high | ID: f3f373f3-1a54-534a-bc6e-2732599d1fe6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
