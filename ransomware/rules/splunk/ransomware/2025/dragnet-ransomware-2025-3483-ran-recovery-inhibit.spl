| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3483 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 88ce7a76-9014-5411-918f-eb0e1413c142"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
