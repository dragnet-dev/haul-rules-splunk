| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4089 — Recovery Inhibition (pear)"
| comment "Status: experimental | Level: high | ID: 3fd697c9-77eb-5ae6-9d2c-f2daa30e2b7f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
