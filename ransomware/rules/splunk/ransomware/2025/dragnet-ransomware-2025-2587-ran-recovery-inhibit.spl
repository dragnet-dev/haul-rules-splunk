| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2587 — Recovery Inhibition (spacebears)"
| comment "Status: experimental | Level: high | ID: b01a7721-f3e1-53a8-8cc3-cb4ab91ddad8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
