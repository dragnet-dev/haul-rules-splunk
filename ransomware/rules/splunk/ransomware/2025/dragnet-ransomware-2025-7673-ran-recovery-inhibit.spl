| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7673 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: ab4336f0-f076-5d78-8826-91f6cde3e497"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
