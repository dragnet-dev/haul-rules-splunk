| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5681 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: ec69f26a-2894-54b0-b5a2-2ae85c172156"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
