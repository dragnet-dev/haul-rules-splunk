| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4495 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 4950a269-fc3b-599c-a94a-bcb0009529ee"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
