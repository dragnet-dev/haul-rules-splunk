| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7879 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: e53eb26a-24d2-5d0b-9f1c-6aed8e484e25"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
