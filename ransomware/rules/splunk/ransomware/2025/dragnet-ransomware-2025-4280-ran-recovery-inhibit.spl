| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4280 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 9aab33e7-74bd-547d-a134-a95704dc0f5c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
