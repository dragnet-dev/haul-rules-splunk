| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5009 — Recovery Inhibition (cephalus)"
| comment "Status: experimental | Level: high | ID: 3b2d411c-5a1e-52c1-b712-4872d7869df6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
