| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3306 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 92e00a7e-e1d7-5835-927e-f0facb6c8442"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
