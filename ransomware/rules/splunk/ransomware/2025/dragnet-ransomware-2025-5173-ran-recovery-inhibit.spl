| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5173 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 4c049d1e-f824-566d-9cac-8ce7b917d2b0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
