| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7772 — Recovery Inhibition (pear)"
| comment "Status: experimental | Level: high | ID: 8b51125b-2f18-5123-93a1-2b236066d667"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
