| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3786 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 1d6a8aa0-f9f5-51b4-a15b-b283fce3a985"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
