| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1417 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: be731a7d-79dd-56bf-99b2-7001d56e9f28"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
