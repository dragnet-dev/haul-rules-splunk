| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5376 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: e48ae790-2d41-53bb-b3bd-0a29c28ba368"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
