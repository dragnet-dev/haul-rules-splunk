| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2174 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: 9f8f6374-0040-5363-a8ce-4f79e17aa93b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
