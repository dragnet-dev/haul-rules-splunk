| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2371 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: 984f1241-015b-5e1c-96c9-0fc128905ab8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
