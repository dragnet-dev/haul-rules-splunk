| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7176 — Recovery Inhibition (interlock)"
| comment "Status: experimental | Level: high | ID: 0202b5fe-cbf8-545c-935f-bfeaeb68bb5f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
