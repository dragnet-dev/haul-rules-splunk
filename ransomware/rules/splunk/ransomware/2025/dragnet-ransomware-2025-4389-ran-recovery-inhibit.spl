| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4389 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 7c647176-5f31-5d95-99f3-4aa76ebae97d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
