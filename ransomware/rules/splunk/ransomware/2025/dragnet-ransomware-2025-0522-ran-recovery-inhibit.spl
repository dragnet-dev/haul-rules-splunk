| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0522 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 8a71509c-70a5-5d66-bf18-10201aa0d099"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
