| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7719 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: f9e6d09f-dd35-5e05-87d6-491eb263f799"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
