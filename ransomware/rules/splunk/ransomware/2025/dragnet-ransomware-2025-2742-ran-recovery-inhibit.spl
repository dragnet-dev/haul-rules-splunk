| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2742 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 82659f5f-0b58-5780-abf3-9914bee8e0ad"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
