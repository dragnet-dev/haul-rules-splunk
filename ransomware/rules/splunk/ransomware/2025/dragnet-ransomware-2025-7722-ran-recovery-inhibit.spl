| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7722 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: d271137d-16ae-564b-b157-c3e0b0ae8266"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
