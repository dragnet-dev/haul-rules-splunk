| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2855 — Recovery Inhibition (blacknevas)"
| comment "Status: experimental | Level: high | ID: 3101b6eb-2730-5b1e-bfcb-49b1c5527c91"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
