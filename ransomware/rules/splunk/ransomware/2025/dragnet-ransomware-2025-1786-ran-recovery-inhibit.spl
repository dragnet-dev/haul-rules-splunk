| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1786 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 4b551e90-bfeb-5462-a565-32b3e4d5fba0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
