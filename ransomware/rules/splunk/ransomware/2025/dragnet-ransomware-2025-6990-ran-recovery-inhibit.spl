| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6990 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 695416bb-ba6e-504d-8003-1fdb663f8915"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
