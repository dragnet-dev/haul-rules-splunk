| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0126 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: adc2eb9b-a060-54c0-906e-f56af12a3971"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
