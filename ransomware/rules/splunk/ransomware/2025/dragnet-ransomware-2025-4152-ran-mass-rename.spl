| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4152 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: a72efd4a-bb55-526d-be82-fbc78d5874e2"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
