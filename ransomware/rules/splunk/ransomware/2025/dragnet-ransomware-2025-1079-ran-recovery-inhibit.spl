| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1079 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 9f4ff082-3e19-5fbe-b6e3-7c9ae9d1d8e5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
