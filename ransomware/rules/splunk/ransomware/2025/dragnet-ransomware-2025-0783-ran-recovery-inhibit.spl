| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0783 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 7eefd9d8-7b06-5743-a019-50b27b84f3b7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
