| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4245 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: b8a42883-49d5-5c86-8217-c548aae625d2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
