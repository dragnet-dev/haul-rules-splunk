| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6525 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: f8d5eb12-e579-5dc4-bdae-08d85c67032c"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
