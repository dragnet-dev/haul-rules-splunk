| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4622 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: 8e9a8e5e-7ab2-5d2f-8753-27f28c025ebc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
