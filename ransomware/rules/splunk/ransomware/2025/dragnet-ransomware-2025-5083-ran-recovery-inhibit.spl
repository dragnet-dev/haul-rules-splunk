| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5083 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: b1d915e6-d646-5c61-8364-1c4f80307625"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
