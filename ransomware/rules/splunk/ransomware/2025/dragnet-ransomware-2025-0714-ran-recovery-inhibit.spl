| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0714 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 2174b789-4886-5f15-aa97-0f1e83f31487"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
