| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6754 — Recovery Inhibition (kraken)"
| comment "Status: experimental | Level: high | ID: 319dab32-e173-5ac4-b30c-573778c7a4fc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
