| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7834 — Recovery Inhibition (threeam)"
| comment "Status: experimental | Level: high | ID: 9478212f-9aaf-5cd0-ae46-ab19189f54d9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
