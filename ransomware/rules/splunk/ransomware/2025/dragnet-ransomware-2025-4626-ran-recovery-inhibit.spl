| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4626 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 32c5e46f-5083-5f97-ab71-b5562945b3ab"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
