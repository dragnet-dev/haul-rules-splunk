| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3269 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 3ff71fb3-8af8-5d6e-bb67-853e79e4c772"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
