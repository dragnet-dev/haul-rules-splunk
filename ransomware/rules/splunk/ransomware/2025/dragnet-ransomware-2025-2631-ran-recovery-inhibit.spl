| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2631 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: b1fd0431-c70d-5ede-b8fb-d10dba64a5a3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
