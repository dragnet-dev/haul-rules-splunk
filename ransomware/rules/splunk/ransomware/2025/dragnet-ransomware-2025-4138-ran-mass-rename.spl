| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4138 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 100e3106-7c77-5ed8-ba5a-adca40308417"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
