| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4422 — Mass File Rename (handala)"
| comment "Status: experimental | Level: high | ID: dad8a09d-ed0d-5d33-ab59-e9f0184987a3"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
