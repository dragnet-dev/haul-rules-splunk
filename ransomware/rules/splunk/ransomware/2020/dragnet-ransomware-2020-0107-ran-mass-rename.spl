| comment "Dragnet [Ransomware]: dragnet-ransomware-2020-0107 — Mass File Rename (maze)"
| comment "Status: experimental | Level: high | ID: 6d6ef5d2-783a-515e-9dad-04b22f083c02"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
