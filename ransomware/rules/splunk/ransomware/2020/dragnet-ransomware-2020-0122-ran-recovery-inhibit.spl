| comment "Dragnet [Ransomware]: dragnet-ransomware-2020-0122 — Recovery Inhibition (ryuk)"
| comment "Status: deprecated | Level: high | ID: 297f2a59-90f2-52b7-b23f-9662a76a4faa"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
