| comment "Dragnet [Ransomware]: dragnet-ransomware-2020-0059 — Recovery Inhibition (netwalker)"
| comment "Status: deprecated | Level: high | ID: 7be22d76-c693-5fbc-998a-4d6e9d6f1ce4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
