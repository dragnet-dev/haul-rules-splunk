| comment "Dragnet [Ransomware]: dragnet-ransomware-2020-0090 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 7e3d49d5-1d0e-5fc6-9f2e-70227fd53f28"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
