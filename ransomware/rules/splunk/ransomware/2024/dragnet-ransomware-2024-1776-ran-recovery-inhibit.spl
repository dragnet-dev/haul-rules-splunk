| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1776 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: a57a5a00-f1f5-5546-b72d-15a2ed77f307"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
