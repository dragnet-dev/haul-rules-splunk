| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3080 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: e34ff01e-6394-5e20-9ac4-5f9913bcfeb4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
