| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5565 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: f5d15361-0b23-521a-8413-e18f8a7f3ced"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
