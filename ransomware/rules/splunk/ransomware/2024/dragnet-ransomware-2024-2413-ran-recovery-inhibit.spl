| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2413 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 6207284b-b068-5ab9-ad4f-b976be40a23d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
