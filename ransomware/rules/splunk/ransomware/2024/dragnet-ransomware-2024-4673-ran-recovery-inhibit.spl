| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4673 — Recovery Inhibition (BrainCipher)"
| comment "Status: experimental | Level: high | ID: 6e403db2-da49-5bc8-b16e-7a6e915097a5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
