| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4039 — Recovery Inhibition (kairos)"
| comment "Status: experimental | Level: high | ID: 5c806877-5e0d-5a51-a7d7-901b7b3cdd96"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
