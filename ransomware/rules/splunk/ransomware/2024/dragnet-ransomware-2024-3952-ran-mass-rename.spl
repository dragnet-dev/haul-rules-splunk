| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3952 — Mass File Rename (lockbit3)"
| comment "Status: experimental | Level: high | ID: 1e231c36-8948-5817-beea-e06e4a56fecd"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
