| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1873 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: 3f734d54-524d-56af-bd22-6f99d3c35a0a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
