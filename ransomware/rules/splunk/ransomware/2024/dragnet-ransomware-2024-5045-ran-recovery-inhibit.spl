| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5045 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: c23682b7-d8c4-5b6d-b0d7-45fb5478e224"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
