| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2482 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: afd2d1dc-903c-5363-8480-ff6ac6c31510"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
