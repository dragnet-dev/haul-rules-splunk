| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2609 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 5dfbc665-6e84-51b7-ac6c-eef5178f15fe"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
