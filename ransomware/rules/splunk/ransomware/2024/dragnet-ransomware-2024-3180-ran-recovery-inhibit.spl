| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3180 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 81f77d68-53e6-5c3c-a57a-fc4459b5f4f0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
