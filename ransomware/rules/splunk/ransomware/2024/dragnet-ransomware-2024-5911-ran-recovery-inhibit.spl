| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5911 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: 9f2eb179-3cce-5f60-bad0-d6d46643eb9b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
