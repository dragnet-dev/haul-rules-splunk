| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0488 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: c5bb8217-1358-50c4-afb5-57b164d11310"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
