| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2199 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 5d75fa6a-803e-5a54-870b-b1ea34a83634"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
