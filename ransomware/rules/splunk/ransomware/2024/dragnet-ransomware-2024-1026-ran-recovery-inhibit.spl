| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1026 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: f1bd8fe9-053f-51b9-8f16-236e0a219041"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
