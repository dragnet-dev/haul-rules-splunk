| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2988 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 3de69f21-19d3-5615-b9f9-ddd6dcb9f79e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
