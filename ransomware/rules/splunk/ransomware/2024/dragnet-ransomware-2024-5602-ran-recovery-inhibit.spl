| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5602 — Recovery Inhibition (funksec)"
| comment "Status: experimental | Level: high | ID: 29dd9b75-01c5-533c-a0bd-c60441717474"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
