| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5827 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: a0345d65-23f1-5f3c-af89-e30be56ac35a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
