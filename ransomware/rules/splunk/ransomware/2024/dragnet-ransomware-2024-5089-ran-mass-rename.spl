| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5089 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 1fee6c1e-8773-5d53-b8ca-09c58333fe63"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
