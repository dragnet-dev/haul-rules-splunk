| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4170 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: c7bbf37a-0d1c-53eb-88e8-1184b926dcba"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
