| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0411 — Recovery Inhibition (ElDorado)"
| comment "Status: experimental | Level: high | ID: 1a611758-419d-5835-86f6-f9ab38231b45"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
