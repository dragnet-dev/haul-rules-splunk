| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2781 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 2aad3146-2d38-553d-ad59-68760fc8bf76"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
