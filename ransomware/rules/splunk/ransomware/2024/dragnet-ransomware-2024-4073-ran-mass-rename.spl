| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4073 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 5d8ccbec-d985-5f27-a7dc-b68275aefd89"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
