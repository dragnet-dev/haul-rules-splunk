| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5918 — Recovery Inhibition (underground)"
| comment "Status: experimental | Level: high | ID: 50ebfff7-99b5-516c-ae9e-231818ba12ab"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
