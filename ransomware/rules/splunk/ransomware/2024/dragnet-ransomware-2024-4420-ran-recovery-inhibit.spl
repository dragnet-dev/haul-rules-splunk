| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4420 — Recovery Inhibition (raworld)"
| comment "Status: experimental | Level: high | ID: 3bcd18ab-f26c-5af9-8c7f-5e31fcea1d98"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
