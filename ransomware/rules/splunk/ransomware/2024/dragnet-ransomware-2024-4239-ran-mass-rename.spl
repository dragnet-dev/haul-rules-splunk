| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4239 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 8b72ce3c-d7ea-5e5b-bf45-81de99d6f4d1"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
