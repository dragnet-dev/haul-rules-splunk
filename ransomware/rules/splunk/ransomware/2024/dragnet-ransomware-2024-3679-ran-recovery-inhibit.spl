| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3679 — Recovery Inhibition (raworld)"
| comment "Status: experimental | Level: high | ID: 78a64bfa-8ff1-5d1b-ad1f-e11dcc72c7a9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
