| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2912 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: ab4817ad-1ec8-54c7-835d-78d618d53ea0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
