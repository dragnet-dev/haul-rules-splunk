| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1114 — Recovery Inhibition (helldown)"
| comment "Status: experimental | Level: high | ID: 5023fd18-1b2b-5520-8b72-96c37e0b9a51"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
