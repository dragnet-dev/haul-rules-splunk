| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2424 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: 184ce5f7-e519-5ae0-b237-0c3dc5525ed8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
