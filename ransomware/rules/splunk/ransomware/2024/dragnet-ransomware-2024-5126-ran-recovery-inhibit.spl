| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5126 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: cd8052bd-3a77-5dcd-8582-4a857f5e2f64"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
