| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5169 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 0fa00eb3-ff6e-583e-850b-73ac07b14d1f"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
