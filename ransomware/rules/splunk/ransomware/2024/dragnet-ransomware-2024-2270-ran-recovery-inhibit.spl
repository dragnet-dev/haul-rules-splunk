| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2270 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 10b34ff1-521c-56bb-8a5a-a9d2beba2f61"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
