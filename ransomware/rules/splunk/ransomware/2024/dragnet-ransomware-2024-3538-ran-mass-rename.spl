| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3538 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 413fcbe1-698a-5d10-bb5b-ddda3c5c7211"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
