| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1119 — Recovery Inhibition (trisec)"
| comment "Status: experimental | Level: high | ID: e4c8697a-98c6-5324-b7db-ab381995f26f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
