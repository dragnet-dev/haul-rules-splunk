| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2656 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 137c9681-01a9-5be2-af4b-37525b6c2a5d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
