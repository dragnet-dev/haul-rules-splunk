| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0904 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: f6c225dc-721f-5b66-bea1-d990e3c4be68"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
