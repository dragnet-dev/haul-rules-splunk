| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2313 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 38509816-29a5-526e-b62c-a1e7419f99c4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
