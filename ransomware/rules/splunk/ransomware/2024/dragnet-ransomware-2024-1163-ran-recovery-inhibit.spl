| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1163 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: 6bb34c37-fc4d-533b-89b5-537a144b7c4b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
