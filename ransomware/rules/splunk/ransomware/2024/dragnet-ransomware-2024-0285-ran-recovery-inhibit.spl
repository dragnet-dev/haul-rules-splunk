| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0285 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: db88f485-a547-5038-a6ec-a6a0ade27bc7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
