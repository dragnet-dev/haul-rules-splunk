| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3653 — Mass File Rename (alphalocker)"
| comment "Status: experimental | Level: high | ID: ee48f74e-b372-5802-91e1-2d341bd9fb20"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
