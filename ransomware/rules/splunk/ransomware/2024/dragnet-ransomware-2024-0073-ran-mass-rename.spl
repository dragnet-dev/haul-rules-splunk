| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0073 — Mass File Rename (lockbit3)"
| comment "Status: experimental | Level: high | ID: c8537541-de89-559f-99bd-d827fb8722d4"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
