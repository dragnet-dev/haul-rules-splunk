| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5559 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: de9a9919-fa50-51e7-86b1-c0fe5ec4a5c7"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
