| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3052 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: f85f9dcf-6052-52de-89cb-aa49d49f5272"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
