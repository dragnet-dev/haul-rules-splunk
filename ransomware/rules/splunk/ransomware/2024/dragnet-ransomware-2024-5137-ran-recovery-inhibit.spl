| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5137 — Recovery Inhibition (arcusmedia)"
| comment "Status: experimental | Level: high | ID: afc75aef-df1a-583c-90aa-f2d0bf8dc07f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
