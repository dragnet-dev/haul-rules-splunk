| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3423 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 631a4fd5-f722-5698-80d5-ed4b09232523"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
