| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1144 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 9627555c-8b45-5ea9-87f2-2a076c3bad0b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
