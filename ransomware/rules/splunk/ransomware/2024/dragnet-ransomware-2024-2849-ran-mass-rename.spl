| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2849 — Mass File Rename (zerotolerance)"
| comment "Status: experimental | Level: high | ID: 52892199-4efc-5c9c-ad77-5b5db1a15742"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
