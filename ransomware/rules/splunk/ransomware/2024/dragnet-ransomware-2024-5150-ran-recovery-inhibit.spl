| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5150 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 44c4bb93-df3c-567c-bc4e-12064fba1159"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
