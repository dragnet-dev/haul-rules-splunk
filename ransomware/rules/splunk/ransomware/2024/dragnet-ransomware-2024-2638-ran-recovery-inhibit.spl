| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2638 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: b8d9171f-2a3a-51da-ba7a-0206a70df3a5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
