| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3744 — Recovery Inhibition (dAn0n)"
| comment "Status: experimental | Level: high | ID: 7af57c72-e234-585c-a20b-04199f2e273e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
