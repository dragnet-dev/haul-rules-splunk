| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0642 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 80da38a7-2259-51c3-8067-4d8062b3c64c"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
