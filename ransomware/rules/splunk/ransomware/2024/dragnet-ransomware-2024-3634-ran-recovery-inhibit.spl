| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3634 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: e5d50174-ad29-53a7-86ba-1a06ccd91131"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
