| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0723 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 5a415835-db44-5067-a560-acf65ff92bd8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
