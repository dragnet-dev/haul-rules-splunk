| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3101 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 853456ee-017b-5232-aa5c-af4e70ba8a81"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
