| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5559 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 02f9153b-8f4b-5ab8-b5f8-dcdc929bbebb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
