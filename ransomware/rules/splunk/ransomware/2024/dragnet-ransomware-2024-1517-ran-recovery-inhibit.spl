| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1517 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 1caa9472-fa6f-5e71-8762-7d52917fca9a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
