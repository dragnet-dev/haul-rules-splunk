| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1759 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 82af2c92-aa14-59bb-ab9f-eff152558623"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
