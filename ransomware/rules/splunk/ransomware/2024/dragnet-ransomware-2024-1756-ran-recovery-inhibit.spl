| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1756 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: b3096466-9fc2-59f5-afba-9c7c6ce4a657"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
