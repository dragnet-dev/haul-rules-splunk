| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5578 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: fe078b8b-2081-5575-9d4f-dd237b3a0e3c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
