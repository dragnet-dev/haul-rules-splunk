| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5364 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 56aff0c6-4203-5ee1-acd1-b85189f2e6af"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
