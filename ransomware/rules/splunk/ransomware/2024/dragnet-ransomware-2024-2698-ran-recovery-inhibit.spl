| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2698 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: c7fd297a-c7ad-52c4-8849-3a096ac6775f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
