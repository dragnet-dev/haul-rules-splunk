| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4824 — Recovery Inhibition (funksec)"
| comment "Status: experimental | Level: high | ID: ddecb314-385a-503e-a4d3-7637e5b46be7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
