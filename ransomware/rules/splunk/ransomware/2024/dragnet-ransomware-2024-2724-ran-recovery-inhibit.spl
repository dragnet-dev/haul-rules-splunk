| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2724 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 3ce1da8b-6204-5046-9de9-ccee09e5ba1a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
