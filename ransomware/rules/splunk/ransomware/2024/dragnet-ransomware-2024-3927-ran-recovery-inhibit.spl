| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3927 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: be7544ac-67f6-542b-bfff-0b3469c3aba5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
