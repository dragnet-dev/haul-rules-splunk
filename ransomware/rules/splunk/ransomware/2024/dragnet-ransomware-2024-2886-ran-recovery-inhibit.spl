| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2886 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 6775a83d-64de-5956-9c0c-1a85b36bb403"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
