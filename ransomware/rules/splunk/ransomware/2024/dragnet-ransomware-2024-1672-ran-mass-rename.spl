| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1672 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 78ce9d30-eb56-5cb5-92ad-1bf9d34f20b4"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
