| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0141 — Recovery Inhibition (arcusmedia)"
| comment "Status: experimental | Level: high | ID: b372f497-4bd5-5a3f-8513-3b2edd0f6efc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
