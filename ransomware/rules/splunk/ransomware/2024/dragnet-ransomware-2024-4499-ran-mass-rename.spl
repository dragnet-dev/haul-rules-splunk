| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4499 — Mass File Rename (qilin)"
| comment "Status: experimental | Level: high | ID: 33489ee4-53ea-580f-8311-7c2501f3d5ca"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
