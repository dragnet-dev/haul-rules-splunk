| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2091 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: af74238f-8913-517a-8b4c-93c0d0b5d7ac"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
