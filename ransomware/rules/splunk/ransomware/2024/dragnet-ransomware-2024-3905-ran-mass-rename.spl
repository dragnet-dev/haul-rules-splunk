| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3905 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 2fb01538-df48-59f2-9779-8e3bbc0c82f8"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
