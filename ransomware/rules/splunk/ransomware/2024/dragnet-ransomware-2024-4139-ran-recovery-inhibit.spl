| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4139 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 4a32f98f-0669-5c94-9ef1-b1f4c7546c92"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
