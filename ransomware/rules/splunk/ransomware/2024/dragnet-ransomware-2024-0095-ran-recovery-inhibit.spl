| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0095 — Recovery Inhibition (handala)"
| comment "Status: experimental | Level: high | ID: 9233c89c-8635-5585-b62a-38dd796c9841"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
