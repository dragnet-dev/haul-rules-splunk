| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5553 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: 920bded3-fae7-5f4a-857f-ccd11d9a8c36"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
