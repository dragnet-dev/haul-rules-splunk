| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2137 — Recovery Inhibition (funksec)"
| comment "Status: experimental | Level: high | ID: 216bce53-1bc2-5f00-b694-9c2936221a74"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
