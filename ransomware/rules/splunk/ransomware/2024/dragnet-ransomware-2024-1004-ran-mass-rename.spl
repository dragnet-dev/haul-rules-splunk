| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1004 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 5b507004-5212-5e39-ad5a-d4dd9c9fc997"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
