| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1142 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 5a172082-cca7-59ce-b83c-3e841a05e40b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
