| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4653 — Recovery Inhibition (snatch)"
| comment "Status: experimental | Level: high | ID: 2b03c8be-4a5d-5dc0-8209-7da374781c83"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
