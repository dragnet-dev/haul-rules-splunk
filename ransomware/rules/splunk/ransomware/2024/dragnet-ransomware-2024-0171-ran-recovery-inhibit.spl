| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0171 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 0580b728-f5a3-5417-83a0-fe062ac25b06"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
