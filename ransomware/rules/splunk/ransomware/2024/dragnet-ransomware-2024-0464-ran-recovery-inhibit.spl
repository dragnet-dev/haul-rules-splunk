| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0464 — Recovery Inhibition (darkvault)"
| comment "Status: experimental | Level: high | ID: f702fd33-b58b-54e9-aaac-cf787e260519"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
