| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0508 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 61739dca-634f-5b79-9793-860e61d0cc0b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
