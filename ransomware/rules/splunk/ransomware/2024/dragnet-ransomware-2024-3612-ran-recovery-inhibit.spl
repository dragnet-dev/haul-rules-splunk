| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3612 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 53235f7a-8338-57a8-b5bf-8eca7bbf5352"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
