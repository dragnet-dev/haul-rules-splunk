| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5927 — Recovery Inhibition (cloak)"
| comment "Status: experimental | Level: high | ID: 8070f644-bdfa-59a8-b17e-d51cb75078cd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
