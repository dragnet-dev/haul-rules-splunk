| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4014 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: b4ce241b-279c-5f21-9eac-45377eddd326"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
