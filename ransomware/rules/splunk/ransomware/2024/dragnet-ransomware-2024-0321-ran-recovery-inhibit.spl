| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0321 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 1d6e4bb0-be38-5067-bb1d-f176f8da7ab0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
