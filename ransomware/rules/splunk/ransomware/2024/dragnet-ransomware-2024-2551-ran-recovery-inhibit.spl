| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2551 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 00884823-5297-58e9-9616-7afc04f95fb9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
