| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2573 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: f456f874-c779-57ad-92fd-1f8dd3889ccd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
