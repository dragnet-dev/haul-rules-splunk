| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5392 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: 62db8c7e-7184-58f1-aaa6-90be00e788a2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
