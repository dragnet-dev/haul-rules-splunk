| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5950 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 828acb42-0b64-5e9f-b568-4a1a7c3ac8fd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
