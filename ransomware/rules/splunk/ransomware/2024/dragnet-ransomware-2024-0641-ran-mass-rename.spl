| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0641 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 3257881a-2e76-578e-9a40-44b520ced8fa"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
