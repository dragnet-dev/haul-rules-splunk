| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1322 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: d57e8f13-22e8-5ce4-8366-bf22c52a1a0d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
