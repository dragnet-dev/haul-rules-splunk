| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1438 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 816cd6f5-6278-5623-9a36-7aea13386131"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
