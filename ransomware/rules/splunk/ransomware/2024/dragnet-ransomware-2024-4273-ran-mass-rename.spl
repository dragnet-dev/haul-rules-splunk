| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4273 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 53062fb3-7a2a-58bd-9819-9ced7951f9be"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
