| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3206 — Mass File Rename (hunters)"
| comment "Status: experimental | Level: high | ID: de0e4d55-5313-541c-b186-94d719ed84e5"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
