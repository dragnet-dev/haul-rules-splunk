| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1567 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 83704f06-f126-59a1-bbd4-03010271e7cc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
