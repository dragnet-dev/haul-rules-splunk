| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1554 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 7361550c-f3a1-5b71-a000-8d666cdff099"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
