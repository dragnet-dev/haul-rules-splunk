| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2916 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 39fe06c7-7cd5-5e56-ac34-09f6c8f8722c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
