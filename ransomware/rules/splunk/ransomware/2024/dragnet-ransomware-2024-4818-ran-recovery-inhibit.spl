| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4818 — Recovery Inhibition (raworld)"
| comment "Status: experimental | Level: high | ID: c0c2deaa-35db-5f54-8ef2-1088b67a39a0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
