| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2952 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: a65114a2-f084-571e-8653-1c23371c740b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
