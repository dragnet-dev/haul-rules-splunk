| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2681 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: ca82d56f-b947-5679-b089-095b640c1870"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
