| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5528 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 5227a959-f590-55aa-917e-fcd40805d4d3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
