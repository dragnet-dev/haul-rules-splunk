| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1983 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 32ccdc8f-a355-5bf1-b66f-fd9f0971ae6b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
