| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1746 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 4cb32133-ad68-5533-bd61-79e814b98d0f"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
