| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0742 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: b5dcaf20-e4f3-5b98-93e9-3c6a21b53db1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
