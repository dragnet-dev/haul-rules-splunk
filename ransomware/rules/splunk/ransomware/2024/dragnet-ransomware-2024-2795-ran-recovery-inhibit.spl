| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2795 — Recovery Inhibition (funksec)"
| comment "Status: experimental | Level: high | ID: 0183d218-b55c-5d17-ac3a-8d2725f75982"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
