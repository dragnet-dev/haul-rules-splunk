| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5988 — Recovery Inhibition (meow)"
| comment "Status: experimental | Level: high | ID: 5a0ae204-8fca-5248-b36b-52138c52fb6f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
