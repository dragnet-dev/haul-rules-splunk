| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3071 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: f0adb0fb-2f8f-5d8f-8380-0fd409687a99"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
