| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3474 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 46a60cda-b71f-5261-aef3-8807d74ca032"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
