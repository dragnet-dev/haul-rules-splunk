| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3763 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 4e3c862e-cc4a-56e5-80cf-7e4c25d35a1b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
