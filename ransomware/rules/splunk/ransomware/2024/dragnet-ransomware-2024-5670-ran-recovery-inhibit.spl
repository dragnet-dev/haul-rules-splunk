| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5670 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: fa7911f4-3c54-5bef-b37d-5ac8c9aa08c8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
