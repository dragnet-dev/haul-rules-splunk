| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4712 — Recovery Inhibition (metaencryptor)"
| comment "Status: experimental | Level: high | ID: 9ca3f83c-daab-504c-b66b-79ab81634f4a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
