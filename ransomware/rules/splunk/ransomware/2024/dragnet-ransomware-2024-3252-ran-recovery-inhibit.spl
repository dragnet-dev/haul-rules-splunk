| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3252 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 08c8247b-619c-5883-8ea9-cc48f03e9e8f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
