| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1816 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: 809a15c3-90d8-5aba-bf64-a3814baa240b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
