| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3175 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: ccc4d549-1e6d-58f9-83c0-24bf4f44e766"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
