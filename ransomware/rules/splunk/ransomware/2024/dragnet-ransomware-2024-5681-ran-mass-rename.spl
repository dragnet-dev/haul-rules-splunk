| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5681 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 527d432a-90f0-5305-9caa-787423316dfb"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
