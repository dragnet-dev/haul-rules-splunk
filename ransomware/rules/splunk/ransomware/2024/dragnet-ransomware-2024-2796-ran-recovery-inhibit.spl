| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2796 — Recovery Inhibition (flocker)"
| comment "Status: experimental | Level: high | ID: 91d32f1b-8b9f-5949-be19-6f6cf8af7799"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
