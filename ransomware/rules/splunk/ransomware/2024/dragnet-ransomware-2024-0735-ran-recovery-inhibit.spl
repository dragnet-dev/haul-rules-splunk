| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0735 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: 0d049543-b486-5c24-a15e-e5d13715172c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
