| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3889 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 4f3710f5-da27-5f72-ae86-7e313daefd6e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
