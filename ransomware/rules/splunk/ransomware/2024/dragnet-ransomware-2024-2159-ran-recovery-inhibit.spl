| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2159 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 507fc892-6171-54ae-a023-3cc353bab1c9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
