| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5537 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 69bdeff7-6411-5747-9857-04ac6829d1b1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
