| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2897 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 3a7bcb2a-425c-5eeb-8889-0b0196f7613b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
