| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2458 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 577f7fe2-dfa3-5a79-952e-27eb3f8d7b48"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
