| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3075 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 61e99b42-1b67-595b-9959-2fa419a5a306"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
