| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5423 — Recovery Inhibition (kairos)"
| comment "Status: experimental | Level: high | ID: 248156ee-0652-5c3c-9458-91e8b3c35514"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
