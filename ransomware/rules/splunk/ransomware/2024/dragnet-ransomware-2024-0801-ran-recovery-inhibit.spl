| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0801 — Recovery Inhibition (embargo)"
| comment "Status: experimental | Level: high | ID: e802a119-318e-5f9b-8986-82084982202c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
