| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1644 — Recovery Inhibition (apos)"
| comment "Status: experimental | Level: high | ID: c831cf6b-6904-5706-aeb2-11ce745ddacf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
