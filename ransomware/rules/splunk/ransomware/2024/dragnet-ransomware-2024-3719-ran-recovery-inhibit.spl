| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3719 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 8030fd51-8493-5d46-a3c3-7d0d5f64395f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
