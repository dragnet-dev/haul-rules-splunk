| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1216 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 3167e10e-6fec-57b5-b5cc-9a095e0077ff"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
