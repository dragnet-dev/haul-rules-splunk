| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2302 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: 8e4bcf83-8a8e-5c20-901b-97fa1f365d89"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
