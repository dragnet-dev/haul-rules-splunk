| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2584 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: 27712b6a-3cc0-5068-90b7-444fb3d63ca7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
