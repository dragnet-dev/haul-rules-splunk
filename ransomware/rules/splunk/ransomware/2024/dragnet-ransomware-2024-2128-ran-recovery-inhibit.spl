| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2128 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 40c1f515-035e-54ac-9225-0cfb7b86a8d2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
