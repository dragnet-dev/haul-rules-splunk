| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4230 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: aab33bd6-23a5-5c88-83db-6047ce6b24dd"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
