| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5688 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 06c196eb-9866-5ab4-ab1c-9d3149b63ca4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
