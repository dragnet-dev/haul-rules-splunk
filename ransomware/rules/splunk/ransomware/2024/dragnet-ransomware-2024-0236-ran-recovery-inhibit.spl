| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0236 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 8b0c9a00-57d3-5126-b521-bd74134e56af"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
