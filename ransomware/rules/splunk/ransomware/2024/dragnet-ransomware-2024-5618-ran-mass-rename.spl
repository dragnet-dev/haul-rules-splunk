| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5618 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 899adcbb-ded2-56dc-866c-9077de18b3bd"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
