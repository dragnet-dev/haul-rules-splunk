| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0874 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: 57b2a71e-3b7d-5cd8-aedb-d4ee96f92b50"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
