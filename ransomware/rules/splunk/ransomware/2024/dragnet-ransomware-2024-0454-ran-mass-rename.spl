| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0454 — Mass File Rename (lockbit3)"
| comment "Status: experimental | Level: high | ID: e364d333-03f6-576e-a2a9-e169377383de"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
