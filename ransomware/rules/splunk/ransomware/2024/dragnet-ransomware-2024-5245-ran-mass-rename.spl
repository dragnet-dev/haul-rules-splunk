| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5245 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 7891afc3-cb19-5d47-993a-bd46134a4b35"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
