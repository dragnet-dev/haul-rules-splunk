| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4641 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 51ab0cb4-e308-5ecd-9f79-6b84ed1e671e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
