| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2068 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 6afd9e3d-823b-511d-90ef-35b9e69d718d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
