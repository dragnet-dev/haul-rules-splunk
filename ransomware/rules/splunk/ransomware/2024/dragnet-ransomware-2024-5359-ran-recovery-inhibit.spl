| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5359 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: f9902b07-65ff-5924-a4a9-e5cdd12855bb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
