| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3563 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: df5ab811-754b-57d0-bed8-cf683f89ecaf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
