| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4720 — Recovery Inhibition (ransomhouse)"
| comment "Status: experimental | Level: high | ID: b0666f61-8d3d-5e87-a640-6672dda08e79"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
