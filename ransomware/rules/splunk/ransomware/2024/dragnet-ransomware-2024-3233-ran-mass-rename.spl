| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3233 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 217b06b1-4c10-51ed-a81c-4ebd49402362"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
