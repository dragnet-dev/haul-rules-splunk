| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5263 — Recovery Inhibition (nitrogen)"
| comment "Status: experimental | Level: high | ID: e023beef-4df7-55fc-9657-e8008f44e891"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
