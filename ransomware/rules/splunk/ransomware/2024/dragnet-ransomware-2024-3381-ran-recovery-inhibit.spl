| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3381 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: b7a6cc5b-a803-5e82-82a9-97d8c4a5139f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
