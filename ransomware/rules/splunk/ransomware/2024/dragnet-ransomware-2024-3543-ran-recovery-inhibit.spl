| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3543 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: cb522cfa-126e-5bda-813b-99c7e239ad6f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
