| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4212 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 9a49ba12-15a6-5b54-a75a-5ff2bc525f8c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
