| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1704 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 8e2033e5-c2de-5a11-af6d-679e4685b212"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
