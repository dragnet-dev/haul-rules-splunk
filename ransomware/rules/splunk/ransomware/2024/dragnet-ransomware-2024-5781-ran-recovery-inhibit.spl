| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5781 — Recovery Inhibition (raworld)"
| comment "Status: experimental | Level: high | ID: f67f5032-5c39-5540-ae48-019d35b9a848"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
