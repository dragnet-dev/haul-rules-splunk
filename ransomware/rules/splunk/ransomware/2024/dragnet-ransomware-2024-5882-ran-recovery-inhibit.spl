| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5882 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 739c7096-da2a-5af7-8b04-b7126f9cbc43"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
