| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1306 — Recovery Inhibition (arcusmedia)"
| comment "Status: experimental | Level: high | ID: 48ec757c-40c8-5d6d-8fe2-0e980414a22d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
