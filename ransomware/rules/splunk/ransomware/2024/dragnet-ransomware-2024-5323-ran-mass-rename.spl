| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5323 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: b0a39096-0cb3-51f0-b40d-c32b49ef151f"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
