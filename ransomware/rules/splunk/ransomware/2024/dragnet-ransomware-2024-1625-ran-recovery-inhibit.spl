| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1625 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: ead54e85-c3c7-5a08-86d6-b5fb0e515c19"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
