| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3627 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: c181b6a4-c4f0-551c-b406-dd952aae4442"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
