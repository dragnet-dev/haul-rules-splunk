| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0239 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 0b93013e-d5f4-53c9-bdc3-c1da6a748a12"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
