| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5109 — Recovery Inhibition (darkvault)"
| comment "Status: experimental | Level: high | ID: 79dacaac-f0a7-511f-84eb-8e956d8e6980"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
