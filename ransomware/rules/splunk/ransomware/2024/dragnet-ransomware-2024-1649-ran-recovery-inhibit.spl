| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1649 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 4e48b956-3317-5634-a7b0-a6ab5d8562bf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
