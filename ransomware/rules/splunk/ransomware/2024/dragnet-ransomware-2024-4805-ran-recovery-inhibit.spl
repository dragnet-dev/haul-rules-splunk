| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4805 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: b636e2b8-526c-5160-ad44-75ed811b0fd4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
