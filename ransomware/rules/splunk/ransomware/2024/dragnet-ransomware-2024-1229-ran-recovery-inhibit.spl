| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1229 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 281eec7f-e6a0-54be-9110-34b093aacd2d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
