| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4431 — Recovery Inhibition (raworld)"
| comment "Status: experimental | Level: high | ID: 72cafb5c-414f-52bf-b211-388d79ed6967"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
