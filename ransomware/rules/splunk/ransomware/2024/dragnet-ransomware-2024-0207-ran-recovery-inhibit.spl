| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0207 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: 87cd49e3-2874-5fdc-a3b7-18e5bcc42224"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
