| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5516 — Recovery Inhibition (spacebears)"
| comment "Status: experimental | Level: high | ID: 843981e3-416e-576f-bbe8-56294c64fe9e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
