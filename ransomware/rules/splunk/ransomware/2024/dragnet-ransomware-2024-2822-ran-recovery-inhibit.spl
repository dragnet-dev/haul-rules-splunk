| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2822 — Recovery Inhibition (meow)"
| comment "Status: experimental | Level: high | ID: 979da6ea-ea67-5bb6-92cc-cb3932103aa0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
