| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1461 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: b3153003-2313-50ee-b779-4d8c823fc4e0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
