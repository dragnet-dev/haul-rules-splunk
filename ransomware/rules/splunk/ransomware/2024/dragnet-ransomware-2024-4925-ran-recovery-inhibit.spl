| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4925 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: bf0974e3-8c54-5159-af9f-76bced6a7a36"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
