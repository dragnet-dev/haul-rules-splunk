| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3404 — Recovery Inhibition (raworld)"
| comment "Status: experimental | Level: high | ID: cf6c6e0e-12fe-5805-aace-fbad72286921"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
