| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2871 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: b3af0584-c140-52d1-bab5-91c9a36ca934"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
