| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1028 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: 66471c62-ad3f-54d0-881f-8918e061cce6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
