| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1965 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 779aecf8-a9b5-504e-b5b0-f5564b6d2f74"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
