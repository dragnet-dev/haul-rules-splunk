| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3270 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 380abe62-b803-55ae-bfd3-a14ffc395552"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
