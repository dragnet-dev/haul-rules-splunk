| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2559 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 7a3c8a04-7d4c-5185-b76e-8c7c78e9a2a1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
