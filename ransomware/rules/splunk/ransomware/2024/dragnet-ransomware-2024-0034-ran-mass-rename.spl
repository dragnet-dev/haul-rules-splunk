| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0034 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: ce992b47-5a1e-5a77-964b-72cc4f1fdb4e"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
