| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1825 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 152e3ddd-56f8-5496-ad74-86af5ad6dc38"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
