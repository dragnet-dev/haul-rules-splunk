| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2807 — Recovery Inhibition (cicada3301)"
| comment "Status: experimental | Level: high | ID: d8916209-63a4-59fd-9b4b-85e35450f840"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
