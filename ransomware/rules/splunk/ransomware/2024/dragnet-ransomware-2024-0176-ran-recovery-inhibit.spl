| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0176 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: 19de007f-033f-5dfc-b13f-d3ef2ac6e66f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
