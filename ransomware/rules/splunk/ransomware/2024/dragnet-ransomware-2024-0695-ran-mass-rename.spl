| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0695 — Mass File Rename (hunters)"
| comment "Status: experimental | Level: high | ID: 369b5068-609b-5bff-bbd9-539283a95400"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
