| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4741 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 389c15e4-f8f4-51fc-aa85-14fe57a74ced"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
