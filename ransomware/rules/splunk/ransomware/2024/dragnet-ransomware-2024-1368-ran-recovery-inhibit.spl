| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1368 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: d73e7655-01f4-5a7b-a0fd-a6467018e3b7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
