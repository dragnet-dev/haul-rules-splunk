| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3773 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: b8429b38-af6a-593e-8ac7-d2f481e796b7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
