| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2825 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: ace04062-0a85-5ad5-bc08-b71bfd3fcf41"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
