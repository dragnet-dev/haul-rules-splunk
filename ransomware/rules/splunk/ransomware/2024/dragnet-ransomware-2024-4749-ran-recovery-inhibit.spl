| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4749 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 4049fda5-4fa8-5a5c-9146-bec56c828b8f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
