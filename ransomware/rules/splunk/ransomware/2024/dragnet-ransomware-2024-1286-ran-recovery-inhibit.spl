| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1286 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 2f51180a-dd50-5833-aee6-03ae483b0f5f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
