| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4117 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: c1d0d5a2-d0b3-5bfa-8de5-8386a454a024"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
