| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3077 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 568b328f-8559-52ae-9f31-c95342f4aa40"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
