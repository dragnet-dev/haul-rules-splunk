| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5299 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 0c137eeb-ffc0-5eac-a903-242ea37d81d7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
