| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4293 — Mass File Rename (hunters)"
| comment "Status: experimental | Level: high | ID: 12aa025b-bffb-527b-8d42-2e7e7c10e73b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
