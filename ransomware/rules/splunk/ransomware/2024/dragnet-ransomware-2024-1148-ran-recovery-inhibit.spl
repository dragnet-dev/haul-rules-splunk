| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1148 — Recovery Inhibition (ransomhouse)"
| comment "Status: experimental | Level: high | ID: 345d979d-a7af-58d7-b82a-625e0d57f4c3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
