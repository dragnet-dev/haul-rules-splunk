| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0724 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 0e749352-44ae-576a-b80e-40eb040c23c0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
