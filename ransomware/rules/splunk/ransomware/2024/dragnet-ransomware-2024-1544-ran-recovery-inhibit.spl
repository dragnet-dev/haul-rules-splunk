| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1544 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: eb27740d-d179-537b-92e6-c7ef9356a1ef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
