| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5800 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: 0c489704-9007-5a56-b5f7-7acbc82868ae"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
