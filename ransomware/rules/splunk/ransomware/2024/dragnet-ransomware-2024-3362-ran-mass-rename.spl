| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3362 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: de27653a-13b1-5651-949d-8886d9bf0587"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
