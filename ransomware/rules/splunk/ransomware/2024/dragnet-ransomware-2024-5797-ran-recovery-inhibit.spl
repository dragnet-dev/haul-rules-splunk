| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5797 — Recovery Inhibition (helldown)"
| comment "Status: experimental | Level: high | ID: e3d0b4db-8032-56b6-876e-be6e4639f20b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
