| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1981 — Recovery Inhibition (funksec)"
| comment "Status: experimental | Level: high | ID: 7cd81c44-736e-5fd1-a58c-7eb2409e5302"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
