| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5154 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: e188af4e-8023-54c5-a60d-798fa123b12e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
