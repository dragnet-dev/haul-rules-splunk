| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1514 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: a645de4d-a879-5c04-aacd-957a3597cf7d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
