| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5527 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 9d84a99d-eb60-5ae5-8c58-c3564fe01d94"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
