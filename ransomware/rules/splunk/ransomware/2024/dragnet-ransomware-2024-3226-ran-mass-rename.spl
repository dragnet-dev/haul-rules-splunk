| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3226 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 0cd07e8d-e825-537f-a9df-1161f267f176"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
