| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3566 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 638395e0-dc2f-50ec-8fe6-9dc4d379c248"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
