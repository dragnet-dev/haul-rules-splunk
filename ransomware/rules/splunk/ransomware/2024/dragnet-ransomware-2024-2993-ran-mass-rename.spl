| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2993 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 44289e00-f73a-5b90-8530-6717c722f93f"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
