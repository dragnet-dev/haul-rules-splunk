| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0060 — Mass File Rename (qilin)"
| comment "Status: experimental | Level: high | ID: ac776183-6e03-5bcc-8630-3a3c958a356b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
