| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1059 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: bd9fd9e8-8c83-5500-aca0-2b93ecf61127"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
