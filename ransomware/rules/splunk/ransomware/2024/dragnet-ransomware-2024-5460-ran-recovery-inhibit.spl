| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5460 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 38695166-71d3-5cf1-8ef7-546ca65b4b4e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
