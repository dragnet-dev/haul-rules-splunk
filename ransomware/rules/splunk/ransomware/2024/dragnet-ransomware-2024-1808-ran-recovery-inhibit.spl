| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1808 — Recovery Inhibition (nitrogen)"
| comment "Status: experimental | Level: high | ID: 164abd36-ec3d-5100-a06d-83497c2d165a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
