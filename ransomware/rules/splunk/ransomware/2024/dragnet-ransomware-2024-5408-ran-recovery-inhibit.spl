| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5408 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 038638c6-4afd-5fd7-89e5-22a42022151e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
