| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2869 — Recovery Inhibition (darkvault)"
| comment "Status: experimental | Level: high | ID: 6a6e70ca-900b-5634-a2f4-146152ee6746"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
