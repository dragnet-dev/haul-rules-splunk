| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2767 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 5b833a01-3377-5e77-9714-661bdda50ea8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
