| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1231 — Recovery Inhibition (alphalocker)"
| comment "Status: experimental | Level: high | ID: 3670361f-1a64-5881-b932-1937b1055afe"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
