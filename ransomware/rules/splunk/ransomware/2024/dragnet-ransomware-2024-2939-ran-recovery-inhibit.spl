| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2939 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 8621eadd-6b0d-5f20-bf1e-978f486c953e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
