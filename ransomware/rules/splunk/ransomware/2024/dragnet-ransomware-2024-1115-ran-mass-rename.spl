| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1115 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: b82950f8-4271-5952-aef4-f637e3ff2138"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
