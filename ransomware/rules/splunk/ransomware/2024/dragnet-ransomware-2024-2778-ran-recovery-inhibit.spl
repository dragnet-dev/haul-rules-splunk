| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2778 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: 6433d35b-c126-560a-8c7f-d202b6e08706"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
