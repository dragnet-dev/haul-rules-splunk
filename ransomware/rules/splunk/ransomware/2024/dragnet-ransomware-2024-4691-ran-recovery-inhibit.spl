| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4691 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: bf1eaad6-1669-5dde-8254-eb95046bfb30"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
