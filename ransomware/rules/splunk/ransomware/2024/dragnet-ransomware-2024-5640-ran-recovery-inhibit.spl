| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5640 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 22c9d184-9d25-5c4b-afdb-cd5cefdc3249"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
