| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0588 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 11e86c56-22ba-5353-b922-86e4b0543464"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
