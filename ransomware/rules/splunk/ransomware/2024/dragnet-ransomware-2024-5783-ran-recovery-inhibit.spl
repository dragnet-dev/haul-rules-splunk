| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5783 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: c6448c65-65ca-5fcf-995a-7856559c9ada"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
