| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5566 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 9b34d595-e711-5311-9ef5-c1bfbb2ad07b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
