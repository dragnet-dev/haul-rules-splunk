| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1073 — Recovery Inhibition (meow)"
| comment "Status: experimental | Level: high | ID: 00253933-b592-5c18-87f0-56544e6816ef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
