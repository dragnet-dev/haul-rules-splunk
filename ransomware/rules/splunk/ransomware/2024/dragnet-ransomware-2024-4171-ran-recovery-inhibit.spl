| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4171 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: f6f202c3-0064-51f5-863b-bdbc1d7bc036"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
