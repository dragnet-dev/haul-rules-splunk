| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5284 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: ece23bd0-be73-57a5-905f-62da93c4bd28"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
