| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4953 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 32a70825-20a8-532c-a692-bc7872acf547"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
