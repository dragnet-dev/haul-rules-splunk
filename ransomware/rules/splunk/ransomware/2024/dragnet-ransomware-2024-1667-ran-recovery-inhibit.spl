| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1667 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 78a817a0-a824-54cc-9b4b-0ce3b0ab04cf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
