| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0948 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: cb50a9d6-4f9f-5fc9-a077-e8a7bcc95b8b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
