| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2365 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: a42a84a3-f124-58cf-adb8-e5a9c8afb3f1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
