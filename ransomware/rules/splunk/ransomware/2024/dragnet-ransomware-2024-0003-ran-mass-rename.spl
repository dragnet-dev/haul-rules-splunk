| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0003 — Mass File Rename (meow)"
| comment "Status: experimental | Level: high | ID: 21bc02de-5967-577e-bdb4-be3a9622fcda"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
