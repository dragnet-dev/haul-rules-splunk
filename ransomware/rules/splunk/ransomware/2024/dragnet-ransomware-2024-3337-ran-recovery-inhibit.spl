| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3337 — Recovery Inhibition (darkvault)"
| comment "Status: experimental | Level: high | ID: f1ad0b70-1b10-5012-9ead-fb184e140a62"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
