| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4183 — Mass File Rename (qilin)"
| comment "Status: experimental | Level: high | ID: 56bd9f62-9940-5057-b456-edfe9a8e2b2a"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
