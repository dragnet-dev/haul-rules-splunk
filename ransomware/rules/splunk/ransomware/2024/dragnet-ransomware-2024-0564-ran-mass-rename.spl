| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0564 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 5e19e5a6-76ca-57d3-ac64-2639d8d57117"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
