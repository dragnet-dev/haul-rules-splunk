| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2769 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: e74f66c1-f23d-54ae-85c1-d9945d1cc830"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
