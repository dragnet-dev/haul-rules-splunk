| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1609 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 3a5b973e-34e0-57b0-bff2-514c71fdfc19"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
