| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2885 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 5285675a-e92d-5577-ae13-e51901cad305"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
