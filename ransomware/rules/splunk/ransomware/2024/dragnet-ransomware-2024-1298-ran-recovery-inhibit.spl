| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1298 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: b17d5c00-7db6-5b93-a928-a537216d5721"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
