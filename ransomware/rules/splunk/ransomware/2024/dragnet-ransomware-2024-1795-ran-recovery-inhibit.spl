| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1795 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 75467a63-3c11-5e04-b2af-12fdc78779f7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
