| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4813 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: c988e087-7bdc-544a-b130-ba9ffba95c05"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
