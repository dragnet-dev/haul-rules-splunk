| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0263 — Mass File Rename (incransom)"
| comment "Status: experimental | Level: high | ID: e307b5ee-499b-5170-a308-e046d2c8afe9"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
