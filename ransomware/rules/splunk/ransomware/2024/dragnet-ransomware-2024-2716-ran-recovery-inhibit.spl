| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2716 — Recovery Inhibition (flocker)"
| comment "Status: experimental | Level: high | ID: fdf3795f-17a0-5aca-9fac-f2b90f1483b4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
