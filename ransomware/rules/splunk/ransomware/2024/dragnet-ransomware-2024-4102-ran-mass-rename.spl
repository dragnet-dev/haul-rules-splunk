| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4102 — Mass File Rename (cactus)"
| comment "Status: experimental | Level: high | ID: 613a7ad0-15aa-5dbf-ac57-02d1544f04db"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
