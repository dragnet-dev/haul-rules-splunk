| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4156 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: afde7eb7-6ac6-51b1-b123-dc13629aaf2b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
