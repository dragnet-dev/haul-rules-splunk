| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0495 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 802d0549-6fe7-532e-ba09-64f77d0c0464"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
