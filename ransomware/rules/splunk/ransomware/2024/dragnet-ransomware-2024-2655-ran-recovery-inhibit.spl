| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2655 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 907f3b83-ffc1-5497-92c3-cda59678db24"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
