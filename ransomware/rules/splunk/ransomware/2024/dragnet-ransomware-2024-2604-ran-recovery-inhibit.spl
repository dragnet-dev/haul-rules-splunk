| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2604 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 9b536db4-23e2-53a2-83ae-b51e069775fd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
