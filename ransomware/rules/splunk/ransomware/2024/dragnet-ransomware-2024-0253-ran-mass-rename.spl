| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0253 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 496eba05-53e3-586b-a080-5ecd6f15f4d3"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
