| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1060 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: d845c30f-8864-5e98-b5d8-9a125a8ff935"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
