| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3783 — Recovery Inhibition (dAn0n)"
| comment "Status: experimental | Level: high | ID: 1dfd89e0-bc99-58fc-b6ff-c70e2d3c5fef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
