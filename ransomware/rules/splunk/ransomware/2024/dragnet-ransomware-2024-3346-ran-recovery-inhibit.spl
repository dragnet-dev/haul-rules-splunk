| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3346 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 42dfefa3-da25-57d0-8752-54c8f44df9fd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
