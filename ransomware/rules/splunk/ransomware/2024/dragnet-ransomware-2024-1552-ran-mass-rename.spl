| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1552 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 5532f78b-787c-5647-acde-dec83c8ce56e"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
