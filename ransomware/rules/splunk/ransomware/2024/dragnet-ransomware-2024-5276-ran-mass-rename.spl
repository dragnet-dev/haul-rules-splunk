| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5276 — Mass File Rename (flocker)"
| comment "Status: experimental | Level: high | ID: 53532a47-e713-5ca8-a637-26d6e5bd79ad"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
