| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5658 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 68cae245-c163-57df-9d64-1494f2b2ffe6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
