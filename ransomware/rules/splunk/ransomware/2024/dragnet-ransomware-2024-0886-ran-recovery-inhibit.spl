| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0886 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: dc47b4a7-b40e-5a9e-991d-43bdca78a99c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
