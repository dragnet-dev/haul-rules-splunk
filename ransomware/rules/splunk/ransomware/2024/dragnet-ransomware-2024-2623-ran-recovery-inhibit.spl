| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2623 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 75977873-8f95-5556-a8b8-215370c1b55c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
