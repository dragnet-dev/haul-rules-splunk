| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3851 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 4fc0392e-21d3-5f06-bd4a-3045329893fb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
