| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3718 — Recovery Inhibition (dragonransomware)"
| comment "Status: experimental | Level: high | ID: 3dcc04dd-8d6d-5f19-90bc-4277bee280b1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
