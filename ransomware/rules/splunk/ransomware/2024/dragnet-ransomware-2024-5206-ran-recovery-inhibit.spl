| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5206 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: aa43830f-d0b9-5f2e-87ea-0cb4c7f8ff16"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
