| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2262 — Recovery Inhibition (dAn0n)"
| comment "Status: experimental | Level: high | ID: 92d89d06-24c0-5d81-ae82-6ca5c63f7ff5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
