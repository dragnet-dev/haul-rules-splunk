| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2397 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 2612eb0e-c42b-56b5-bad8-755a692d346d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
