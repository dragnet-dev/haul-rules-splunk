| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0815 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 54584c95-96fd-5ee1-8ace-0962e91bb81f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
