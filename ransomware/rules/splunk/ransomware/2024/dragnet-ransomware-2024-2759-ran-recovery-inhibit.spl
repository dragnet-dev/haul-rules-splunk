| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2759 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: a5619075-70f3-548a-9b5f-e36608d81f4a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
