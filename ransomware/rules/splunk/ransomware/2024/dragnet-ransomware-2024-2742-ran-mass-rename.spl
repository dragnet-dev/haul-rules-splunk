| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2742 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 31d4e3ee-7f0f-510e-b2a3-ae5dc089e3eb"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
