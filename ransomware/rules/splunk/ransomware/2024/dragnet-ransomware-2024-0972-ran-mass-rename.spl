| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0972 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: ed45ac66-d64d-5186-8bda-4d0c1a668771"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
