| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3583 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 5006dbcd-6410-51b2-ae39-15b578160f2e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
