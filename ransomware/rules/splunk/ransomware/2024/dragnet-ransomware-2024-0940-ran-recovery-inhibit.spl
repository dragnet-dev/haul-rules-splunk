| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0940 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: 10721f62-9322-5e3c-99fd-ac8621dbd0ae"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
