| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4503 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: ba49b085-63e3-55f1-833e-d73a58fca1e2"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
