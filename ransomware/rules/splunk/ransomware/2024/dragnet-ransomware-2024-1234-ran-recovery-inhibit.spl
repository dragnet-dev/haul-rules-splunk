| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1234 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 581b1c79-b123-5950-9a6d-284e86d29fe4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
