| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3766 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: a0c075df-d92c-57ac-a262-0ec44d47e528"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
