| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3787 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: eda8d963-9497-56c1-9e0e-029668be5322"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
