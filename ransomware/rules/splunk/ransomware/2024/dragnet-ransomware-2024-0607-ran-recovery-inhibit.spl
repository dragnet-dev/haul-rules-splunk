| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0607 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 9d560756-f796-51e3-9f5e-88581989d94b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
