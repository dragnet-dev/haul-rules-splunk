| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2135 — Recovery Inhibition (incransom)"
| comment "Status: stable | Level: high | ID: 282e27a6-df6a-5bbe-b422-5b0f8b8ed033"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
