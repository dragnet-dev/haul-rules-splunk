| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2264 — Recovery Inhibition (gunra)"
| comment "Status: stable | Level: high | ID: ab85ea1d-ecff-51da-96bd-b1be08fe315e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
