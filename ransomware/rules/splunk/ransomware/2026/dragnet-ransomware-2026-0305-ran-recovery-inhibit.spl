| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-0305 — Recovery Inhibition (incransom)"
| comment "Status: stable | Level: high | ID: ee22fb6d-227b-5d36-996d-1ae6d98a96c6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
