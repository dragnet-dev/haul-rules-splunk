| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2124 — Recovery Inhibition (dragonforce)"
| comment "Status: stable | Level: high | ID: 7d6653dd-a23a-5871-9bd2-205896c0c15d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
