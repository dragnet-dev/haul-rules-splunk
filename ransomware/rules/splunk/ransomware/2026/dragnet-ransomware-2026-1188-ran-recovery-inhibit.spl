| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-1188 — Recovery Inhibition (qilin)"
| comment "Status: stable | Level: high | ID: 199902ab-1776-55de-95eb-6168feea8f30"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
