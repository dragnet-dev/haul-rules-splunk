| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-3242 — Recovery Inhibition (dragonforce)"
| comment "Status: stable | Level: high | ID: 099be2aa-5f3b-5eef-91b6-bd8bce56c9cd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
