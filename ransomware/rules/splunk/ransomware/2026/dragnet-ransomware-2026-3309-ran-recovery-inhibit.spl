| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-3309 — Recovery Inhibition (lynx)"
| comment "Status: stable | Level: high | ID: a9e1872b-70ec-5172-84c3-800ba1fd13d7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
