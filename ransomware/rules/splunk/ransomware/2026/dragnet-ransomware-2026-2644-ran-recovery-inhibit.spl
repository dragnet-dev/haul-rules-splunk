| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2644 — Recovery Inhibition (m3rx)"
| comment "Status: stable | Level: high | ID: 6aa8034e-6991-5b74-a028-3d255c4347ac"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
