| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2175 — Recovery Inhibition (medusalocker)"
| comment "Status: stable | Level: high | ID: 13c6ba5a-ac8d-55cd-82ca-cd45125edd2d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
