| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-3187 — Recovery Inhibition (qilin)"
| comment "Status: stable | Level: high | ID: 65d5afae-1d5c-50d1-8bbc-acc208ab8fa8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
