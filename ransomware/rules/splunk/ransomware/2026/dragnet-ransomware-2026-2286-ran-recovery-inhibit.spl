| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2286 — Recovery Inhibition (incransom)"
| comment "Status: stable | Level: high | ID: 2c903ec2-9cb7-5b44-ab7d-49930657c940"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
