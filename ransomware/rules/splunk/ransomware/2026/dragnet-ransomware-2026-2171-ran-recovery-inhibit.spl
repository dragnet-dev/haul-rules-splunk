| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2171 — Recovery Inhibition (dragonforce)"
| comment "Status: stable | Level: high | ID: 56cd8b31-056f-5065-99bb-ee42bf66b68d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
