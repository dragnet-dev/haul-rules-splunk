| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-0991 — Recovery Inhibition (dragonforce)"
| comment "Status: stable | Level: high | ID: 2f01d0dc-52fa-5ecc-888a-d5e1f619a523"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
