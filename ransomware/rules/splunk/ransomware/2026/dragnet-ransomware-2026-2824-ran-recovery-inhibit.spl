| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2824 — Recovery Inhibition (handala)"
| comment "Status: stable | Level: high | ID: 8d423967-52bd-5679-957b-eae8fd818124"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
