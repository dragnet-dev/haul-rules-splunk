| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2599 — Recovery Inhibition (dragonforce)"
| comment "Status: stable | Level: high | ID: a747ed52-2d34-53a7-a7c1-fc6b889158da"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
