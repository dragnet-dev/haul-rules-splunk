| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1563 — Recovery Inhibition (ragnarlocker)"
| comment "Status: experimental | Level: high | ID: 630b1f1e-5a35-5d9b-afa9-76f52efc0fd0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
