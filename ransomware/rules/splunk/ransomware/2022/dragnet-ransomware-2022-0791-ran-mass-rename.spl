| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0791 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: 34a25442-36d8-5199-981d-d693b1dfce45"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
