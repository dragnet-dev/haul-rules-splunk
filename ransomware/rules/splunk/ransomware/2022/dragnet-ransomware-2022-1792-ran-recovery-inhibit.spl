| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1792 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 5802a859-71bf-51af-9d13-611869357f93"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
