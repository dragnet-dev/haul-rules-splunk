| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0985 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: 87be92f8-a71c-5e37-94e6-326d7883a830"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
