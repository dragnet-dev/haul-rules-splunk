| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0291 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 40becd79-21ae-542b-9019-aa1261ced779"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
