| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2155 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: fb7dc23a-3290-5def-a08d-eb686a574071"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
