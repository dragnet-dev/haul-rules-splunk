| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2986 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 5ed05258-456e-5d2d-adcf-1a701cd39e87"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
