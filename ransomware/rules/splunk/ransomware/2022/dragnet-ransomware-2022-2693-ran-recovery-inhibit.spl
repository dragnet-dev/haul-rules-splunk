| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2693 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: b59478f8-f55b-5274-a7a6-e20da466da01"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
