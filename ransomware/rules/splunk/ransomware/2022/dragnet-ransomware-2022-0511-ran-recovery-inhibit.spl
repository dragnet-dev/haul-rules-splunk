| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0511 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 97f6e3fa-7ef2-5894-b669-9dcfe77c7872"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
