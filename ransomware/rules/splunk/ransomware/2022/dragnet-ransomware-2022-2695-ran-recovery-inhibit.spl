| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2695 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 3857a508-fc94-580b-9fa5-47e462c8362d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
