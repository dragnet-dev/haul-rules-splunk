| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2555 — Recovery Inhibition (lv)"
| comment "Status: deprecated | Level: high | ID: 119dc991-a17f-5bdf-83a6-5a1d3e1a5956"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
