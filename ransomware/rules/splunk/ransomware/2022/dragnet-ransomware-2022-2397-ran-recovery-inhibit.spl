| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2397 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 54f655e0-d8a5-508f-ba5b-8b6d3fa87824"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
