| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2334 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 8de3b99a-2256-59ee-9fbc-ce7d5526a14b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
