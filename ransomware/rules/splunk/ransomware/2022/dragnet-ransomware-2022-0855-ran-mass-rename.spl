| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0855 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 5d66e5f9-d39d-5bdb-aa7d-4e0440937abb"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
