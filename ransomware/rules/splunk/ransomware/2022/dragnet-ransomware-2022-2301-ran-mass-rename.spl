| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2301 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: e8d78313-9926-5886-9240-4a84f924fa0d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
