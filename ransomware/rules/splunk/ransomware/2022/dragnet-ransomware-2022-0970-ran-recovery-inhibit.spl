| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0970 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 4d25e13a-05a3-57bf-a9d7-ffd06da3be05"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
