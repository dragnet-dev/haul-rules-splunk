| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1778 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 76aca26f-12fb-57fa-a098-7854a4b7bf15"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
