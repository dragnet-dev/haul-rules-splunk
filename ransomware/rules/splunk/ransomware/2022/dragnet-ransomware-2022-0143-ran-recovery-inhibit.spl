| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0143 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: a182af94-6f57-5e6a-935e-e1c6aa3e0ea4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
