| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2805 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: e5bf991e-e3e3-51f9-9bdc-0f07586046d0"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
