| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0894 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 208e723e-53ca-5644-96d6-0d524d599fff"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
