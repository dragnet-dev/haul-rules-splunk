| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0126 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: fe9d2f76-5667-5b1d-8f2a-ffbb080bbbf9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
