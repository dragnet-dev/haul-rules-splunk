| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2459 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 29b0ac65-d638-5279-ae3b-6fa6c3804234"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
