| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0673 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: c0bb32b1-0075-5e48-b0db-6edec7fca8fe"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
