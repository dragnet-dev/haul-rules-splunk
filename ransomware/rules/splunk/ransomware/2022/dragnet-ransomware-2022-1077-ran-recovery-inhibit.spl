| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1077 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 59ca8ff2-9523-5e18-b603-0cb5e13f2f9e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
