| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1023 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: a8a8f92a-8e0e-5ad6-bc7e-9ff45788c060"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
