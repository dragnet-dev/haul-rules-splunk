| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0024 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: 325e8f42-3393-5f42-9dff-938b836cf462"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
