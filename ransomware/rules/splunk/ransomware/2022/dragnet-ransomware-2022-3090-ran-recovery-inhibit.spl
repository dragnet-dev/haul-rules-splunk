| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-3090 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: e5bd7be8-9621-505a-ba2b-895e053bd2db"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
