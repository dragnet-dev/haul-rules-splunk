| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1156 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: db8dea74-9cbe-5c6d-86fe-85d790b17d46"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
