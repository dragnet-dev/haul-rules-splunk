| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2016 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 8e4a1981-e6ce-53c0-9732-046992973ed4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
