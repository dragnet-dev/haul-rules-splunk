| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1256 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: f4c4d3f4-6a92-5a9c-b59c-83cd15a3b894"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
