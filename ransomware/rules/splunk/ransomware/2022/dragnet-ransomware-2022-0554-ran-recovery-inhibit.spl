| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0554 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 64653b75-42c5-528c-8fb6-f51b1b08b391"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
