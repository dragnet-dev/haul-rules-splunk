| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2876 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 92465a58-ce8f-51cf-bf05-bfc0c1c514d8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
