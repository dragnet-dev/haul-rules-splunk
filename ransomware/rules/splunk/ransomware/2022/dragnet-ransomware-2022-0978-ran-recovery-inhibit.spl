| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0978 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 717d8223-07d6-5f2c-96c5-24352ae96f89"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
