| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0126 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: af99351b-c6cb-581b-be4b-f0383ad2cfbf"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
