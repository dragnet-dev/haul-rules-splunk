| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1036 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: b420f323-16ba-5385-99d6-55d083a79c7b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
