| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0240 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: c4695154-f676-5af2-afc7-6810d7db874c"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
