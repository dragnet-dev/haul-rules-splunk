| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2252 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: 215b0a64-f346-5628-b298-38d227cf3f19"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
