| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5027 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 511826cd-56a4-51a7-93cd-30b648fcf8a7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
