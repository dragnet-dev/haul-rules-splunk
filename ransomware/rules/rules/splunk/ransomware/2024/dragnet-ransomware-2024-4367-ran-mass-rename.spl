| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4367 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: a777d874-8324-523e-8f1a-c927067b460b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
