| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3940 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 307c3907-ba23-5813-b1d7-7bfc86c1fcc9"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
