| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2239 — Mass File Rename (meow)"
| comment "Status: experimental | Level: high | ID: 31c43609-bbc9-560e-b6f0-ef2eb7ab374b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
