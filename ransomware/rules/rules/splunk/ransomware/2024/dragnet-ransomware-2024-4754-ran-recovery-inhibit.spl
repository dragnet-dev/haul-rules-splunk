| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4754 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: ea85fe1c-85c6-54a3-82c2-9f6d1e31992b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
