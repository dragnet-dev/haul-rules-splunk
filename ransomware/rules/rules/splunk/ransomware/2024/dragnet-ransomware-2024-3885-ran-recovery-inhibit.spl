| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3885 — Recovery Inhibition (dunghill)"
| comment "Status: experimental | Level: high | ID: 2bcc6968-7e8d-5b8a-b93c-48bda1820d0b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
