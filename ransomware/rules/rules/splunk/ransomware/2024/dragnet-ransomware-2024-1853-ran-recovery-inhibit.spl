| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1853 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: d870582d-c532-5a7b-bcbe-374ac828dbf1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
