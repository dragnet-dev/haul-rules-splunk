| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1669 — Recovery Inhibition (meow)"
| comment "Status: experimental | Level: high | ID: c54d40b2-249b-530e-873e-4a07a0c6de0d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
