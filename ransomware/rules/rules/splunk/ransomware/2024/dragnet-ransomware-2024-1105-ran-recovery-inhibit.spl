| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1105 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 08289547-c579-5521-86f2-8c0ce8333ab2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
