| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5230 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 08afead1-6597-5fa4-b62f-9aece20b88a8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
