| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4820 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 2e11b7a4-50a2-5bbd-90f0-e6a35299186a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
