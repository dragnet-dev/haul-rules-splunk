| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1614 — Recovery Inhibition (qiulong)"
| comment "Status: experimental | Level: high | ID: 0d7e5bcd-df9a-5186-899b-200d220bae9e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
