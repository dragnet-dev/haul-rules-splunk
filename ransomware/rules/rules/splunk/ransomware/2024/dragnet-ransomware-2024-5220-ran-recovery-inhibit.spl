| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5220 — Recovery Inhibition (trigona)"
| comment "Status: experimental | Level: high | ID: b27e8339-6b0b-5351-af3e-8e3a3a697720"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
