| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5064 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 6411af95-be16-5bd2-8278-6caf9d7de101"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
