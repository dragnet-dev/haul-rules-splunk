| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5503 — Recovery Inhibition (darkvault)"
| comment "Status: experimental | Level: high | ID: 1dedfae6-589d-55c2-8b65-90325f61ab98"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
