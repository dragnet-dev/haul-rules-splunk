| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2552 — Recovery Inhibition (madliberator)"
| comment "Status: experimental | Level: high | ID: e50e1f72-7e01-5779-8aa7-b3608a8e3503"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
