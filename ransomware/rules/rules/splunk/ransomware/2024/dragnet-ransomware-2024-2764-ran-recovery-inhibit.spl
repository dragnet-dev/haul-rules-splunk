| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2764 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: c3ec5dff-7577-530b-857f-9f9b7f7ea482"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
