| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2254 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: c6a287b2-66e3-5cff-a6c3-0fd7c9539d56"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
