| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2605 — Mass File Rename (incransom)"
| comment "Status: experimental | Level: high | ID: 4e59d30c-50ca-5d4b-8d7b-c83d7783707d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
