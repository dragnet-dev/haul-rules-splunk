| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5190 — Recovery Inhibition (underground)"
| comment "Status: experimental | Level: high | ID: f91fdd90-5a26-5c17-9475-41d31e9bd467"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
