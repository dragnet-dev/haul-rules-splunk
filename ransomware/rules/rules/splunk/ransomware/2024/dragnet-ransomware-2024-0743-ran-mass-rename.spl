| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0743 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 5b54e3e2-db6c-5a56-849e-d19678cc5e47"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
