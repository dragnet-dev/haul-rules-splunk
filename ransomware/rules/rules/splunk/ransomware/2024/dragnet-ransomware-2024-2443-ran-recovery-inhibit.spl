| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2443 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: 5f2272e4-e7f0-541c-94bc-959ec630ce1b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
