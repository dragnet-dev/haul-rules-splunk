| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4152 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 3dcd1fe2-8bf8-5d47-913f-75f351206657"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
