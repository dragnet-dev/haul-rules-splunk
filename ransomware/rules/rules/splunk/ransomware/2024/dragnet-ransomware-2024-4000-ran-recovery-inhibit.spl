| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4000 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 00f2a17d-8233-58c5-b423-192ec90aad56"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
