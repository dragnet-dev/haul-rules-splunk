| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2251 — Mass File Rename (meow)"
| comment "Status: experimental | Level: high | ID: 06c9d6e4-05f1-565b-8831-7b4019414bee"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
