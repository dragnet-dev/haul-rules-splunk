| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1930 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: f9d5a8c9-c995-5d43-8063-683988de142e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
