| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1124 — Mass File Rename (incransom)"
| comment "Status: experimental | Level: high | ID: 181ed94c-be39-597e-a6df-bd53f13a3d95"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
