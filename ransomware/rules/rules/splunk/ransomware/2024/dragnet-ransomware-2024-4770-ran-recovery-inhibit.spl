| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4770 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 19bec73f-55d9-52c6-84ff-6aff3abda49d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
