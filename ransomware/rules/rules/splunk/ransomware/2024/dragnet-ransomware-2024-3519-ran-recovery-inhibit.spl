| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3519 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 721e4141-42f9-5f3f-8c00-01c742f77504"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
