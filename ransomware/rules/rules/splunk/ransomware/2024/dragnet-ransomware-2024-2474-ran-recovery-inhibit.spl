| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2474 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 7fed8848-575c-5074-81a4-52277493f48c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
