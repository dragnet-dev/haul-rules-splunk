| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1823 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 38d7ad64-2081-5060-b3e5-acf9c0f76b00"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
