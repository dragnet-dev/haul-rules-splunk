| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2969 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 455684e6-c169-5ba9-85f2-ba37133586d1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
