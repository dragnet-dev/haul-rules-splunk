| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2334 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 2f1c1147-e67d-5f80-86e2-608daef86130"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
