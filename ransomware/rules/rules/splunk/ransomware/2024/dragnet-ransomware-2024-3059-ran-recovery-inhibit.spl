| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3059 — Recovery Inhibition (mallox)"
| comment "Status: experimental | Level: high | ID: 476c58f6-6a61-5a28-89fe-c99b4ff7c25a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
