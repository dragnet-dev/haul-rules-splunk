| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5388 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: d506f32b-4c73-5dae-bace-2f5be06f613b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
