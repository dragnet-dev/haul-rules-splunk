| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3948 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: e07f7ebb-0fe5-5833-994d-c85c02caf2a6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
