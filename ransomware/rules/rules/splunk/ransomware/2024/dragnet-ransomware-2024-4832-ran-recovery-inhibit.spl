| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4832 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 9f1ea773-20b1-5697-829d-90fdc968fbd8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
