| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0765 — Recovery Inhibition (dragonransomware)"
| comment "Status: experimental | Level: high | ID: 8277965c-3ce2-5ae9-9f6e-430afecce52d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
