| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0389 — Mass File Rename (hunters)"
| comment "Status: experimental | Level: high | ID: e5bfe398-2450-5edd-84be-0494fdb0c274"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
