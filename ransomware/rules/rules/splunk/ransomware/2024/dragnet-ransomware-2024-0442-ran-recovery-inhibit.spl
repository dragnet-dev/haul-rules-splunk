| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0442 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 15d00f4b-bb9d-52a5-86ed-57669ce42ec5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
