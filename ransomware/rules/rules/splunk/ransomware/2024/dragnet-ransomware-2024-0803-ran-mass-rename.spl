| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0803 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 0fc950b6-115f-5385-a070-78b6ff89837a"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
