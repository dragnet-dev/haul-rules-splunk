| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0919 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 334e84cc-7035-542e-bd21-ea2b7d656bbc"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
