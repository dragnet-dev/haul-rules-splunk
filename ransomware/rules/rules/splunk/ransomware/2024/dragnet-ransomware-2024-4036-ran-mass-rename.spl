| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4036 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: c8b305e6-3726-5a1a-bc2e-5a1999d31b77"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
