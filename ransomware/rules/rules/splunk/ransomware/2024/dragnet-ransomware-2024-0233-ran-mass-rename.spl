| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0233 — Mass File Rename (hunters)"
| comment "Status: experimental | Level: high | ID: fcf22fe5-1571-5f2e-9385-0f87e8bc3cf5"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
