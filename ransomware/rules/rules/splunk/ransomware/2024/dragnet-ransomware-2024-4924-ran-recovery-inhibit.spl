| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4924 — Recovery Inhibition (arcusmedia)"
| comment "Status: experimental | Level: high | ID: bcd3b624-62b8-5f21-b7d4-f04e57f1837c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
