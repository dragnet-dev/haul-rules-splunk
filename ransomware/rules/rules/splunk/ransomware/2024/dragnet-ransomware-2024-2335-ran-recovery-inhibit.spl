| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2335 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: cad3d889-533b-5664-ba9f-a0a734a7eb16"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
