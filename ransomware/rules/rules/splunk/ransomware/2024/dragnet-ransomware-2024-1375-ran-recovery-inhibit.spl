| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1375 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 699fddcf-ced1-5887-905c-67d25b30384f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
