| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2841 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 6a66cbc2-a06d-56c0-a444-576ca5a328ea"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
