| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2563 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: 79cfc508-007b-5108-ac79-ceed4e4d26d7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
