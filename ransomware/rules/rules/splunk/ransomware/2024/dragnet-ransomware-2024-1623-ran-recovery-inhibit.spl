| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1623 — Recovery Inhibition (handala)"
| comment "Status: experimental | Level: high | ID: f9ba9d4f-8f5a-536c-a11a-0d5f2aaf1f5f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
