| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3497 — Recovery Inhibition (bluebox)"
| comment "Status: experimental | Level: high | ID: 74eb3804-ffd4-539c-bce6-538e707a7d97"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
