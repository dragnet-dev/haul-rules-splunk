| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5171 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 80edf5c0-6b5d-56d6-a91d-2a159f67e6b9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
