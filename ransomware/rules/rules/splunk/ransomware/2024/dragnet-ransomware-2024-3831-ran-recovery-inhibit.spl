| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3831 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: af7f97bd-69d8-59c6-870a-b89dbd8f6aac"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
