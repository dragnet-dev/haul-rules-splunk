| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5810 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: 4ab3080c-54fd-5b9c-ad77-bfc047cdec85"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
