| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3286 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: 0f110896-3967-5084-94a6-dee7fd52a683"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
