| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5246 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 5a4fe58f-b1c5-59c2-9223-db9bc0b1b632"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
