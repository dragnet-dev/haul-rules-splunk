| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1233 — Recovery Inhibition (ransomhouse)"
| comment "Status: experimental | Level: high | ID: 52a1b8d1-0c64-52e6-afcb-4aa4bc0144b3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
