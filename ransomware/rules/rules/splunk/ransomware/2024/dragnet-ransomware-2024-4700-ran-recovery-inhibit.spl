| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4700 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: 67975507-159a-5be7-95a6-6fff3eccc258"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
