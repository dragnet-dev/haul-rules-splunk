| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2323 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: a02a991f-6c05-5934-805c-4dca2b86ad4c"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
