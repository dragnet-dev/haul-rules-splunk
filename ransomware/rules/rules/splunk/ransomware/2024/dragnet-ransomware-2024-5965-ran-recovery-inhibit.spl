| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5965 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: ae11ca16-7ddc-5efa-b6f4-2da1f95921ed"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
