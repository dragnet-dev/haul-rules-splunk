| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0664 — Recovery Inhibition (blackout)"
| comment "Status: experimental | Level: high | ID: 76b20ec0-7656-5b1e-8ea1-621c0cc3a84d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
