| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3333 — Mass File Rename (incransom)"
| comment "Status: experimental | Level: high | ID: b296d75b-89cb-5144-ac11-da788deb67a9"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
