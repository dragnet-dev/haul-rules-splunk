| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5136 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: f68b7b11-0421-5e26-af19-0557bc1d7a86"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
