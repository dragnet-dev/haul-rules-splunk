| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0168 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: b00e2e2a-fedb-5ad0-b9a2-b50c067e2726"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
