| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4091 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: f0ff7dec-563d-5ff0-ba6a-4af77ddc7678"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
