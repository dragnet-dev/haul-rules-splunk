| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4061 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 9b35e10a-8614-5e39-a70e-d8739ed4c85f"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
