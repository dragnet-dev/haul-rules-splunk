| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1363 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 10a97f10-5c60-587c-a7bb-8ad61a86e4c2"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
