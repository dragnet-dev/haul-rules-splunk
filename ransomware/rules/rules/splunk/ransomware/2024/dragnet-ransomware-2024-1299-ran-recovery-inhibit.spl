| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1299 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: d34cfc17-09f6-5fbc-b610-9df617d0aa5b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
