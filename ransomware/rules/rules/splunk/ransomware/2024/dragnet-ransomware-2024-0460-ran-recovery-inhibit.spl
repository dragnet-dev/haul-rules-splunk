| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0460 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: e7cda94f-a1e3-541e-9864-f2008b0557a1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
