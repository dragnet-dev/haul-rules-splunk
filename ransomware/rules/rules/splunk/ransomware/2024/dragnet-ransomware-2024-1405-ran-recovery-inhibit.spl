| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1405 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 7e88e6c8-e432-5fd5-83fc-a09b91dee6d4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
