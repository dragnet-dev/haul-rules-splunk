| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0572 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: 177a9b15-6595-5ba9-ac27-1f8e2650771f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
