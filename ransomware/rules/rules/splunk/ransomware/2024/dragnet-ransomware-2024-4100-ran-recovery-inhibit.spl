| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4100 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 94ff4a25-9f44-590c-8627-75613978b30e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
