| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1874 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: 391c7eb2-9a3b-50bf-a9af-42b00c5d72b3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
