| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4059 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: c75d4fea-10e6-579b-8cb9-c4c433fd410a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
