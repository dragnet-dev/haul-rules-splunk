| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0059 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 4b861987-efc6-59bd-bd1d-920c70ca003c"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
