| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3133 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: ddb0834b-cb21-5ea9-b656-33d0daaa6696"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
