| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5803 — Recovery Inhibition (threeam)"
| comment "Status: experimental | Level: high | ID: 7b49798c-953c-5797-a80f-fe1c4015ddae"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
