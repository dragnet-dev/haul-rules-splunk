| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5907 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: b14e4a3c-d417-5832-b3e9-7b59c5d8daa2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
