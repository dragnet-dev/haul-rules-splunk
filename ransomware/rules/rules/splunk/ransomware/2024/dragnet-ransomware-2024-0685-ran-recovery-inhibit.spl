| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0685 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 244646bb-f33d-5f5f-bcc6-2c2f154f2546"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
