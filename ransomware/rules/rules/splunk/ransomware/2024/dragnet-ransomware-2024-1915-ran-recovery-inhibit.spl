| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1915 — Recovery Inhibition (BrainCipher)"
| comment "Status: experimental | Level: high | ID: 81d11a93-f7fe-54ee-92ea-a9639e342539"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
