| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2916 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: fe22eb18-4f29-56aa-9dd9-b70b4bd56085"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
