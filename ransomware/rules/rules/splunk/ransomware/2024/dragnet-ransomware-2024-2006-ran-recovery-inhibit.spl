| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2006 — Recovery Inhibition (akira)"
| comment "Status: deprecated | Level: high | ID: 9722a7e7-cc8c-50d2-abaa-b5bedf54142a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
