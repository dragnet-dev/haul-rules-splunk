| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2859 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 064c5639-2b6e-5ed4-80c3-23f87822abdf"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
