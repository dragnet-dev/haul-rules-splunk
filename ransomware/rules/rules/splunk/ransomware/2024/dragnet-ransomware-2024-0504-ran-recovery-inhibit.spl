| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0504 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: a6d21870-546f-52c4-b744-ee37c0bd7e00"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
