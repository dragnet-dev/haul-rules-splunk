| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2590 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: 8f957580-d1a0-5053-b96d-40e388cb2b29"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
