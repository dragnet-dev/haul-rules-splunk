| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3039 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 389b8aad-c5a7-5fd8-a25d-8ec18c776ccb"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
