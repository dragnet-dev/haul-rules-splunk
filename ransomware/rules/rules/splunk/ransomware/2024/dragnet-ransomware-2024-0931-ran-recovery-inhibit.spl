| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0931 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 24589064-6de8-5561-8d82-d8d08385c086"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
