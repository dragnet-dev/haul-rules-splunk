| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3723 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: f8b00ee2-f870-52bd-9b07-a79b6b6a8489"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
