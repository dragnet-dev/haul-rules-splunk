| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5188 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 39c2c40b-94cd-5063-9279-c216a6f85b6d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
