| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0870 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: a561163d-7e93-57cf-aeb2-77654b4b6ed5"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
