| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1698 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: a9a8493f-b949-564b-b2f1-802b0677295c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
