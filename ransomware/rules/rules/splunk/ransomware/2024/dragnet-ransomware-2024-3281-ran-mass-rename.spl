| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3281 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 89e2381d-beb2-5e25-82de-2148cdbbc8d2"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
