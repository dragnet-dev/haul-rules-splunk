| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4141 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: ff4981a2-3fab-5109-abf7-1c28f8d7056f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
