| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5967 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 02a2699c-429f-51bf-a662-09fdde09d16c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
