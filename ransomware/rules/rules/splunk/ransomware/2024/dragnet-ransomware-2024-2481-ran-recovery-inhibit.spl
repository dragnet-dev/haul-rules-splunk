| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2481 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: f5afc19b-4766-5e42-a9a8-8652fba608ef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
