| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5999 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 51daaca3-e594-5e21-9736-a456ba7aed0c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
