| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0711 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 76504dcf-2dc7-5241-85e1-f62db02f1dba"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
