| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3556 — Recovery Inhibition (BrainCipher)"
| comment "Status: experimental | Level: high | ID: c672e6ee-6834-5858-85e4-65b647c91c7f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
