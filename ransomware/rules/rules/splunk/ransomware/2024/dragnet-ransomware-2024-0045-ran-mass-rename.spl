| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0045 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 854b91b0-18cc-5fd5-86df-1fb33847b158"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
