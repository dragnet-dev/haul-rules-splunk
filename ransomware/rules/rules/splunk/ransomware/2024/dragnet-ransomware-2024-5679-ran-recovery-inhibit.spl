| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5679 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: db7bea8b-717a-58c2-8b31-5cbab79f652d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
