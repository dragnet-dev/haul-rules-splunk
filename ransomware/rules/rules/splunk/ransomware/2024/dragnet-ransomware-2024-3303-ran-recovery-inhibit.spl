| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3303 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: ecdbc359-cd62-5c56-a7f1-26e4734f12ef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
