| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0849 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 6f8204fb-31c5-5b9a-b73b-257d050fd5c2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
