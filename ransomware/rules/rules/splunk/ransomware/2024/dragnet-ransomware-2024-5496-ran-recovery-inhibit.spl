| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5496 — Recovery Inhibition (spacebears)"
| comment "Status: experimental | Level: high | ID: 0d6b964e-e0df-567c-9875-35ac3812f15d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
