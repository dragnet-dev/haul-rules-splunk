| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2511 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: cdb31f99-56f5-558b-947c-afc8ce7625c9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
