| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2353 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 1a55d65e-74cb-56e5-a05c-93558cb3dc0b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
