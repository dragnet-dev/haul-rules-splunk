| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1913 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: c40b435d-533b-5f6c-accc-6d8b2e429dce"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
