| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5617 — Recovery Inhibition (funksec)"
| comment "Status: experimental | Level: high | ID: 59ce88bf-308e-59ec-8967-97dae37feb52"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
