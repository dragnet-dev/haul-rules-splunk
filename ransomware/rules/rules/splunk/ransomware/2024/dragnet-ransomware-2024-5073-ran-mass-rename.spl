| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5073 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: e996294c-6e99-5fa0-8e21-912bea290e1a"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
