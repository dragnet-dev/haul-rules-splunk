| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4806 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: a1664b76-9e7d-5d6f-8611-b7cbff43a46a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
