| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3847 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 15974d32-eebb-545c-8651-a8ab4a200bb8"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
