| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2431 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: e3a5de44-9295-5207-b74f-130af7a6b3ce"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
