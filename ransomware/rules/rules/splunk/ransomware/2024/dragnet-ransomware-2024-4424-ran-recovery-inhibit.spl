| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4424 — Recovery Inhibition (raworld)"
| comment "Status: experimental | Level: high | ID: 5b2cf2b2-35c4-59c2-9d1d-3aa81a0e5827"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
