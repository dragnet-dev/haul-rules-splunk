| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2346 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 421dbec8-b3b9-5ac8-8758-c5173d57a192"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
