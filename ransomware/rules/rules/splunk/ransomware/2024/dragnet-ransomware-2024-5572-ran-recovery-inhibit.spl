| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5572 — Recovery Inhibition (ValenciaLeaks)"
| comment "Status: experimental | Level: high | ID: 14212918-8ac7-5cd8-80ed-efa21e259128"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
