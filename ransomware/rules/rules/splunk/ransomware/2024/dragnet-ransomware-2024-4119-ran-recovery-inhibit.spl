| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4119 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: ad59d74a-14b2-5588-afeb-6efd76a26724"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
