| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2975 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: c232ad6a-0bf3-536d-b282-905ddedfd17c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
