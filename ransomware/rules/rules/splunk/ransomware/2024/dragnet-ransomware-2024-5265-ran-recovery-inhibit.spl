| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5265 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: dc0fff86-d873-5ecf-b548-57c27d370c9e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
