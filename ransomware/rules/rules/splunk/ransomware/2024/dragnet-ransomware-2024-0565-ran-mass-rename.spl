| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0565 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: d35e6cbe-dbca-5c75-8bb5-030412f7153f"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
