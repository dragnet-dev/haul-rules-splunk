| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2096 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: 7a361b15-3f11-5ede-8b5d-7d187dfce324"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
