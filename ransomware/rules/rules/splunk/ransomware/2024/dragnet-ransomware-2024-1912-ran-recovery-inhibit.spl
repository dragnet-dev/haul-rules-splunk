| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1912 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 0f8abae4-379b-5513-aca2-bae07ed1d47e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
