| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3046 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 69169605-eb36-5089-a354-16638e8e4bbc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
