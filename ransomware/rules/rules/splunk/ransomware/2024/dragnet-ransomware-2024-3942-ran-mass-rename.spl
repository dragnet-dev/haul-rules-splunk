| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3942 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 84beb5cb-182b-5a9b-a283-d51e39b0f2e8"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
