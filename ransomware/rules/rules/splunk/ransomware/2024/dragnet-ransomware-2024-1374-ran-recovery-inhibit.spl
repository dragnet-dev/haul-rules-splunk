| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1374 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 67842a8b-a960-56c1-85e4-9f6bcd720257"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
