| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0855 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: fd5b4b85-32d1-5a01-9001-9a2ab6a067e4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
