| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5902 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 4750ef06-4447-59b0-999e-1fc3fb34f86c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
