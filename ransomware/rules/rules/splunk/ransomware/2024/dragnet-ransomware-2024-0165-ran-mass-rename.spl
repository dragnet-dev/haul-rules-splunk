| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0165 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 180f3e94-cb42-5407-af8d-2d7e1e437225"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
