| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3678 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: 2bca7cfc-125f-5493-97c1-0f13d072c5df"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
