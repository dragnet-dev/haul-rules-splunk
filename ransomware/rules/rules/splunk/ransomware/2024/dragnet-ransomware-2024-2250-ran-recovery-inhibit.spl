| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2250 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 05bc88d6-1249-5577-86f1-85ff4d12be3c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
