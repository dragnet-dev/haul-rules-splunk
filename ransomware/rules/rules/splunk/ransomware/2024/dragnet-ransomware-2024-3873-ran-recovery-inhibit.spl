| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3873 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: b082a365-ec85-5ca8-acef-cbf2f9932160"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
