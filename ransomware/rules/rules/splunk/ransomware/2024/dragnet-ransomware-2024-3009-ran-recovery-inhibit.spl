| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3009 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 4293989f-4759-58da-9c64-bb94d93f76d8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
