| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3811 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 2cd0457a-bcc3-5012-a1ae-f7763ae00a65"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
