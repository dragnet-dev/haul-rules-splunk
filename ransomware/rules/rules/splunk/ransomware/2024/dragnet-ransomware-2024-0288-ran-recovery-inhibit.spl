| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0288 — Recovery Inhibition (donutleaks)"
| comment "Status: experimental | Level: high | ID: 65101535-f961-5a68-a81d-dcf5baa4bfed"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
