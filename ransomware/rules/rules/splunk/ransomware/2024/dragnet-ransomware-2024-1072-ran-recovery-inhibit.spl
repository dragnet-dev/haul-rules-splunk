| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1072 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: ddb97edc-8843-567f-8ba0-4f220b7b04ba"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
