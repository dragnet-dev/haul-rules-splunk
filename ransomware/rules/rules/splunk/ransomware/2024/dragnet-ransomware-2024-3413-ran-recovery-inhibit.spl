| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3413 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 691a39bb-31f3-502c-b3a3-afb0889b7140"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
