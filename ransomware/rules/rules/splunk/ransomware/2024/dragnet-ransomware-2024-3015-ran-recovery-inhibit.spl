| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3015 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 0f9cb9aa-70ef-5522-bd4a-b640abcd83e2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
