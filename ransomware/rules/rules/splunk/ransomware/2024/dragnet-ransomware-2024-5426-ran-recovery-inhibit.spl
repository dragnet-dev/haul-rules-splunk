| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5426 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 79b5219a-9aa8-5585-8603-8e162c201897"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
