| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4037 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 20578ad6-723b-5a88-8610-7c49b9bb3297"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
