| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3853 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: b589646f-46b2-51b4-8dce-6831777c61d4"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
