| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2104 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 6d3dce59-ad97-55d1-b107-ea5db885e63a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
