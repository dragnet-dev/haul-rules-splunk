| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2535 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: 8457aa8d-f42a-59c9-8a15-6bd6af895c2b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
