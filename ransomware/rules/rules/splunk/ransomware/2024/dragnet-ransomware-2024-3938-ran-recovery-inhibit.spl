| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3938 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: dc4d4b6d-45ca-5b24-bd2f-a8d8962943ab"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
