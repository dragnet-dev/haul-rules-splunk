| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3623 — Recovery Inhibition (funksec)"
| comment "Status: experimental | Level: high | ID: e48991e8-f3c9-5965-82eb-3bb033ab14cc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
