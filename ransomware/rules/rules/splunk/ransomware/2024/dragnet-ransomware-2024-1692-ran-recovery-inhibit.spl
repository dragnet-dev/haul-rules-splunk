| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1692 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: b48eca75-9222-5703-8421-e9e3bb90da89"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
