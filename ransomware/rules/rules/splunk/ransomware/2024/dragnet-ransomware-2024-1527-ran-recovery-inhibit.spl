| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1527 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 5849437d-fa86-51cf-9b4b-56774b04efd2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
