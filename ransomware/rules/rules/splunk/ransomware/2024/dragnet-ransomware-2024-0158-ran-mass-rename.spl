| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0158 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: f0423ad5-4d56-5093-8087-e4dab54cf90a"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
