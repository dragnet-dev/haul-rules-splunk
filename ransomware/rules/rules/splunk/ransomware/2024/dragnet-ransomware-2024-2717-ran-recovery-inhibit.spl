| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2717 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: 8ca1fb38-d925-58c7-8c72-ba75e0850a2c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
