| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5745 — Recovery Inhibition (snatch)"
| comment "Status: experimental | Level: high | ID: 1a53d3ba-3b29-5076-9686-fc3d3adc9f2f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
