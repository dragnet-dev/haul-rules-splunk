| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4850 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: e10c4964-a158-50ee-8b72-18afd123dde1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
