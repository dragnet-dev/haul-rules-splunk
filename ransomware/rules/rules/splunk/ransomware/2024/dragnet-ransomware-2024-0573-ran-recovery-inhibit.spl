| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0573 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: b8f4dcdb-c8bb-505c-9053-4180be32159a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
