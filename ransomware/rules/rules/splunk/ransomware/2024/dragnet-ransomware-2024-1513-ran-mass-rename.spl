| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1513 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 8106ff08-758c-5505-b741-17fbfc2bbb6e"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
