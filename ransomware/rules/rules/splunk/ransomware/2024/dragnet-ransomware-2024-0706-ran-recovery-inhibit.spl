| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0706 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 24a06721-a10f-5c97-b9a0-bc40daabe988"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
