| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3515 — Recovery Inhibition (flocker)"
| comment "Status: experimental | Level: high | ID: 3e181e28-6e8a-5de4-8af1-1b5d863f85d6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
