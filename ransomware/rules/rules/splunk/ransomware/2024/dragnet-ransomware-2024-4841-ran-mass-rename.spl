| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4841 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: be673884-3696-5b91-85a1-ca18d7a8b2fc"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
