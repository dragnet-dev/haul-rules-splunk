| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5522 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 4de71b24-2ea8-51d4-bb25-f6e518d3bc11"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
