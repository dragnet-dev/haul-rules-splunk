| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3515 — Mass File Rename (flocker)"
| comment "Status: experimental | Level: high | ID: 9d46972e-7e1e-5659-86cb-883a213ed725"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
