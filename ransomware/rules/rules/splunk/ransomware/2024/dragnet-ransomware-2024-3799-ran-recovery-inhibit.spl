| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3799 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 9f386644-dfec-5e1c-96dc-5f2fa72d4fc4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
