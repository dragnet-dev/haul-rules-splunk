| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2660 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 621fd157-f276-5d6d-93d1-10236e01e331"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
