| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0625 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: 8f309dc2-bbf2-5f6c-950c-583708ff7fb4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
