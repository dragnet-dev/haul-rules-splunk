| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1779 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: f8d271c0-dd0c-505b-92ec-96c7f1e08da6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
