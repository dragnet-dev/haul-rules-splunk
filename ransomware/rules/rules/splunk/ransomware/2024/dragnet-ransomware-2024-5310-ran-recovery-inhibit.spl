| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5310 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: a9bc6b07-d2ab-57c7-a04c-34973ce74098"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
