| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4969 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 1db71df4-189f-5371-ab95-431a4b98c87f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
