| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4260 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: f19a4698-ceeb-5a5c-a1a7-d427dfa399f9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
