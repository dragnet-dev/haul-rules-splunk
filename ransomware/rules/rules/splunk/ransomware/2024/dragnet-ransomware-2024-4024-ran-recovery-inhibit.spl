| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4024 — Recovery Inhibition (dragonransomware)"
| comment "Status: experimental | Level: high | ID: aa76d6d0-5ab4-5a2f-b620-31fafba1085d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
