| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1164 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 74077b05-aa6b-59cb-ad7a-73b5d5d24590"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
