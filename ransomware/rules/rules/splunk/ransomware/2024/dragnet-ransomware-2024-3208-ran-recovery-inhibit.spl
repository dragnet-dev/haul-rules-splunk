| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3208 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: f2c1cb2b-22f6-582b-9d4d-1d3468fbd882"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
