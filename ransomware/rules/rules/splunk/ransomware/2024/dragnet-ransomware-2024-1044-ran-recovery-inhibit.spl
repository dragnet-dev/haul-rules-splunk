| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1044 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: 6645281a-cda8-5993-85e7-5be65d2a114e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
