| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2581 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 227c6ca2-6eda-5690-afe2-b4a94f83b613"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
