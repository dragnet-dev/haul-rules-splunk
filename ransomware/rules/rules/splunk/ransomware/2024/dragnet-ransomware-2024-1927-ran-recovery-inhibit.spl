| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1927 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 9fc32e5e-6c60-5ee4-89db-930af2ee08ba"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
