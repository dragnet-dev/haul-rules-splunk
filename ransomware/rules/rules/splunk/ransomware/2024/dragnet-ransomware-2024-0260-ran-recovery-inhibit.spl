| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0260 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: ce1edf0d-14f4-5d4e-87b5-2616f82fde3d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
