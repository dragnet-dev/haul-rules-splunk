| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5311 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: d7f34813-949c-56d0-95cc-375e050743ec"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
