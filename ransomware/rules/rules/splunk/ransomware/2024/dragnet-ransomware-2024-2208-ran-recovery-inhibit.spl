| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2208 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 3a14349f-4468-5663-875f-827e25ac57b0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
