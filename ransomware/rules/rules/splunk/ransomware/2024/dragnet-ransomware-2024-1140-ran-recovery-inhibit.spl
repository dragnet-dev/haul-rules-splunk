| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1140 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: e3d6a6e5-f195-5ff4-9ebd-019883a03973"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
