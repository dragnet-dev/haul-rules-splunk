| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2470 — Recovery Inhibition (madliberator)"
| comment "Status: experimental | Level: high | ID: 0cc4b814-7d68-5687-ba35-beec44b922eb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
