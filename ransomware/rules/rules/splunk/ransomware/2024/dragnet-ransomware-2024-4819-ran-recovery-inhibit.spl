| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4819 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: 3cabc36c-f732-550f-8315-c246624ce2a3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
