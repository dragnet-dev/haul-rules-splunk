| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4021 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: e509d518-d4a8-5103-80d3-ecfc0dfa0d60"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
