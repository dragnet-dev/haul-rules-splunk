| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4899 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 9fc903e8-b095-5a78-bfa3-83d1c2e91a3d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
