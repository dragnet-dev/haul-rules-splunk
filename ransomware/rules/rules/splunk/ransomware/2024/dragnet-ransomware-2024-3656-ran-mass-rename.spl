| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3656 — Mass File Rename (handala)"
| comment "Status: experimental | Level: high | ID: 37c11980-058b-556b-b95d-6d00ab807e96"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
