| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4741 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: fe40f9fb-23e7-5d1a-8fd3-2540c2dabcbe"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
