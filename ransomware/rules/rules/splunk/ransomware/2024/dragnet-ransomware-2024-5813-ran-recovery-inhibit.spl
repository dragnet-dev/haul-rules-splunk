| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5813 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: 4fc7fe13-5aae-5cc7-abad-7640dbf9a3a7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
