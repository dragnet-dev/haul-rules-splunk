| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0939 — Recovery Inhibition (ransomhouse)"
| comment "Status: experimental | Level: high | ID: a7e44c27-f9fb-530b-b061-608d1ca38b59"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
