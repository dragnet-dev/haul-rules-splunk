| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5904 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 9cd1ad44-f002-5cbf-be57-fc0d53596f0f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
