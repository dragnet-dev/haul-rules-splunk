| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5243 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 047f35e1-d1a5-57cf-b8ee-da632e168cef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
