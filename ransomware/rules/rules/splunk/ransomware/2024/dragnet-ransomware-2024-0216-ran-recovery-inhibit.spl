| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0216 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 27cbc51b-1746-5c80-8dfc-4447123489c7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
