| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2797 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 46857593-cef2-59f8-b07b-b8e4f5f11b2b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
