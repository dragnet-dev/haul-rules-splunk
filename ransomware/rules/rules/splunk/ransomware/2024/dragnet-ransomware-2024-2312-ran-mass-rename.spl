| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2312 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 91ec1a78-3096-54fc-9b09-9109ec62eefb"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
