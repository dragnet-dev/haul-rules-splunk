| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0345 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 0982a68e-30ed-589d-af72-9b773d8f6938"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
