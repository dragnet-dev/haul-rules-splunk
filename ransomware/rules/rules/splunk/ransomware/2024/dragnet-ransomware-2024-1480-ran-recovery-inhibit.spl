| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1480 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: a3520c79-a3ed-5945-8bf0-95c747c478ad"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
