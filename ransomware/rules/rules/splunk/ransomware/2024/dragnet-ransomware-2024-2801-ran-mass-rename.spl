| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2801 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 393e3226-8192-5550-b520-f281d094f035"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
