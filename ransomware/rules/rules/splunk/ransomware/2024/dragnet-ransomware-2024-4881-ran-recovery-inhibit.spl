| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4881 — Recovery Inhibition (embargo)"
| comment "Status: experimental | Level: high | ID: 79e9fd44-5cf9-59bb-82b9-3f923028c950"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
