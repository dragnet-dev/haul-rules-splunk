| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1462 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 31e0ff38-1ae9-5025-a1c1-aa1b94401371"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
