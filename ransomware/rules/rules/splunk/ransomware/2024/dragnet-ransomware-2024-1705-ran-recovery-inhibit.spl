| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1705 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: f0e604df-4b3c-5fcd-98a2-b5c8e42e3afb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
