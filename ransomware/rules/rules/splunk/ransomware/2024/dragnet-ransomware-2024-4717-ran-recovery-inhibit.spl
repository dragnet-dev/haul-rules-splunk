| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4717 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: c898b2c8-7700-5798-8fc2-74139836406c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
