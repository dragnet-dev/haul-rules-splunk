| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5860 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: 7a764486-9318-554a-8dcd-9c40f23febac"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
