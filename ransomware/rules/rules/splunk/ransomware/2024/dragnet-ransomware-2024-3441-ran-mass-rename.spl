| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3441 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 903cb326-edf2-5e86-833e-3abade63bc60"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
