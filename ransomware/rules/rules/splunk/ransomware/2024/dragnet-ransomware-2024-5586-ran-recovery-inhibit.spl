| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5586 — Recovery Inhibition (cicada3301)"
| comment "Status: experimental | Level: high | ID: 70a6e253-f174-5b6b-a6e3-4b7e035e999a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
