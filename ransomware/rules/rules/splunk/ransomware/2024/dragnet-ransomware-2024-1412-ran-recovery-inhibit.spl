| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1412 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 592d1ee4-6a90-54c0-a59d-6df500193a41"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
