| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4060 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 97db2820-1cb5-559f-a8c4-d96f9e658306"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
