| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5825 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: ef9da18f-4026-58d8-b316-d68e8dadb496"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
