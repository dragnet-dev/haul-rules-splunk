| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2114 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 562e82e7-1388-5173-bc53-e40178ada05d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
