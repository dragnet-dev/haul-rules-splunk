| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5157 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: 72af1248-b526-5696-8233-3029cb45a907"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
