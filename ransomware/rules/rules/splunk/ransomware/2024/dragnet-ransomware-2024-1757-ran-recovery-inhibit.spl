| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1757 — Recovery Inhibition (dragonransomware)"
| comment "Status: experimental | Level: high | ID: 3a96db44-3c8d-556d-9525-e905908428e1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
