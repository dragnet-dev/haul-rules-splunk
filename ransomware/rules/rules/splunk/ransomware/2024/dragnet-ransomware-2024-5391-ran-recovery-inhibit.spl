| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5391 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 04804ea3-5be1-59f6-86d9-84a964cff881"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
