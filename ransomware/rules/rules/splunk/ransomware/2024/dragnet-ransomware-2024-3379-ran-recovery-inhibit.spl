| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3379 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: b2e30137-83b4-5ca2-b319-b0e243afe462"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
