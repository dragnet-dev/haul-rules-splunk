| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4356 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 35223458-0f01-5bc7-8611-8479ca07c00e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
