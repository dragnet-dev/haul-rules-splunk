| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-0026 — Recovery Inhibition (cicada3301)"
| comment "Status: experimental | Level: high | ID: d470b5dc-ec28-5a64-9069-5cc2597a23ff"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
