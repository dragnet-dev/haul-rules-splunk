| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5141 — Recovery Inhibition (snatch)"
| comment "Status: experimental | Level: high | ID: cdae451f-1550-5530-bdc0-7e1c98ccbdda"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
