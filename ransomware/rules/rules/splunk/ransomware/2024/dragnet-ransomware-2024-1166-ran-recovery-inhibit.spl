| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1166 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: a2f2899e-d67e-5cff-bab4-2211da961dc3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
