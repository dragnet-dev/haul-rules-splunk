| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5211 — Recovery Inhibition (qiulong)"
| comment "Status: experimental | Level: high | ID: cab6a74e-3850-55be-aa3c-870f9ee7d7e1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
