| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2542 — Recovery Inhibition (blacksuit)"
| comment "Status: experimental | Level: high | ID: 46712379-83dd-56b8-a2b8-18818d2f13fc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
