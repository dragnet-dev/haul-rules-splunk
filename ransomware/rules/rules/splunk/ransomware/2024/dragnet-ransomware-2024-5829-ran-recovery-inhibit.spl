| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5829 — Recovery Inhibition (darkvault)"
| comment "Status: experimental | Level: high | ID: 26436dfa-bad5-5423-8dce-f8753383381f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
