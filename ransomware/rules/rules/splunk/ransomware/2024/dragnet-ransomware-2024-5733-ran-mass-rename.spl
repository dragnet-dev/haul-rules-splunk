| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5733 — Mass File Rename (incransom)"
| comment "Status: experimental | Level: high | ID: 7e5e9655-574e-5dca-a567-51fbfb8647e3"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
