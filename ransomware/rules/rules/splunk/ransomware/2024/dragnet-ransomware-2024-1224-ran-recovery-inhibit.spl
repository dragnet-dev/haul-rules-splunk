| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1224 — Recovery Inhibition (donex)"
| comment "Status: experimental | Level: high | ID: 5181ea64-d8ff-5377-9ef0-ffbed6c0036c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
