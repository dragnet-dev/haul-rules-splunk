| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1366 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 90fbb2e0-86be-5281-abe7-cc55648bcbc5"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
