| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3891 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: 5f9d1e30-72c7-553c-abef-6b4729b65f5a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
