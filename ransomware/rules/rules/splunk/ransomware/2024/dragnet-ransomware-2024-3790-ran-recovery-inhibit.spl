| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-3790 — Recovery Inhibition (arcusmedia)"
| comment "Status: experimental | Level: high | ID: fc5df778-78d2-517e-8aed-710be8cba0d1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
