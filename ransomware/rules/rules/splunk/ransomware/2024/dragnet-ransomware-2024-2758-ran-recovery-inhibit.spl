| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-2758 — Recovery Inhibition (knight)"
| comment "Status: experimental | Level: high | ID: a42189bd-aba5-503f-a13f-20a01e3cba7c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
