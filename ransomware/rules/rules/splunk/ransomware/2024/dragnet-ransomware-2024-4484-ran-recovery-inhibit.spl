| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4484 — Recovery Inhibition (flocker)"
| comment "Status: experimental | Level: high | ID: af749e65-4a27-5847-85ce-7ef9ee567790"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
