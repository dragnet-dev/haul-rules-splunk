| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-4622 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 190b063b-0686-57f8-bb0a-92139f8471cd"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
