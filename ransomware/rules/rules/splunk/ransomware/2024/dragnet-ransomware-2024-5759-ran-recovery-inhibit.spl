| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5759 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 8b3f2bb8-ce84-5176-b974-c255a48b5928"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
