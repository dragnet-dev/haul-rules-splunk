| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-1556 — Mass File Rename (hunters)"
| comment "Status: experimental | Level: high | ID: 999e2cba-252e-5970-b2ea-0059258880e9"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
