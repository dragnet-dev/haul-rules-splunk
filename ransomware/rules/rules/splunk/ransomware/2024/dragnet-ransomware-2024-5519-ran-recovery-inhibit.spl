| comment "Dragnet [Ransomware]: dragnet-ransomware-2024-5519 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: 05428a8e-7f26-5d1d-8a64-ba80ac52e7df"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
