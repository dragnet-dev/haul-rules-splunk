| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4260 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 47b97389-4e76-5e31-b07c-5b7823fd7853"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
