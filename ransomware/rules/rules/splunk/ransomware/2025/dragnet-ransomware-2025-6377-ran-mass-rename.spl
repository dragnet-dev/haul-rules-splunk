| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6377 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 4cb44f06-19ab-507a-89e7-82d39ad47fa7"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
