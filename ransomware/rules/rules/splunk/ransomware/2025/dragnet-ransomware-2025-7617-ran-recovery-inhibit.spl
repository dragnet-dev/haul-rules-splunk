| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7617 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: 8dfdb63c-e53c-55f5-8e7c-ea424468af3e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
