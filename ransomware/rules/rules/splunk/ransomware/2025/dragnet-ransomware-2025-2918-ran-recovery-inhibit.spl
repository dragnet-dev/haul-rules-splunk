| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2918 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: c565f332-0752-5921-bdc6-c0eebc90b15d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
