| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0731 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 93b84fce-576b-5234-9e3e-337373eec0b1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
