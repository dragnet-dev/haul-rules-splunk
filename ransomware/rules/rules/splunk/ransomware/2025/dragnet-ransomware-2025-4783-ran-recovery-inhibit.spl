| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4783 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: e9d6f2b8-4fed-5e42-a306-97f3ff2d8ae3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
