| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1590 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 41972c4d-7a3a-5c14-a001-558e552a322c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
