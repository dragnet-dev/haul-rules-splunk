| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0825 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: dd0323c4-6d6b-57d4-82ac-2dcb872412d2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
