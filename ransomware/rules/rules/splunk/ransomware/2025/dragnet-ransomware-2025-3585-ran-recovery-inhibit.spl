| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3585 — Recovery Inhibition (kairos)"
| comment "Status: experimental | Level: high | ID: 80e59928-c681-5d59-811b-7f936dce33b4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
