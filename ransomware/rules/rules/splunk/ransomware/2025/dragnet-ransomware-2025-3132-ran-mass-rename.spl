| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3132 — Mass File Rename (handala)"
| comment "Status: experimental | Level: high | ID: e8b78672-aac9-55ff-a1ec-d630bff88d96"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
