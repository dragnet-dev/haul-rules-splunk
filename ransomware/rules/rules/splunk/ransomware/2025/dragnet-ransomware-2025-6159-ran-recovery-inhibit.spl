| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6159 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: 0a022a55-e8ff-59cd-a00d-8cc158520cc4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
