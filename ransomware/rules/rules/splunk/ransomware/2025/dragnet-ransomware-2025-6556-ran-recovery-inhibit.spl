| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6556 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: cbd69ae2-a08b-5d18-a07d-bddc2670a8ea"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
