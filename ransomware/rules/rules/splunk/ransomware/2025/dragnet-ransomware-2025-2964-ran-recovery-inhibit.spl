| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2964 — Recovery Inhibition (direwolf)"
| comment "Status: experimental | Level: high | ID: bda5f673-eaa4-54b0-9f59-5856c886b790"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
