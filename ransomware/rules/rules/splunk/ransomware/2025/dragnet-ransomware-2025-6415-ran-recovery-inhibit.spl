| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6415 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: c628acd2-1c0a-5c3a-92f2-5c82e595744f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
