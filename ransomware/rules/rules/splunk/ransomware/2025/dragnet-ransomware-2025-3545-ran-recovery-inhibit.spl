| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3545 — Recovery Inhibition (spacebears)"
| comment "Status: experimental | Level: high | ID: d48370f3-a76e-5d2c-97e7-275984b3ee47"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
