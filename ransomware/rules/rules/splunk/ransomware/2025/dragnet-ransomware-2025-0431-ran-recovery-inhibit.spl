| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0431 — Recovery Inhibition (anubis)"
| comment "Status: experimental | Level: high | ID: 31db92c6-fb66-5957-bb5d-2b464ae6bd1e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
