| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6956 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: dfe4dfcf-0e0b-5b2b-8865-0980631b9e67"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
