| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2076 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 9a0ff940-6627-528b-8923-344309e317b2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
