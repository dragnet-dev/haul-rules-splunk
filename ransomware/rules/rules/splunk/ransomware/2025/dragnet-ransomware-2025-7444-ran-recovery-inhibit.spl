| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7444 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: cf0f2892-0d55-5bd8-9a69-b83522e383fb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
