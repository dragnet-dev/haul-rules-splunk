| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2840 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 1bf67236-75b6-5bb2-8e4f-49b8a7d03022"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
