| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5347 — Recovery Inhibition (cicada3301)"
| comment "Status: experimental | Level: high | ID: 5a400e87-1e2e-52b9-9c2b-7b58545a7225"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
