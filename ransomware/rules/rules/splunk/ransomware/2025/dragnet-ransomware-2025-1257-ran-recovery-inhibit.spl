| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1257 — Recovery Inhibition (funksec)"
| comment "Status: experimental | Level: high | ID: c78771d4-dd47-592d-996b-c063e3e657a3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
