| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6001 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: fb4193f3-d9cc-5e80-8bd9-54163ed37ccf"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
