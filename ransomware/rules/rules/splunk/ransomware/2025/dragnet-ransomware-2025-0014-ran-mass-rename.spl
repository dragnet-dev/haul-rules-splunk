| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0014 — Mass File Rename (incransom)"
| comment "Status: experimental | Level: high | ID: 285535e9-26e0-5585-ab0a-c5507819ccab"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
