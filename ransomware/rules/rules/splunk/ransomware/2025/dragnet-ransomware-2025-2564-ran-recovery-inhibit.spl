| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2564 — Recovery Inhibition (blacknevas)"
| comment "Status: experimental | Level: high | ID: 19e154bc-cc37-5fca-a227-ee920f6cab1f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
