| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1433 — Recovery Inhibition (blackshrantac)"
| comment "Status: experimental | Level: high | ID: 5db49be7-cfb6-5d52-a743-9fa8fdafba60"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
