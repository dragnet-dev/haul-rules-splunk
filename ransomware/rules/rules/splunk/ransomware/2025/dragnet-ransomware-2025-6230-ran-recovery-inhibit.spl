| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6230 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 98f23bf7-9a4f-538b-8c13-be562e32e806"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
