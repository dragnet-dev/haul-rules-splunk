| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1339 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 1584173f-b7ef-5a38-84f8-6ee3334f7e7d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
