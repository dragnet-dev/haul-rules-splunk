| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1151 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 855378ac-67b1-5919-b32b-f569ab37c38d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
