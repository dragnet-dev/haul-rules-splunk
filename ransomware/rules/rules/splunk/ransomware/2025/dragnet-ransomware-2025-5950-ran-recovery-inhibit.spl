| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5950 — Recovery Inhibition (pear)"
| comment "Status: experimental | Level: high | ID: 16a38197-10a7-5c91-879b-6fbe1aa4bc19"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
