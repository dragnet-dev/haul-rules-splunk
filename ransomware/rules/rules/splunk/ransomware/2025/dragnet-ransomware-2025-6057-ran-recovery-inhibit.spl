| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6057 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 44918fb3-a901-5c05-90f0-9ee00b88b486"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
