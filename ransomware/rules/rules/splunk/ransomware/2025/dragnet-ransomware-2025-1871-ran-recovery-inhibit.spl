| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1871 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: e4da8694-26e7-5c3f-bb0e-e50c68e1346b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
