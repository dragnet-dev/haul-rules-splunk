| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0727 — Recovery Inhibition (everest)"
| comment "Status: experimental | Level: high | ID: 9c4bda8b-9025-5e18-8769-61f9ea7194c7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
