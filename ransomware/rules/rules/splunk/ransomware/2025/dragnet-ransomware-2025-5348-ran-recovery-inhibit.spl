| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5348 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: e933c216-d7bc-596e-b799-505b2bd254df"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
