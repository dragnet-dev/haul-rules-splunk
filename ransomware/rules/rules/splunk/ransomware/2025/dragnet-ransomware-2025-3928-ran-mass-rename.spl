| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3928 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 86999493-a7ae-5c4a-8d43-2638728e77fc"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
