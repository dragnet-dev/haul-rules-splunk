| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2509 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 30615883-42a6-5c7f-a603-bc9dcd854b96"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
