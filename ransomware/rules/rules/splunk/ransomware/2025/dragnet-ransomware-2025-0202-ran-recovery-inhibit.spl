| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0202 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: dc0e9a04-1adb-568c-a37b-3180657c1785"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
