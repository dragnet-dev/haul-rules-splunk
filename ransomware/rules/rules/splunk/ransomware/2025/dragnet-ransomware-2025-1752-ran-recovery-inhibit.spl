| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1752 — Recovery Inhibition (spacebears)"
| comment "Status: experimental | Level: high | ID: a0fc2036-6065-5d35-83e7-1a61ae7e16e6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
