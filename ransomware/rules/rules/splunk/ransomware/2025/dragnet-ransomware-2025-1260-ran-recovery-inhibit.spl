| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1260 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 9ec546e9-f99c-5dc0-9cfe-ea5359968651"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
