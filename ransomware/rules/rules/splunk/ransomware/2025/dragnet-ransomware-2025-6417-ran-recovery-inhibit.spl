| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6417 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 1cc65c69-2395-53b6-a581-301311e7511e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
