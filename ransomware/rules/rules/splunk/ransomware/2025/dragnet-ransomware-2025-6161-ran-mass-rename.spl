| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6161 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: f1bf3d32-e320-56db-9fb9-aadcb1d2210d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
