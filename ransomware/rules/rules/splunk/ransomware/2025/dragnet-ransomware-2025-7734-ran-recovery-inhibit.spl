| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7734 — Recovery Inhibition (everest)"
| comment "Status: experimental | Level: high | ID: 8b0b7b21-71fe-5d9c-9db2-ed9ae77d158b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
