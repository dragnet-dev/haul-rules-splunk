| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6523 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: d0b4c7a3-679b-5ae8-a462-8eb41f15df29"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
