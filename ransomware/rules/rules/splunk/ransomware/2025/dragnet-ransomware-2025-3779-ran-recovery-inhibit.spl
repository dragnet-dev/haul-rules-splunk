| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3779 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 984861f0-c6da-56a7-be38-7d8c103ce9be"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
