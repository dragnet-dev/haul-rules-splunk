| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6143 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: eede26b5-b017-5e76-9023-350226b2fce2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
