| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7166 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 1880a8a3-0847-5727-a168-fd2b0c82ae46"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
