| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4808 — Recovery Inhibition (lockbit5)"
| comment "Status: experimental | Level: high | ID: f35b3890-ddbd-5ff4-acfe-851129932d82"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
