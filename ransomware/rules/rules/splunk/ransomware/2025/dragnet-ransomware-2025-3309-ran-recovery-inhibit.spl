| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3309 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: d55fa557-7fcc-5599-9888-4d48d9791cb3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
