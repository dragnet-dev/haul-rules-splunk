| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0264 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 1208fdf2-e8bf-5991-bab4-a8d467423831"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
