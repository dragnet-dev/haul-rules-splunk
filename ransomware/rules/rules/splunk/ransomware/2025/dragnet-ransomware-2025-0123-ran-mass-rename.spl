| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0123 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: d8409ca7-3ddd-5a08-840f-a7e6a54d254e"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
