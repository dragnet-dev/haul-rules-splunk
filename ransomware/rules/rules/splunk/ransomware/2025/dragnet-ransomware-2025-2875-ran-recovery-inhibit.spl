| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2875 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: 5f698b8e-cbbf-53e7-a310-481e19a3f1cb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
