| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4002 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: cc52c576-52f0-533a-9a17-14f8afa02658"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
