| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7816 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 0c572203-bb48-587c-b5d7-9fea2861b714"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
