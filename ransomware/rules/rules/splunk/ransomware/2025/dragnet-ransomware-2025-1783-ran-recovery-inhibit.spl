| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1783 — Recovery Inhibition (bqtlock)"
| comment "Status: experimental | Level: high | ID: f8f0b687-a23d-5153-ae63-fdaccd4b31a6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
