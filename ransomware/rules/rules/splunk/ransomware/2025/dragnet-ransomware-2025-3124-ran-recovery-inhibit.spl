| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3124 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: f5e31176-3b57-5dd5-8d04-11a45c9f65b4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
