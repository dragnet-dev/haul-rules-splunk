| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0572 — Recovery Inhibition (devman)"
| comment "Status: experimental | Level: high | ID: 0ccde837-aa35-5ead-abcc-97ec95a87b94"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
