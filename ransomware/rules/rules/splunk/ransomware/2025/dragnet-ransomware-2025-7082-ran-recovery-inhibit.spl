| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7082 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 53824a1c-090a-5b6c-b2ef-4be8878af54c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
