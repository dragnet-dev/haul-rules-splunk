| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1773 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 256f2ffd-d2e0-55bc-9a8a-6e3d76c41076"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
