| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6860 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 0e41d925-c19c-5718-a661-ed23d0b754ac"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
