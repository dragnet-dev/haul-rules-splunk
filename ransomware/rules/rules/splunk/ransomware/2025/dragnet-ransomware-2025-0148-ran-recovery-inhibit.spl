| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0148 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 2f2b4d3e-690a-5467-bf41-511055a9f38e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
