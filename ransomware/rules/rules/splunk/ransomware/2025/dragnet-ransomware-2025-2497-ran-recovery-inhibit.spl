| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2497 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 3df232af-20a6-533f-bf73-7eb6e1ce0638"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
