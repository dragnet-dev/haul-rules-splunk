| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0933 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: e069c10e-db42-5b01-9d91-061e4ea84a2c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
