| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3564 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: c67cf8f7-4a48-56af-b9b0-2a10cf4999fb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
