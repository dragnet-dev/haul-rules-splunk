| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1856 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 053f3a95-dc9d-5662-b551-3e37733c5259"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
