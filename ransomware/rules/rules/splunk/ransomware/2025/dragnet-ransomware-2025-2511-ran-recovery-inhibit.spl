| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2511 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: f721e505-07b6-50e7-982f-92782ead4236"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
