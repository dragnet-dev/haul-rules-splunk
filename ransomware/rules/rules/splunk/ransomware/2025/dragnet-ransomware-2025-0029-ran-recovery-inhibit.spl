| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0029 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: cb033c5a-b39e-51c1-bd72-25e8d9ec3fbe"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
