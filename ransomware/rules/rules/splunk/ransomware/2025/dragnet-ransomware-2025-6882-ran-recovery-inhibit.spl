| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6882 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 41c56571-04cc-5cfa-b3b3-47d52465c1f5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
