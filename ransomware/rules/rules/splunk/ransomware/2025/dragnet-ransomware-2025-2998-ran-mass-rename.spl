| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2998 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: fb820d80-484a-5e7a-831d-6eefc9acef6b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
