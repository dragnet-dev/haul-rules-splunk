| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4869 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 48fe7e14-24a6-5f98-b66a-6173c7c71cc6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
