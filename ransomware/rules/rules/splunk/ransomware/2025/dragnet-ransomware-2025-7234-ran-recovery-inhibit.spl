| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7234 — Recovery Inhibition (tengu)"
| comment "Status: experimental | Level: high | ID: ea19746b-7d34-52bb-b375-9a31f521a470"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
