| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5809 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 434476cf-5398-5a3e-8fff-64bcf03b9a62"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
