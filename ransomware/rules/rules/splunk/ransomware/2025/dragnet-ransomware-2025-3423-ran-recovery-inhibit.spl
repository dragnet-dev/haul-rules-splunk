| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3423 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 735d6af3-7989-5269-b33f-a9cf515a46de"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
