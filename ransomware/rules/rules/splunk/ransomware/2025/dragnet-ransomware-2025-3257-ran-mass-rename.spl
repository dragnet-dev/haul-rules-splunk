| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3257 — Mass File Rename (flocker)"
| comment "Status: experimental | Level: high | ID: e0bbaae4-bdd5-55aa-b6ba-73ad83d82722"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
