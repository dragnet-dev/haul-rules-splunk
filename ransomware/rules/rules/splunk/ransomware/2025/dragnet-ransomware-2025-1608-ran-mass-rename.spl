| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1608 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: e5d23a57-4574-5120-8a6c-86b9d56e0413"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
