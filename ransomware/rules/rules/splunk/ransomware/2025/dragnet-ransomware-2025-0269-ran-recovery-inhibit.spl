| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0269 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: f981f7c4-1c8a-54f4-86f0-4e8a8c5e97f1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
