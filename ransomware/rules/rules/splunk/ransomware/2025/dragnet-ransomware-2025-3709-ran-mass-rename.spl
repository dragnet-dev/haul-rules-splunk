| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3709 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: adfcaa2e-d5d2-525a-bda4-ae36518c0cdc"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
