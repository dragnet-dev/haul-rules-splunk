| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6904 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 8badb678-0e09-5cb1-93af-d3442035d922"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
