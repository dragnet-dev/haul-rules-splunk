| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7609 — Recovery Inhibition (handala)"
| comment "Status: experimental | Level: high | ID: 5a7e7817-3390-5c0c-943d-6c1a54c5b9f3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
