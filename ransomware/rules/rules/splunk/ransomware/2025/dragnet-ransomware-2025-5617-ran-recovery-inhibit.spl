| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5617 — Recovery Inhibition (devman)"
| comment "Status: experimental | Level: high | ID: dfb1f8b5-d5b8-5751-884c-55b246795390"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
