| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3853 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 9582c316-ed4e-5681-b7ee-d859a65abd9c"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
