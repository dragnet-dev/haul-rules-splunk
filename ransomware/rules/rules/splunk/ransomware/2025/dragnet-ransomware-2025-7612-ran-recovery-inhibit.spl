| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7612 — Recovery Inhibition (interlock)"
| comment "Status: experimental | Level: high | ID: 0721228e-a206-52cb-a982-e9cc0d7fc194"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
