| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6633 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: c39fcddc-4c57-5dce-88ca-67dc0826e26b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
