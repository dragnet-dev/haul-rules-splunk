| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6350 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 4be3503d-945b-5cfe-9cba-c1c399082a98"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
