| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5323 — Recovery Inhibition (sinobi)"
| comment "Status: experimental | Level: high | ID: 416ca82f-2095-55a8-8ab8-3d8d28d715c8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
