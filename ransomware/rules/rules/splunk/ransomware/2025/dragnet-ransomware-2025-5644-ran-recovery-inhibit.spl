| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5644 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 445dbae7-e3b0-5649-8ea4-085a431bf3cd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
