| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2419 — Recovery Inhibition (thegentlemen)"
| comment "Status: experimental | Level: high | ID: 6ca484cb-2667-507e-b978-983ba3174819"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
