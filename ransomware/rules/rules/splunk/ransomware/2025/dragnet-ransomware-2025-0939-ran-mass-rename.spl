| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0939 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 14ef901a-121f-5c00-b414-6ddb7072d39c"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
