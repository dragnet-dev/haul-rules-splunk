| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2094 — Recovery Inhibition (direwolf)"
| comment "Status: experimental | Level: high | ID: 2ae1b43e-c491-5803-9ee9-ab4e992cb488"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
