| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6330 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: df8b3dd8-d800-5081-a9f7-ceca6a7bf7e2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
