| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5574 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: ffef8346-c9a1-5727-a86a-5d080848e697"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
