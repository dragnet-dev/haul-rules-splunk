| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5011 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 64dd532e-4a98-5096-b621-2239a839abb8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
