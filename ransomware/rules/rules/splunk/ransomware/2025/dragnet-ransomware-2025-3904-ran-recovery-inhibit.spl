| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3904 — Recovery Inhibition (flocker)"
| comment "Status: experimental | Level: high | ID: ff6ebef6-79b4-5478-b0c6-72127644f6da"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
