| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3542 — Recovery Inhibition (kairos)"
| comment "Status: experimental | Level: high | ID: 23bc2287-5fb2-5c8f-ad90-434f2f98671a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
