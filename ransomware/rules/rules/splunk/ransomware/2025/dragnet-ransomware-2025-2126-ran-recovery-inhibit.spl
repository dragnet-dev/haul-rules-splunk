| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2126 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: f917a7f0-ba37-53cf-8933-93e5eed34484"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
