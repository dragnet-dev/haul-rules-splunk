| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3271 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 53609259-e5cf-5d55-88ca-ef40addc724d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
