| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5544 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: a5ea5a30-4537-5e59-9148-8e6916accdfe"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
