| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1778 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: f1f6ddbd-b624-54bf-8a20-a7c68df57b80"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
