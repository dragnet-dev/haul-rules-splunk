| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3724 — Recovery Inhibition (sinobi)"
| comment "Status: experimental | Level: high | ID: d037ce2a-4e09-5bca-b91d-9766b08cc6e8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
