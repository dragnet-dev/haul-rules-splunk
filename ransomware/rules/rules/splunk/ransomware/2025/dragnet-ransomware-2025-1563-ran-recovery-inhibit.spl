| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1563 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: b705630f-9bbd-59a6-99b0-4203234d3983"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
