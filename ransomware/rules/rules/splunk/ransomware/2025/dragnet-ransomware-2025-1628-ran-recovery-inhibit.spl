| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1628 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 6ad57588-7097-5ff6-bbba-9ecdd7aa4b71"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
