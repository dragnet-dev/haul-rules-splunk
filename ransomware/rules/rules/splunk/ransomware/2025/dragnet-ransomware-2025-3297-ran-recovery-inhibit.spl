| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3297 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: c1147058-e63c-54be-ad8a-097cca0ae663"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
