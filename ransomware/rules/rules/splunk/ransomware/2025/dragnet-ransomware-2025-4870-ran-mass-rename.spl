| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4870 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 00bd42b6-475f-5511-a82d-ea0a07e65f73"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
