| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7483 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 991470a1-b330-59a7-aa9e-177af0bbe4da"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
