| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1419 — Recovery Inhibition (funksec)"
| comment "Status: experimental | Level: high | ID: 4347af8c-fe4e-5b20-8c03-57f0c6302158"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
