| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2435 — Recovery Inhibition (thegentlemen)"
| comment "Status: experimental | Level: high | ID: f2378c66-861c-563b-be2f-0131b9cb76a6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
