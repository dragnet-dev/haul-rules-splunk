| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3112 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: cadb78b0-8946-5b52-ad36-f0827eb5175d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
