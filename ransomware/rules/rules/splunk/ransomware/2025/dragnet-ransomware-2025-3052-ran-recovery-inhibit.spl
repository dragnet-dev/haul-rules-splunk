| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3052 — Recovery Inhibition (cicada3301)"
| comment "Status: experimental | Level: high | ID: f9ed9a9b-cfc1-59f1-80c4-3b03a36620c7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
