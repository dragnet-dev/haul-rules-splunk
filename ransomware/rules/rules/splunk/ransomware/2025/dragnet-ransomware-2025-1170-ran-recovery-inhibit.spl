| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1170 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 004a3f13-357f-5f67-8e40-a877ad093a3b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
