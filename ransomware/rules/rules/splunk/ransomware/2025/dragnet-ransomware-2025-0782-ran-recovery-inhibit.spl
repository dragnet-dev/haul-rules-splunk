| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0782 — Recovery Inhibition (bert)"
| comment "Status: experimental | Level: high | ID: 37fda110-3d27-544a-92fe-d9ffc1628eef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
