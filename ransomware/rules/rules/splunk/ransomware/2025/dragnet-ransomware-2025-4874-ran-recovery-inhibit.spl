| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4874 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: 3990c710-9da4-5b5b-b539-cf002134664c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
