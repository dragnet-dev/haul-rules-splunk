| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0986 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 4241be92-a975-5b11-967b-534cfe6bad5e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
