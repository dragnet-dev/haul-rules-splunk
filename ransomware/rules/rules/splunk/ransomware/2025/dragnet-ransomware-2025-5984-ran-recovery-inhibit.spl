| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5984 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: a72631fe-8923-5e14-9d1d-85dd053f2f32"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
