| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0068 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 6df9d44c-e517-516b-badd-8a105034b4c3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
