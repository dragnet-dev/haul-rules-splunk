| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7533 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: faede4ae-18e4-5480-9f26-fafa84db4552"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
