| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0665 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: c1647ddd-147b-523e-826b-6b8ac044be27"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
