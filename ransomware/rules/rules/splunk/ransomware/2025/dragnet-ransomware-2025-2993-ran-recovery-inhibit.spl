| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2993 — Recovery Inhibition (chaos)"
| comment "Status: experimental | Level: high | ID: b049ac4f-16d6-591d-b4e1-201c1755c114"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
