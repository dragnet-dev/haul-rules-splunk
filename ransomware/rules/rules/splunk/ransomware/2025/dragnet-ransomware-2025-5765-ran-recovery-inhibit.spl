| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5765 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: a0ebb75f-c470-5898-ad3e-b02205e07380"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
