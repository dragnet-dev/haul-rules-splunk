| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2285 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: cef8b91a-eff2-500e-98e2-121114ff6c08"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
