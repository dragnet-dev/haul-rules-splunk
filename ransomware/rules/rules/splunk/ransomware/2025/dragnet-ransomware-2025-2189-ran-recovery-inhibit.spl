| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2189 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 724846dd-6cb4-57be-ba23-79af65927e70"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
