| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4976 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: c0b0ccdf-806d-5ec6-8bb7-3955bf206689"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
