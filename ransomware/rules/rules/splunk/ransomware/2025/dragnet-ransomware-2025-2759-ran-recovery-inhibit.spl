| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2759 — Recovery Inhibition (shinyhunters)"
| comment "Status: experimental | Level: high | ID: 0910519b-6105-5eed-a029-2d26770f4e9e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
