| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7053 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 6cc0199e-e714-5c73-93ca-43551d319aab"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
