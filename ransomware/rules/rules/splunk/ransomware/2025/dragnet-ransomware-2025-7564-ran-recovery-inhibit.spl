| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7564 — Recovery Inhibition (nova)"
| comment "Status: experimental | Level: high | ID: 37d93257-3d55-5e47-b98e-9064de61abe3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
