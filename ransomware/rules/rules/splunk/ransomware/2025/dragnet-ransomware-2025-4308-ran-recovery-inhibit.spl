| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4308 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: cf113774-e2af-5285-bec1-c360ce88d26c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
