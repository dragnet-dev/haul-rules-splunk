| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5146 — Recovery Inhibition (shinyhunters)"
| comment "Status: experimental | Level: high | ID: 52b0656d-7b0f-5ae8-af28-89338515a6c8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
