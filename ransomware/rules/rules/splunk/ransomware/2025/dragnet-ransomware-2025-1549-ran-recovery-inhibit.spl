| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1549 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 4859904c-b4e6-594b-8249-ec240bc2e914"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
