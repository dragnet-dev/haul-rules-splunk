| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4870 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 2c7d2e63-64b1-5337-8b95-9de901f191ee"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
