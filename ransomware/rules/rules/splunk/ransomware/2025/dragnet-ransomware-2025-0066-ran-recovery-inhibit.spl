| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0066 — Recovery Inhibition (funksec)"
| comment "Status: experimental | Level: high | ID: 56acb147-e796-5ede-b275-61ae9a8688f6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
