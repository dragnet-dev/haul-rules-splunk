| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6297 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 3ec0e8d6-b85a-5676-8f90-b2a16b7d60b0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
