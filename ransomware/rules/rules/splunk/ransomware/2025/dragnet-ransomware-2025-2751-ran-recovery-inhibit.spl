| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2751 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 68231360-99d6-501d-ac76-6f9eab53dcba"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
