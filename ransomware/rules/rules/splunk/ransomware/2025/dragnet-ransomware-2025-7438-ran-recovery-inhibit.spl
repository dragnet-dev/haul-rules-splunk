| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7438 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: 391e1248-30fe-5334-b60d-14544a03a5d9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
