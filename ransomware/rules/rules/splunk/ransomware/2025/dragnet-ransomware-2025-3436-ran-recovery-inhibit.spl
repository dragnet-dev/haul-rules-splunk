| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3436 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: c7346965-84ab-558a-9824-47537810d843"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
