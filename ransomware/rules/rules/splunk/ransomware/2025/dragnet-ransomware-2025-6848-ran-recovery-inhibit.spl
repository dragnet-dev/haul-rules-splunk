| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6848 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: b83ded4b-187f-5826-942c-ea8a5cf6f98b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
