| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7847 — Recovery Inhibition (spacebears)"
| comment "Status: experimental | Level: high | ID: 2e4fe16f-5133-5053-8eab-2d52c4370e38"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
