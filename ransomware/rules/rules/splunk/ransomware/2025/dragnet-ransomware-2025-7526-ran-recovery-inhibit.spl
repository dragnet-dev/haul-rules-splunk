| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7526 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: ed31f594-6e90-5fc4-8be8-eb03d5b3f465"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
