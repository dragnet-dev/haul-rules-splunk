| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6399 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: 1cbca46b-74a9-5baf-97d8-020a06d046d6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
