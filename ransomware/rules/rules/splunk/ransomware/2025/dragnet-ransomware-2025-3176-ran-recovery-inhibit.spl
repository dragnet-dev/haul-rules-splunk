| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3176 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 03653f2d-dfdb-530a-bf46-c86811d42a1e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
