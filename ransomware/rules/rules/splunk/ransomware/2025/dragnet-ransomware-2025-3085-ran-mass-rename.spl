| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3085 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: c2632de3-c488-540d-b63f-d0cef53e780f"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
