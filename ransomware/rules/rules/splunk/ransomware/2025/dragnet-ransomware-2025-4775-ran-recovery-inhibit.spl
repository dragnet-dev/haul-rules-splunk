| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4775 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: f9d1a8c5-66cc-5b72-bb7f-75d7dbe74f9a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
