| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5740 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 90490b45-2b50-5fd5-9320-8b3f7c5725bd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
