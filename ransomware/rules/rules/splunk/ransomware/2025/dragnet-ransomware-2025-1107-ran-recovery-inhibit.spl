| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1107 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 288c235e-1ec6-599f-8d22-52e36af5f96d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
