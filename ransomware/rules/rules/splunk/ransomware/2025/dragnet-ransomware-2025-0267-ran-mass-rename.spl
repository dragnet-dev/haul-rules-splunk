| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0267 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: ad6475fd-286e-5a7d-a48e-5fcfeebd16fc"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
