| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3731 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 6482511d-c15a-5f2a-92d4-151f38c13c2c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
