| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5899 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 6d125f23-2c35-51de-8283-f77859959cba"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
