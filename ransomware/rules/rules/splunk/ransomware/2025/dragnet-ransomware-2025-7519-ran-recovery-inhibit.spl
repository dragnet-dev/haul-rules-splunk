| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7519 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: bd90ec8f-f9c4-55ed-ae88-488517d6f96c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
