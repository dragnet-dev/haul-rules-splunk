| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3095 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: e75676bd-05e4-5b04-a688-18d2b372aa13"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
