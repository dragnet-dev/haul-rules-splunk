| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7672 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 297bc4ea-74ac-519c-b464-b2e35ac3da95"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
