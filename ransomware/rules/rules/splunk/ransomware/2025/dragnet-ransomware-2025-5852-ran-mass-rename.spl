| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5852 — Mass File Rename (gunra)"
| comment "Status: experimental | Level: high | ID: ce54ba68-30c5-5fa0-a56a-56a5bbc6791b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
