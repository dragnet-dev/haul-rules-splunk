| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6525 — Recovery Inhibition (killsec)"
| comment "Status: experimental | Level: high | ID: 6f21f4e7-f7b9-5008-b7f3-b3653a22ded3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
