| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2825 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 5126757e-eaa6-5e9a-8e09-b387f8dd76a1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
