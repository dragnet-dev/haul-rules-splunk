| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3856 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 7f1cdeba-b183-5052-aaa5-7b46e40eb53c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
