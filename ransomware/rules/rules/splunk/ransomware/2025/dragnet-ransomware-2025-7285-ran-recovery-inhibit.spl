| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7285 — Recovery Inhibition (spacebears)"
| comment "Status: experimental | Level: high | ID: be3d955a-c36a-58a4-ac9a-4f1cba7a6e01"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
