| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3228 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: a57ff7d5-f3f9-5648-b0b6-8e2f71d03f44"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
