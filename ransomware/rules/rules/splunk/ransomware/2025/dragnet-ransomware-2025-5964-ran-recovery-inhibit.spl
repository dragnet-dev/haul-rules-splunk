| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5964 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: c0872c39-f19e-5e22-990e-01c246a3ecc1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
