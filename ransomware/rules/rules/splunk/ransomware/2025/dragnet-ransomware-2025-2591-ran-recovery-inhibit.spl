| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2591 — Recovery Inhibition (ransomhouse)"
| comment "Status: experimental | Level: high | ID: add759d1-5280-56b3-a378-c13a4ca88398"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
