| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0308 — Recovery Inhibition (fog)"
| comment "Status: experimental | Level: high | ID: 4d47b616-e6d2-56e1-a96d-5eb19f1c7bdf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
