| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3749 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 83a914df-b79e-59ed-a9c4-6287720f0bca"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
