| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2887 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: c28ebb89-27f7-5a9f-aff9-c98482eef46d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
