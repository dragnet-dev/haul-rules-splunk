| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1548 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 51dd3013-02b9-5c57-a988-efa8d4560356"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
