| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5143 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: b430d6cd-8e22-5dd7-898f-53f76556a014"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
