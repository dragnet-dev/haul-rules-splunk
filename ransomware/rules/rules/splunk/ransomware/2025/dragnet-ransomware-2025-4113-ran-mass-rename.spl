| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4113 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: a98ca43f-3865-5243-b543-9e24800922d0"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
