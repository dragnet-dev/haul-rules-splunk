| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6309 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: 4d76b6f0-8f6e-54b1-ad30-8d300cfbce9b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
