| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4759 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: ac86f2fc-fea3-5346-9a4f-2518a52484f4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
