| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5569 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 135267c8-26c8-54b5-90fe-d95d80e4cb25"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
