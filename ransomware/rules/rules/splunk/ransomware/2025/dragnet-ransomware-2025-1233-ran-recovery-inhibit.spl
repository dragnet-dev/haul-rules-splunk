| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1233 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 6a9fbb66-72e6-54f5-87ec-4145258d1c50"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
