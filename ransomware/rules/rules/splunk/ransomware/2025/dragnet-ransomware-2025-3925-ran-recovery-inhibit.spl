| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3925 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: c80b01c3-ff4a-5909-b357-35f920f1f0ed"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
