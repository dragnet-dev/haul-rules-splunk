| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6828 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 6f674dac-1e83-5bfa-bc7f-d53252e9bd6d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
