| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4757 — Recovery Inhibition (interlock)"
| comment "Status: experimental | Level: high | ID: 75d6ac14-d16e-5d35-b8d7-849281b3ed0a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
