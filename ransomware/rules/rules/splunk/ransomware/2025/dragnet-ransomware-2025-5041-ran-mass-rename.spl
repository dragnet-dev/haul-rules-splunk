| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5041 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 0ab4e2e2-6716-5353-aa01-823b8c90bbfe"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
