| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6334 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 5c063e88-ead4-5d24-a4d6-f1d26e8133d1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
