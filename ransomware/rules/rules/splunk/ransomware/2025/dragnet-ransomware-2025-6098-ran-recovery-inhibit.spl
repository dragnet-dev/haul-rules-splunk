| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6098 — Recovery Inhibition (direwolf)"
| comment "Status: experimental | Level: high | ID: 5cd35b27-a846-5517-8d29-4006e7241e87"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
