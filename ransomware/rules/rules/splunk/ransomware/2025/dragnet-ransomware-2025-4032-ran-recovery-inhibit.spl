| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4032 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 448351eb-c323-5bae-94e7-77e0bb85159b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
