| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0436 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 376c86e6-d147-5054-b811-c3438bba5d4e"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
