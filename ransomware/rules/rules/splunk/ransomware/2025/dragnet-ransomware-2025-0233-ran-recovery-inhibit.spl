| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0233 — Recovery Inhibition (sinobi)"
| comment "Status: experimental | Level: high | ID: c14f993c-62a9-500a-8e02-6f5e59b6a1df"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
