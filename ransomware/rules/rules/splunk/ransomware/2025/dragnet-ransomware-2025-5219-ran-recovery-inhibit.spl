| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5219 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 4aee7053-91af-5108-8ae0-8de65883b5ee"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
