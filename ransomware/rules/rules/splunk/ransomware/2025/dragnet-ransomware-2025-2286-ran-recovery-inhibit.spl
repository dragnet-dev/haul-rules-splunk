| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2286 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 943e199f-ab10-5b59-b428-58cc51891b10"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
