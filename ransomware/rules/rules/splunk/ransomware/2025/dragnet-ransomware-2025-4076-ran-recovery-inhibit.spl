| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4076 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 9ac7644a-3532-58d8-a74a-5cae08655f79"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
