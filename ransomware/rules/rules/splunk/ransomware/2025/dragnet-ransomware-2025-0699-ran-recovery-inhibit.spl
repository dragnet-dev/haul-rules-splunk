| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0699 — Recovery Inhibition (devman)"
| comment "Status: experimental | Level: high | ID: 562f0ad9-197d-5cf6-8908-63033acacd0d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
