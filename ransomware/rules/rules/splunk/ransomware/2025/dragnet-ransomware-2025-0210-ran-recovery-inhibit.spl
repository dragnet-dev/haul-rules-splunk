| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0210 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: e46d13d7-6b05-51d2-b2fe-79d6435e9604"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
