| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1749 — Recovery Inhibition (arcusmedia)"
| comment "Status: experimental | Level: high | ID: f3d245d2-f97f-505b-9e0e-63d9747347ba"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
