| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1565 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: f910707a-49b2-58e9-8175-425db1f9586d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
