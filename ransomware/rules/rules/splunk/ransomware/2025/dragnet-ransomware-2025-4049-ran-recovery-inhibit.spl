| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4049 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 9273f23e-cb07-5974-8be6-df32e376d154"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
