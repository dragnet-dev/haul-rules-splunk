| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6004 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 05db6be3-c4ec-5143-9405-2c5a596be829"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
