| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6139 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: c0c087d5-f2dd-52fd-86e8-ccd40cb6024a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
