| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6275 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: 426bded8-a0f5-5562-86a1-4d6fe28ff0d1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
