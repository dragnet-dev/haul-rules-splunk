| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1208 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: ab79c691-2c22-51b1-81a1-095f0f645734"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
