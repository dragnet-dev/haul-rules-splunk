| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0867 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: 6bf9af48-fa58-55ff-8cda-55c80786df0b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
