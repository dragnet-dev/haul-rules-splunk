| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0618 — Recovery Inhibition (handala)"
| comment "Status: experimental | Level: high | ID: e7a306d3-90ec-5e96-afe6-c68bcd7a6490"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
