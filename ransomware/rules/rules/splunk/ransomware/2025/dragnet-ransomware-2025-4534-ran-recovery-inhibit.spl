| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4534 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: 97f05a7c-e236-5284-b17f-16510f3bd2c1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
