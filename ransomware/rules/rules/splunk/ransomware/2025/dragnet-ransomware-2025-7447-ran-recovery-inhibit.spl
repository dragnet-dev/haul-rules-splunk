| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7447 — Recovery Inhibition (funksec)"
| comment "Status: experimental | Level: high | ID: 1579f7a7-debc-53cc-b5e6-c662de659543"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
