| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2006 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: d4206951-586e-52e7-b06b-1793c871c35a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
