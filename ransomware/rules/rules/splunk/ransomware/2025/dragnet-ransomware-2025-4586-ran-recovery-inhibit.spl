| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4586 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 53b6d5a5-29f9-5969-a6ab-a13d666fd1f4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
