| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1154 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: c1f555b1-4d76-57ec-a8e9-671f8c95429a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
