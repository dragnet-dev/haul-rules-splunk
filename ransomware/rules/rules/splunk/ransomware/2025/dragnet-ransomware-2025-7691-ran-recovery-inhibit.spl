| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7691 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 92d53b28-d61d-5475-91aa-15497850e58f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
