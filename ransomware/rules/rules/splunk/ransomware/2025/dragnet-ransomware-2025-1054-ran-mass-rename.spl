| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1054 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: bcbf35b2-9d1d-5fd1-9839-cbbaa7011045"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
