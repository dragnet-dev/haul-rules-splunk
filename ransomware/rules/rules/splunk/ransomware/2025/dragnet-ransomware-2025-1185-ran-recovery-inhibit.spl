| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1185 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: fe16a074-6039-5de9-985d-8e24a3b7bca7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
