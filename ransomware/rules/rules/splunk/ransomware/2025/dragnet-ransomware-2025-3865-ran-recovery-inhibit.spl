| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3865 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 583a0df1-ebc7-5449-86f3-1d429b40c632"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
