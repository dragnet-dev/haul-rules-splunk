| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5915 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 9f4d7601-2122-5620-8dae-61b6a461ebde"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
