| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6202 — Recovery Inhibition (ransomhouse)"
| comment "Status: experimental | Level: high | ID: d6fc6522-311b-54e2-bda5-07d91247dc36"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
