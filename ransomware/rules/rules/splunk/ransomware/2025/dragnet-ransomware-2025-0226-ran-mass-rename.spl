| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0226 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 30c30baa-7380-5849-acf7-34f1c5867056"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
