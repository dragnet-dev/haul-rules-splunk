| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0253 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 5ef08060-cbad-5c84-8c63-b67ce8f5599a"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
