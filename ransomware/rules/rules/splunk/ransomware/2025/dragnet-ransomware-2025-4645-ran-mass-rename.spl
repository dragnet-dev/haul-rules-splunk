| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4645 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: c0088b19-765c-5042-a5d1-79bfdd59124c"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
