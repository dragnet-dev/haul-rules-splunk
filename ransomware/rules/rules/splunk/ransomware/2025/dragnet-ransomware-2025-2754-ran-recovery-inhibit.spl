| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2754 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: d74aef79-1ae2-5463-a34e-f0d4d8170e48"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
