| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3364 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 55f38279-a38a-5d14-a883-b3af39503611"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
