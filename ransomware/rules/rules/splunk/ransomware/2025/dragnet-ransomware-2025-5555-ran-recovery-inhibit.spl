| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5555 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: d98a92fa-b933-5119-8666-61e030393aa7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
