| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1247 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 5fdf3cdc-436c-52b9-9c0c-46a4dec59017"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
