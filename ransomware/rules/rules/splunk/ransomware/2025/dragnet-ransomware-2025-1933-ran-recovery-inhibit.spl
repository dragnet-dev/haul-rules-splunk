| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1933 — Recovery Inhibition (IMNCrew)"
| comment "Status: experimental | Level: high | ID: d6b9950a-e542-57ba-a262-a6afac444853"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
