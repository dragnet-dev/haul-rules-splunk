| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2532 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 540bfad6-e815-54b8-976e-94916d69ea37"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
