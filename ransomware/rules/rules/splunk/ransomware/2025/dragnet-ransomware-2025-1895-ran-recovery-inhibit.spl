| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1895 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 634d0497-2722-5324-925a-60fb9f3bdbcb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
