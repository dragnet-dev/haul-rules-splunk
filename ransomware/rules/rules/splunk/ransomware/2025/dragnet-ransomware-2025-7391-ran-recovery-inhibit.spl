| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7391 — Recovery Inhibition (direwolf)"
| comment "Status: experimental | Level: high | ID: d1ecb666-619f-5365-acb6-9f5612fa1964"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
