| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7613 — Recovery Inhibition (everest)"
| comment "Status: experimental | Level: high | ID: c1da47f2-cf68-5de0-a1ba-9d2ac5ea7cc1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
