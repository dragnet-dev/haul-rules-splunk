| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4047 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 9e5341bc-bda9-56a2-b6b8-10ff45b8de32"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
