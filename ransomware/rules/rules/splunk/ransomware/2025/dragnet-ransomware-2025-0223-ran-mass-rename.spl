| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0223 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: b9ca4f97-097c-519f-af6b-178c154a46f2"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
