| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1044 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: fe7bd806-c8d2-5860-af0b-6286b82adadf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
