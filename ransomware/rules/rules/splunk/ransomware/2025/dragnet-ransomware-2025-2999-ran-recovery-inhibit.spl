| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2999 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: c6caab43-a831-52f0-b235-e17628292b7b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
