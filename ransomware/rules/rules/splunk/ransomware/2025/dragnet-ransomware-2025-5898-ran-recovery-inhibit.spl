| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5898 — Recovery Inhibition (shinyhunters)"
| comment "Status: experimental | Level: high | ID: a5c9e1de-6c5f-5c24-a900-28a542d3835e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
