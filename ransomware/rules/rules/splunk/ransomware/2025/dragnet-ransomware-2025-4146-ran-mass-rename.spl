| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4146 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 260a9711-fe50-5f7b-8e02-8e126d7b2d02"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
