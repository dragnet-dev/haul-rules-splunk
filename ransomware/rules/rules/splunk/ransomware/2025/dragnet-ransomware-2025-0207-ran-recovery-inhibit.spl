| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0207 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: f7af4856-62a5-5406-b49a-92f7448fa45e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
