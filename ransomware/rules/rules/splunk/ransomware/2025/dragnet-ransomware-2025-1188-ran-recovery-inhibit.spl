| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1188 — Recovery Inhibition (lynx)"
| comment "Status: experimental | Level: high | ID: 8da3835a-5b3f-5fa9-b2c7-e848a5339b70"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
