| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2791 — Recovery Inhibition (BrainCipher)"
| comment "Status: experimental | Level: high | ID: 20ccc42a-7651-5ed7-9bab-312d0583bbb9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
