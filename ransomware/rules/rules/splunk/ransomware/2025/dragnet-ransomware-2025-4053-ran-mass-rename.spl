| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4053 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: cec09fd0-cecd-5a6e-bd58-7a42d1020593"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
