| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6564 — Recovery Inhibition (devman)"
| comment "Status: experimental | Level: high | ID: 6d41b41a-ef4d-5a3e-af5e-3c8609ab2fb9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
