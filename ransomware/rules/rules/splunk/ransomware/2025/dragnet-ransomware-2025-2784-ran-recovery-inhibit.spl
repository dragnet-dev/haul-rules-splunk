| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2784 — Recovery Inhibition (blackshrantac)"
| comment "Status: experimental | Level: high | ID: 60c43fe5-fc3e-5865-a1fe-40560f50523e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
