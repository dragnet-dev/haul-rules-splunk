| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3314 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: a587e022-0584-5588-901d-8b0f47b52d1f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
