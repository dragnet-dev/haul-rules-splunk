| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5051 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 757cfd77-259a-556b-afa1-cfa4fef0438d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
