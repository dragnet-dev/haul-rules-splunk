| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3550 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: b356308b-fd94-594b-b5cd-39b134d2ad0b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
