| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5285 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 1990de9b-10ee-5090-aab8-9b4e841629da"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
