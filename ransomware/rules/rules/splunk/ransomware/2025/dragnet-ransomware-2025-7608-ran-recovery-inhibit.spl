| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7608 — Recovery Inhibition (flocker)"
| comment "Status: experimental | Level: high | ID: 78c4cd98-8b42-5741-a91b-870f741c4eec"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
