| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7708 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: f794d8b3-5f49-511c-b215-a242dcc0aa35"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
