| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2186 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: dc67f98c-312d-58aa-a0d1-dec72e6000c2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
