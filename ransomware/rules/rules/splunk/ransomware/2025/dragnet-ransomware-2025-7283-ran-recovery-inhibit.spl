| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7283 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: 02b9050d-2628-550f-87bc-593b8b7a24b5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
