| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6930 — Recovery Inhibition (kraken)"
| comment "Status: experimental | Level: high | ID: d661b83c-ddb9-5994-a600-ff145e8f1362"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
