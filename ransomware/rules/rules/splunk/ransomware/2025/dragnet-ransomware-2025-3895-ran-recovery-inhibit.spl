| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3895 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 50d65e2f-93e9-58fe-b846-4baddb459b13"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
