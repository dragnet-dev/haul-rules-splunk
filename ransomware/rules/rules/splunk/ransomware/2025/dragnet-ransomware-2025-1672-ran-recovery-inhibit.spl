| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1672 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: dde505a4-597c-55cc-90b2-a9244e19f789"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
