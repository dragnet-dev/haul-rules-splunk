| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5085 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: 7fe7cad5-3cfc-559c-81e5-067c38137b6d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
