| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6965 — Recovery Inhibition (ransomhub)"
| comment "Status: experimental | Level: high | ID: 44a76d27-3b2d-53c1-94da-99a5dadc80d8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
