| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7898 — Recovery Inhibition (interlock)"
| comment "Status: experimental | Level: high | ID: acf34bbc-90e8-538e-8734-09d1deae9d42"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
