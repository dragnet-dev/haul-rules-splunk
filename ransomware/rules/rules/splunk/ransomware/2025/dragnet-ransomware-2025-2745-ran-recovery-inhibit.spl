| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2745 — Recovery Inhibition (alphalocker)"
| comment "Status: experimental | Level: high | ID: 2610b545-1b0e-5ce1-99f8-c75337c175fe"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
