| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4631 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: bcc66f65-5b69-50d9-a17c-01fe559c2c2b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
