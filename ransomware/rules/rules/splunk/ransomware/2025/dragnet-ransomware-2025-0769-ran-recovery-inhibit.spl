| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0769 — Recovery Inhibition (chaos)"
| comment "Status: experimental | Level: high | ID: 9e8adfd8-bbbb-52a1-99b2-ee768b7a1ec7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
