| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7728 — Recovery Inhibition (spacebears)"
| comment "Status: experimental | Level: high | ID: d61d79e7-c5b3-5c52-b4c8-33e857a546a2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
