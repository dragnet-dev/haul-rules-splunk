| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4312 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 0d9a2dc0-26a8-5b67-b5c5-f9ee3ae78aea"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
