| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0765 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 886306c5-31c8-560a-8c5b-416cacd5f61b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
