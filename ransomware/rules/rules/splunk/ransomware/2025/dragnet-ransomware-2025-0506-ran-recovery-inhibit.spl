| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0506 — Recovery Inhibition (nova)"
| comment "Status: experimental | Level: high | ID: b384e0fc-903c-54cb-ba0a-b656d0396a13"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
