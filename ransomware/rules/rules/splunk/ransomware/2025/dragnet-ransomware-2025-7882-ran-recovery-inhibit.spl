| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7882 — Recovery Inhibition (interlock)"
| comment "Status: experimental | Level: high | ID: 256f42d8-c4b8-5c2c-883a-f249b9858e38"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
