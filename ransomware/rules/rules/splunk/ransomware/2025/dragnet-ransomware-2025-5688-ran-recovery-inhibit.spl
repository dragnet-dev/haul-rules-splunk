| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5688 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: e611ab48-8c4a-5d88-9f76-f2c80e3fb2b1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
