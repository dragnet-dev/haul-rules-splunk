| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1039 — Recovery Inhibition (spacebears)"
| comment "Status: experimental | Level: high | ID: 4046dc5b-7e24-56e7-83fb-18469b8c2bd0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
