| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5455 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 8b32a513-9c9f-552d-88b7-06bd7220be71"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
