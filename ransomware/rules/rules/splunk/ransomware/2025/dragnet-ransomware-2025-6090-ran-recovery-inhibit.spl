| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6090 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 71dec3ce-e154-5e59-b9f2-f33b0197ce69"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
