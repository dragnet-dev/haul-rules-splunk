| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4602 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 4ccb2235-2a30-5c82-b801-57f37604fb10"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
