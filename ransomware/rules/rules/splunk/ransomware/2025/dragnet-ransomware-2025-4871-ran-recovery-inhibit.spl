| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4871 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 302eeac9-c7aa-53f6-ac72-30f514a88a3b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
