| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6444 — Recovery Inhibition (interlock)"
| comment "Status: experimental | Level: high | ID: bded8703-7d87-5622-98f5-41c9ea951eb6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
