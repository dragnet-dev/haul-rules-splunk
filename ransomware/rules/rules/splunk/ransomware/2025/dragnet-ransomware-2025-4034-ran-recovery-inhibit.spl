| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4034 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 35289b15-7b3e-50b5-ac72-45ca76405bd4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
