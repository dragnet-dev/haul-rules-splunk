| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6408 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: e26a4efd-0b50-54f4-89f7-be183b50ccd1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
