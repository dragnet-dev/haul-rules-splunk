| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2100 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 29843e40-1396-5635-a63c-40392d25c025"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
