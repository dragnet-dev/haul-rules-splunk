| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7565 — Recovery Inhibition (nova)"
| comment "Status: experimental | Level: high | ID: cdfd3d85-2b65-5fd7-8a52-e6ad43eb220b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
