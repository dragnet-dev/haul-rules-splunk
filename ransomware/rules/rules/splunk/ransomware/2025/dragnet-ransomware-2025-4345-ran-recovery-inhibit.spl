| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4345 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: e55f8bd8-762a-54c4-aac8-3440f279ec6f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
