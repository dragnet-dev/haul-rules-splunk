| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3100 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: b56f133d-901e-5ba2-ba83-3de70bd1b64f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
