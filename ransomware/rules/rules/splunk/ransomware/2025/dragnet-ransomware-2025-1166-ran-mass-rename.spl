| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1166 — Mass File Rename (incransom)"
| comment "Status: experimental | Level: high | ID: db77c913-9642-573e-9cca-fd2b9746cba3"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
