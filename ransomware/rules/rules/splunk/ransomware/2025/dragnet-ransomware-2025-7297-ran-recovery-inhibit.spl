| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7297 — Recovery Inhibition (embargo)"
| comment "Status: experimental | Level: high | ID: 510682a9-f802-5a37-a0f7-1521363e5602"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
