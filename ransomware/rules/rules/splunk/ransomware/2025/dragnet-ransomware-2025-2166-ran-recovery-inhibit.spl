| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2166 — Recovery Inhibition (radar)"
| comment "Status: experimental | Level: high | ID: c6225ae7-52d7-5556-8ac1-31e4063e6ee0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
