| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4366 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 606c2565-4b06-5ea7-8dce-b137ef479fc4"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
