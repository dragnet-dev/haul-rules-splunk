| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2266 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: db1663aa-05b7-50b3-9d35-64240b64604a"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
