| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2918 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 17d10cf6-1061-5d70-acb0-2ff735593ca4"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
