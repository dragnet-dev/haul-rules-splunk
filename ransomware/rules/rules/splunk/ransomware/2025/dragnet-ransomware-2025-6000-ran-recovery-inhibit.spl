| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6000 — Recovery Inhibition (hunters)"
| comment "Status: experimental | Level: high | ID: f641817b-01c7-5920-94c2-108e5d241458"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
