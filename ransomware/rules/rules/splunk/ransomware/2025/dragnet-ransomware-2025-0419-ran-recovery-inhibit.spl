| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-0419 — Recovery Inhibition (medusa)"
| comment "Status: experimental | Level: high | ID: 0b0be688-af38-5945-a149-2f3cd540671d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
