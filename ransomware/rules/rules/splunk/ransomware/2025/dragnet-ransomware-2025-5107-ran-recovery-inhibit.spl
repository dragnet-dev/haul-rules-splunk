| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5107 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: fd70fa8f-6bf3-580a-864f-5b3d43993bd9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
