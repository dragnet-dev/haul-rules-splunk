| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7547 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: e489d151-3dde-5ebb-9552-b0b644485346"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
