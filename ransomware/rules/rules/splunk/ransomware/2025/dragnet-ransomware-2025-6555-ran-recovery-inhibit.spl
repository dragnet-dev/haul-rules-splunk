| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6555 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: dea421a3-3f41-54b1-8296-85f5ec8e569a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
