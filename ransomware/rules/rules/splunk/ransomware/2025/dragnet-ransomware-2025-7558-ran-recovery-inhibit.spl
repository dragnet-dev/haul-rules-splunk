| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7558 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: f414f5af-c16e-53dc-aacf-c81eb379934a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
