| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4503 — Recovery Inhibition (interlock)"
| comment "Status: experimental | Level: high | ID: 0ecd8e49-f2c1-5467-b3ac-a8f0884351d6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
