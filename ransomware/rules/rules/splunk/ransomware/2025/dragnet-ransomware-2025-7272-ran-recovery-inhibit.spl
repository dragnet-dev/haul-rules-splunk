| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7272 — Recovery Inhibition (babuk2)"
| comment "Status: experimental | Level: high | ID: 0af4c4e8-1d9c-5cf6-947a-2bf8d5f6fbb9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
