| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3805 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: a6fbd00f-638d-509f-b418-160a6de84237"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
