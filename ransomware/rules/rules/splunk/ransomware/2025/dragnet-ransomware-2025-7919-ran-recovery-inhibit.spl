| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7919 — Recovery Inhibition (J)"
| comment "Status: experimental | Level: high | ID: d0e66817-0c0f-504d-aa7f-560351402f94"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
