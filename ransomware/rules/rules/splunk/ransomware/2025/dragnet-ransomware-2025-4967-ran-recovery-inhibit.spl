| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4967 — Recovery Inhibition (worldleaks)"
| comment "Status: experimental | Level: high | ID: c79eda21-3ffe-56ea-b631-c3a5622fbb96"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
