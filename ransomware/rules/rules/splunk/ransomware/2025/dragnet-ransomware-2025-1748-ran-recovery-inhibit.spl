| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1748 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 094b98e1-9914-59a8-a3dc-b0b02339a2b3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
