| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3186 — Recovery Inhibition (sinobi)"
| comment "Status: experimental | Level: high | ID: dcbca9c6-3ad4-5251-a714-74587d61aaf9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
