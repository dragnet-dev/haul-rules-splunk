| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6304 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 35707d08-7b07-577e-a24e-fdac6d6b4974"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
