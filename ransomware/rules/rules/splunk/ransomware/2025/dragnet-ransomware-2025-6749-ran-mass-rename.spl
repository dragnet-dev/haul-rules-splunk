| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6749 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 96865146-f09f-5f89-979e-01e721b033c4"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
