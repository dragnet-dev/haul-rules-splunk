| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7591 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 7f61d24e-0355-5564-9b52-f4897b8fe76f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
