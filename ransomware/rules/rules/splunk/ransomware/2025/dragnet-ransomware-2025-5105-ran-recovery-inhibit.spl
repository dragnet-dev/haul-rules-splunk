| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5105 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: b6490e36-69cc-56f1-a6bd-b1643ee6d4a5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
