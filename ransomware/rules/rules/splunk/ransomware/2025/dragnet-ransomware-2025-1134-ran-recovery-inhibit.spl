| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1134 — Recovery Inhibition (anubis)"
| comment "Status: experimental | Level: high | ID: 18e7994f-b42d-57a4-8527-aa2fa3384c6d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
