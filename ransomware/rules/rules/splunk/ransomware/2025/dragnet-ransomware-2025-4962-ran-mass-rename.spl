| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-4962 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: b51fe5eb-b56a-55c0-8b57-1ba2eda7b929"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
