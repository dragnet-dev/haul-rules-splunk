| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5594 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: ce8ffe4c-5294-5628-aa08-b31de10bcbe1"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
