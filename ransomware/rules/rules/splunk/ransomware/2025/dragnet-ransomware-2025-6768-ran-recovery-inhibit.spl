| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-6768 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: f9225e73-2efe-5740-8de7-a35eccdf05f8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
