| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-7196 — Recovery Inhibition (desolator)"
| comment "Status: experimental | Level: high | ID: 59285484-36d9-528c-b63e-91cd8caf8979"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
