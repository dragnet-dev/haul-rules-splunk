| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3889 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: bded634c-d35d-5437-a854-e6f20258383d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
