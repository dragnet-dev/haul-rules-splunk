| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1104 — Mass File Rename (killsec)"
| comment "Status: experimental | Level: high | ID: 27cc3732-b410-52ad-a439-d9a6f50611c5"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
