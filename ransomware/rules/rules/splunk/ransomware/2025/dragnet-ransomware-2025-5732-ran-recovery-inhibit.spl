| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5732 — Recovery Inhibition (safepay)"
| comment "Status: experimental | Level: high | ID: 996b631e-49ba-5c03-b3de-4cc5de5dd963"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
