| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2919 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: ac3c048e-5b0c-58ed-a96d-fc6d41bf5ecc"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
