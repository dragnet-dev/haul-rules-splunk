| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5700 — Recovery Inhibition (devman)"
| comment "Status: experimental | Level: high | ID: 026385b7-f2dc-5b82-9206-90996561270a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
