| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2988 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 1064134e-3ea0-5fd7-8519-1d71227f73c4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
