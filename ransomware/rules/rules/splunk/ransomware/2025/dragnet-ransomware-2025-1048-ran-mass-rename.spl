| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1048 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 28d0091b-d071-53e8-9659-f31047b088d5"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
