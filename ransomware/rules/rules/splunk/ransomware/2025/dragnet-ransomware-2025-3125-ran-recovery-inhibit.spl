| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3125 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: e57ea16b-e9cb-5927-9f2e-6b36d2caadb6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
