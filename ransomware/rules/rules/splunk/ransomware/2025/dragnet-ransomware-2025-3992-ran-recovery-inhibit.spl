| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3992 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: b105ec96-0efd-5af3-ba97-7c19f2ab5714"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
