| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2143 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: 77d90964-1195-5584-b90e-049fae9fafc0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
