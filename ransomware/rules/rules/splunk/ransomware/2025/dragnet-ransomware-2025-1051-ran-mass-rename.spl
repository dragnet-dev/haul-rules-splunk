| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-1051 — Mass File Rename (lynx)"
| comment "Status: experimental | Level: high | ID: 5f0469a3-8461-565d-91ff-8ab22e287634"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
