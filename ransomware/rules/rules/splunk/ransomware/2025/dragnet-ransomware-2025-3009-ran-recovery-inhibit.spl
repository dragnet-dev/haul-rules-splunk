| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-3009 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 0335b282-9edb-586a-830d-e78560fab3b2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
