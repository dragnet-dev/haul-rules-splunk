| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-5731 — Recovery Inhibition (dragonforce)"
| comment "Status: experimental | Level: high | ID: 0889e075-353b-599e-bb08-031b371c8d0a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
