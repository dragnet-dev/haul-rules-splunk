| comment "Dragnet [Ransomware]: dragnet-ransomware-2025-2773 — Recovery Inhibition (cephalus)"
| comment "Status: experimental | Level: high | ID: 0c6fe81b-67cd-5943-a17c-aef78ef627b4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
