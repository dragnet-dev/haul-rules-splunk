| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2265 — Recovery Inhibition (qilin)"
| comment "Status: stable | Level: high | ID: 202e8671-2181-52c7-ac75-444401ec7978"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
