| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-3016 — Recovery Inhibition (qilin)"
| comment "Status: stable | Level: high | ID: 67e7d314-9945-58ad-ac5b-664b72818f9d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
