| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-0957 — Recovery Inhibition (everest)"
| comment "Status: stable | Level: high | ID: 600a86c1-8c2a-5467-ac24-edc22d50ba61"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
