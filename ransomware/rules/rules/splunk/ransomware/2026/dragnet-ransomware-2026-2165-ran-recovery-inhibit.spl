| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2165 — Recovery Inhibition (everest)"
| comment "Status: stable | Level: high | ID: 905c629f-0ad4-53d1-a065-c913c519a78d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
