| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2702 — Recovery Inhibition (dragonforce)"
| comment "Status: stable | Level: high | ID: e62b6360-d54a-560b-a0da-99efc9d06e15"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
