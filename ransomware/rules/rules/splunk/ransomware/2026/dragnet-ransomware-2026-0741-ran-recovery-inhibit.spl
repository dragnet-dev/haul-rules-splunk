| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-0741 — Recovery Inhibition (ALP-001)"
| comment "Status: stable | Level: high | ID: 6d0017aa-8273-5b30-8462-f96957778643"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
