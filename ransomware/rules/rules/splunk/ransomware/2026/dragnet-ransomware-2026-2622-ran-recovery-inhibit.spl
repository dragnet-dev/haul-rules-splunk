| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2622 — Recovery Inhibition (qilin)"
| comment "Status: stable | Level: high | ID: de25ac40-1c67-570a-a45e-a868f2692d5b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
