| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-2069 — Recovery Inhibition (lynx)"
| comment "Status: stable | Level: high | ID: c1f5d166-8dfc-56b8-8d01-f81164fcc137"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
