| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-3223 — Recovery Inhibition (dragonforce)"
| comment "Status: stable | Level: high | ID: 86b5062b-861c-5b55-860a-bb498ad0a96b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
