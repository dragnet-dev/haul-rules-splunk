| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-3529 — Recovery Inhibition (krybit)"
| comment "Status: stable | Level: high | ID: 46542c44-4ddd-5148-8bf7-02e1c176b22e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
