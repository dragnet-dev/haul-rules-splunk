| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-1337 — Recovery Inhibition (qilin)"
| comment "Status: stable | Level: high | ID: 6a616e61-75b3-5a17-a510-68d3ca56e6ba"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
