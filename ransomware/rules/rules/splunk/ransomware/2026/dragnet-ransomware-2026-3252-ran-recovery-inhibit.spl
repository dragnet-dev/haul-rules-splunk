| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-3252 — Recovery Inhibition (qilin)"
| comment "Status: stable | Level: high | ID: 90807dd6-2cea-553c-a80f-2b3041d08333"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
