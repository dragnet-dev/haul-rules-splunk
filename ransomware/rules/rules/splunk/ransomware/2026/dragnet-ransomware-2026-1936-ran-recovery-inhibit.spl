| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-1936 — Recovery Inhibition (qilin)"
| comment "Status: stable | Level: high | ID: bee2d72e-ac66-5d10-b08d-bd5e7872cf33"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
