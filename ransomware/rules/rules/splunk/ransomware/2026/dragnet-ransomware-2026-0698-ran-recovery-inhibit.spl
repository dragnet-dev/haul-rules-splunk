| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-0698 — Recovery Inhibition (dragonforce)"
| comment "Status: stable | Level: high | ID: 8642e8d9-5b4b-5862-9a26-1e2baebdfd6d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
