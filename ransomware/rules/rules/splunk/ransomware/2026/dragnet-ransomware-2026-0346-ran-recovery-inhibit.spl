| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-0346 — Recovery Inhibition (dragonforce)"
| comment "Status: stable | Level: high | ID: 1bbd6657-adc8-5a9e-903f-6c2e2aec5e64"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
