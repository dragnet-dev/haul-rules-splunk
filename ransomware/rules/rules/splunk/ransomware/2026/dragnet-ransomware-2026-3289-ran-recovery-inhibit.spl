| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-3289 — Recovery Inhibition (krybit)"
| comment "Status: stable | Level: high | ID: ad91e7d6-7e33-536f-97e6-6219348e465b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
