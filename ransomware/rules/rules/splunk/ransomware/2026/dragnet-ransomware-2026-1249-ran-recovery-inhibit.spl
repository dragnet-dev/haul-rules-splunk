| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-1249 — Recovery Inhibition (handala)"
| comment "Status: stable | Level: high | ID: e706aa4c-0413-5d2b-9912-c1c3d8310dd4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
