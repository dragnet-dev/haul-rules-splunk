| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-0251 — Recovery Inhibition (qilin)"
| comment "Status: test | Level: high | ID: 19835af6-61fc-583a-a233-8075130a2e6f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
