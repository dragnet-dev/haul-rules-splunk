| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-3347 — Recovery Inhibition (qilin)"
| comment "Status: stable | Level: high | ID: 5213684a-b4ac-5121-a633-0bffdbff4b4a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
