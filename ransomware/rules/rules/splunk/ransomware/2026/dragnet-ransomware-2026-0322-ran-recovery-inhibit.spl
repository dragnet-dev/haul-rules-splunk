| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-0322 — Recovery Inhibition (dragonforce)"
| comment "Status: stable | Level: high | ID: cb331ccd-f665-5e8b-863c-cb37a08df94d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
