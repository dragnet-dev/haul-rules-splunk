| comment "Dragnet [Ransomware]: dragnet-ransomware-2026-1730 — Recovery Inhibition (qilin)"
| comment "Status: stable | Level: high | ID: d9a8a212-09db-53bd-9ecd-966bd607c7a3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
