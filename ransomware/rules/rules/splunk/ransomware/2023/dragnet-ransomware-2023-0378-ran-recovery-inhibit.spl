| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0378 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 67e1e654-b6fe-565e-ae47-cb511819f76b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
