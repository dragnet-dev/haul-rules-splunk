| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4292 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: f507e74e-c518-5879-90df-f8e0c9651180"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
