| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1761 — Recovery Inhibition (nitrogen)"
| comment "Status: experimental | Level: high | ID: 48b90b25-a022-59f0-9cfa-f4852dfa523d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
