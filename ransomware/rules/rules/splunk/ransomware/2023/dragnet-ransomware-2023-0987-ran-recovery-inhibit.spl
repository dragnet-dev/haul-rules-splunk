| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0987 — Recovery Inhibition (trigona)"
| comment "Status: experimental | Level: high | ID: 8afa70f2-acc7-5bf6-abea-e1ae5ed0fc7c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
