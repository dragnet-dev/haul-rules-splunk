| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1288 — Recovery Inhibition (noescape)"
| comment "Status: experimental | Level: high | ID: 7d2c5599-233c-5820-a9fe-6a7fb6c0a73c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
