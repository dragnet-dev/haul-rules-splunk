| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2331 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: d1026e21-b070-5d05-ae92-23eed8931d9d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
