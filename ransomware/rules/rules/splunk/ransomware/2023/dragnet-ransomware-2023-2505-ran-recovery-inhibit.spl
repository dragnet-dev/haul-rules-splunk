| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2505 — Recovery Inhibition (ragnarlocker)"
| comment "Status: experimental | Level: high | ID: 3344b8ae-53ad-5047-8501-a78fcd4d637f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
