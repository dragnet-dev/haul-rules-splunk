| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5299 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: a68b67eb-4617-52df-a1f5-ff71b182555b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
