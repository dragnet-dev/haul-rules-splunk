| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0842 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: ec45f137-a3b6-5d94-a0ba-32be24a2333b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
