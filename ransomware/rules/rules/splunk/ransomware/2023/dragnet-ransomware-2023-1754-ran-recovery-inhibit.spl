| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1754 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 18262377-18da-51f1-bffa-011656d33129"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
