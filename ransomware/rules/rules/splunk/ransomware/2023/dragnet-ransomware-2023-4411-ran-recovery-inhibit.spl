| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4411 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: aea51faf-cc54-5b2c-8cf7-bf623d3e980f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
