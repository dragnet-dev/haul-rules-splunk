| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1563 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 6a4f51a6-8372-5eec-a5d5-9088e477ab28"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
