| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1478 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: ace12b21-88f5-5ac1-90ff-4bc8a7439dac"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
