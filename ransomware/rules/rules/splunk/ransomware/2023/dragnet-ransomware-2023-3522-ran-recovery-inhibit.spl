| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3522 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: c509f818-e170-587a-ade3-d33a5e1593d2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
