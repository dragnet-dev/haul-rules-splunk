| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4649 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: a470803e-c82b-5647-9371-791218df5432"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
