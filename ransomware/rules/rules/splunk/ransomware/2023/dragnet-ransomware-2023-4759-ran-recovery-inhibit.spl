| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4759 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 60f6fc17-3945-5b39-bd90-f96959b2baa1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
