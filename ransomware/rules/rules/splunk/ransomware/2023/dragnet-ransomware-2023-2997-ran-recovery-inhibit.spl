| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2997 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 1f8100ce-a31c-541e-8a1c-7296caed44d1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
