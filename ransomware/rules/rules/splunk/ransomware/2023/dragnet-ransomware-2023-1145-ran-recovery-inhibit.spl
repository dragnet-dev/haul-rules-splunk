| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1145 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 5d5b2c7b-e82c-55ce-a912-32990e79f1ef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
