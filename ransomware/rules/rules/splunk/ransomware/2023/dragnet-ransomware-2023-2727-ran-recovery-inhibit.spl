| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2727 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 5b719353-a785-591f-a2f8-4897729b62eb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
