| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2789 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: f8c76662-54db-5e63-b25f-56b02bb1a647"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
