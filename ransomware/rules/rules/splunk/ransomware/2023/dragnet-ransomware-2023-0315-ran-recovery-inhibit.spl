| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0315 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: c09dc017-cfed-5f22-b8fa-b73e2b9c106b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
