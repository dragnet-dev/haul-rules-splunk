| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2457 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 36cf4ec6-6e55-5f88-84e6-28020eef9bac"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
