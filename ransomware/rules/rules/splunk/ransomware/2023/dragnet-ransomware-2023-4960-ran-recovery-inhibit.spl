| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4960 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: be75cb04-689d-5f11-8a77-b42cbdb86499"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
