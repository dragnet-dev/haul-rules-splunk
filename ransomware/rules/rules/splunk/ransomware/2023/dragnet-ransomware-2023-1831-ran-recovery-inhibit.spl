| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1831 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: a4c483d5-49b7-57d9-a034-ffbb6763dd51"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
