| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2334 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 33149049-02e1-5284-9a6b-47d38bc8b9c3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
