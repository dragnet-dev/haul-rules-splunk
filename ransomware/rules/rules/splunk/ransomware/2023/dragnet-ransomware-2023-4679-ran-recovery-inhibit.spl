| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4679 — Recovery Inhibition (karakurt)"
| comment "Status: experimental | Level: high | ID: d65c1244-29bc-5a59-93b4-8ddd2c9fe7fd"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
