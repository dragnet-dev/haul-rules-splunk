| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1102 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 9b1e5ac7-1c8a-5202-80d8-30fcdc93dcb3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
