| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3256 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: d605edcf-d3e6-5f92-b375-7d114971ed76"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
