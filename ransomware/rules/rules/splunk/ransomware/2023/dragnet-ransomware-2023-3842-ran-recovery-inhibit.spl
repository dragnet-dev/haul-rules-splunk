| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3842 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 78d7c012-7c19-52fd-ad3b-ff8ddf67a22b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
