| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0644 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 799b2c5e-fec2-5c06-a58c-ee0f96e5a43a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
