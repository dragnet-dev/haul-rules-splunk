| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3477 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: b42eb811-0867-58e8-b009-ddc488d88477"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
