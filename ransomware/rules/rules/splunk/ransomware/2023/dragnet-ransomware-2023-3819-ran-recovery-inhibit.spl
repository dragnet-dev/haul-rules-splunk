| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3819 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 856eae60-89f3-5edb-84b6-6cd9b8409842"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
