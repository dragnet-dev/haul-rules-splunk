| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3554 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: c0e6e68e-df65-534b-b4a1-766a7d22e881"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
