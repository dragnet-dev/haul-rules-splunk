| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0083 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: b549a00e-f56a-5054-ae1b-9f576eebc109"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
