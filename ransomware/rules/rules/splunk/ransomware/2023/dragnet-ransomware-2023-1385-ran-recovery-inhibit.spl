| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1385 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 09026557-65ea-5256-8dd4-6d1c254b6b20"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
