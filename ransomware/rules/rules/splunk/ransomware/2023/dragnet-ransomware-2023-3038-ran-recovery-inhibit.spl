| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3038 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 95d349a8-3ad2-5ef4-b045-62b93d85ab43"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
