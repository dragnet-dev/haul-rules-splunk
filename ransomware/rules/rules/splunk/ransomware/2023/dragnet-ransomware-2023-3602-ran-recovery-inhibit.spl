| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3602 — Recovery Inhibition (royal)"
| comment "Status: experimental | Level: high | ID: fcd69f94-eee9-5249-9013-30da0ad8cfc3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
