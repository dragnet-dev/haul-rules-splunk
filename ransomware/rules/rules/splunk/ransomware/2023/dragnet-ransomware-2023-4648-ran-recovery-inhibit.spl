| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4648 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: f0211525-7349-528f-acfb-79526566fb0c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
