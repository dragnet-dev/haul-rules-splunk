| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0860 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 3207f359-0206-539c-8c8a-fbbf74fc3aef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
