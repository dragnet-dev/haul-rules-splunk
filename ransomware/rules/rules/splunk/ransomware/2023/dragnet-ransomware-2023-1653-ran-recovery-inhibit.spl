| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1653 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 7c048c67-a805-5dc4-bbd8-6964c659f4bb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
