| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0772 — Recovery Inhibition (meow)"
| comment "Status: experimental | Level: high | ID: b86337b2-b429-5de0-bd90-562225df9daa"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
