| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5290 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 26ae3ca8-e97f-5315-8d8b-b14f1a4caa0a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
