| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2882 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 93763ced-0f73-5db3-baf3-bd1d4ce71831"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
