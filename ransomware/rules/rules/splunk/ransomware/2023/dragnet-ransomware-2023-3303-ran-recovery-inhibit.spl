| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3303 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 6a71b91a-1376-5be0-8444-77409688f603"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
