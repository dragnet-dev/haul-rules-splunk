| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4791 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 95cae279-bc8c-5038-8417-bcef794f06b2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
