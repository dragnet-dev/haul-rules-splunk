| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5036 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: b98b1c91-98b3-5af0-b9c7-723419848665"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
