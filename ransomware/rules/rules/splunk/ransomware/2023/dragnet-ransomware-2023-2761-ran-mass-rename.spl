| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2761 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 76a10ea5-4092-5343-a663-237ad1836d0f"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
