| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3165 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: a8e57433-7e8d-5d85-b6f8-2fb5ce0f852c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
