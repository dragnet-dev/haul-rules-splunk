| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0062 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: aae58b29-3bfd-59da-b0fd-0f7788f7e72c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
