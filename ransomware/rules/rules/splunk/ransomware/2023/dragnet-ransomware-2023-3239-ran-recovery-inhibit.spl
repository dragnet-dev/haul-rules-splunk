| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3239 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 890acf94-5123-5544-83cf-2d85ddfe754e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
