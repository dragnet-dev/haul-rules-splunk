| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1068 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: ed487ebe-e203-5021-9abf-e875ed0c6c99"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
