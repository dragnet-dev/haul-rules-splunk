| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4043 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 791cd2a6-4286-5bd5-ac97-825b89da6d95"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
