| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3982 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: d1a9d1e4-f993-5621-a5ab-0289b8e6efbc"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
