| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1075 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 57ad786f-6ef2-5942-8079-83f8e78f413c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
