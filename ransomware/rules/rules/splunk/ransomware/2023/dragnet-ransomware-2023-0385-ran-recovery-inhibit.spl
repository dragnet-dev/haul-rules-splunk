| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0385 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: ff5bcf57-00c8-5f34-96ae-3ee17b0ed080"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
