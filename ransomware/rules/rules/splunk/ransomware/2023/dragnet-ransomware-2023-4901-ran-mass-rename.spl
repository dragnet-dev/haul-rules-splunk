| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4901 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: ffbd9f33-a262-58ed-8ce7-8e9b139a6833"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
