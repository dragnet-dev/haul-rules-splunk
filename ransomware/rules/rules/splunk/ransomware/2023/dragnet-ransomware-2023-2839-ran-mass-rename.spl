| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2839 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 4ac0d109-1ae6-5261-8789-b97f80ef942d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
