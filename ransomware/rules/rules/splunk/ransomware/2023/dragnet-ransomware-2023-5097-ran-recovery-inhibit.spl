| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5097 — Recovery Inhibition (mallox)"
| comment "Status: experimental | Level: high | ID: 93889842-f118-5f22-af42-265f8103f218"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
