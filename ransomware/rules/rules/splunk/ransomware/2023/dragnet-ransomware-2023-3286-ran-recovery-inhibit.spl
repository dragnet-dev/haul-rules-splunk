| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3286 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 53babea3-1896-551c-a540-c22f340ee26e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
