| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0892 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 4b918a5b-3b77-591c-9822-b05fb8921098"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
