| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2881 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 84d1286b-0fe3-5fc5-8487-d44d3e2e70a7"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
