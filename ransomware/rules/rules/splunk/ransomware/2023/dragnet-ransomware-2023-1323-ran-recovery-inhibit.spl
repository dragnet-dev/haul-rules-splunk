| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1323 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 18f7b4c3-6d8a-55ce-8c5a-6753eee4e102"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
