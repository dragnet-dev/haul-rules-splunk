| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1830 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: d388cc6e-d078-55b4-8291-751bcc02f5e6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
