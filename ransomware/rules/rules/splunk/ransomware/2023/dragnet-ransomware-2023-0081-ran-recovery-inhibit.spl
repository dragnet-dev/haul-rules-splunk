| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0081 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 81c99050-a0d3-511c-9a7d-e96ea0de9614"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
