| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2140 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: f5bda034-a0ff-50ea-8c51-cb9248cf0ae3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
