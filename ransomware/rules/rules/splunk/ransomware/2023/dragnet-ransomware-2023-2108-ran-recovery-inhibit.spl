| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2108 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: cdf4f30f-4c72-54a5-a88a-0d022f4cead5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
