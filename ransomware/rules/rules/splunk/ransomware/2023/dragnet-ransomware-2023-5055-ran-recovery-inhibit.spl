| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5055 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 2da37534-a7eb-5448-98f3-43bd27ccb62e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
