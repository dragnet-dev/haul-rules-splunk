| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4621 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 4898610c-1dd7-5ba8-849b-9e2c4b7d7a56"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
