| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1133 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: f4dd4ca1-791c-5f55-8600-a331cc0bf738"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
