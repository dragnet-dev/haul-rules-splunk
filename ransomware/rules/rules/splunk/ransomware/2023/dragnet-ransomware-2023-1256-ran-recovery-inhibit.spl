| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1256 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: 977b5dd1-91dd-5a7c-9a68-edda72728c8e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
