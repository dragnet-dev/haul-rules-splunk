| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0108 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 6e5bf689-8dfc-56a3-b68b-e1c438ed816b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
