| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0296 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: 4ea3f974-6aa5-5bd4-8087-5d2067008114"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
