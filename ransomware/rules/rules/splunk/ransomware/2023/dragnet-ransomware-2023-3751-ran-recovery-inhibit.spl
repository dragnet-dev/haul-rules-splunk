| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3751 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 098f08e1-0307-56c5-8a7c-3b3c38faf610"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
