| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2982 — Recovery Inhibition (medusalocker)"
| comment "Status: experimental | Level: high | ID: d00c1e9a-6096-512c-9171-035649519e66"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
