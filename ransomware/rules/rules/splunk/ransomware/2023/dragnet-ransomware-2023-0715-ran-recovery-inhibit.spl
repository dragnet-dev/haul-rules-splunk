| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0715 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: f75b8cc8-97a3-5312-bea4-415f5ee4d886"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
