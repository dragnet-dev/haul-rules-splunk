| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5046 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 3102ca8a-59b8-5e14-b08c-9dc30b7aba6a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
