| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0992 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: ada7bf74-7654-53e5-9ed7-6add2b43f425"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
