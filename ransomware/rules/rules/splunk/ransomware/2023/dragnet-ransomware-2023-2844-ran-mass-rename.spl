| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2844 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 7ad0d904-b23a-556c-909a-f4e58a345676"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
