| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5229 — Recovery Inhibition (medusalocker)"
| comment "Status: experimental | Level: high | ID: 2bb7086d-634c-579f-a62d-4d0f265c90c3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
