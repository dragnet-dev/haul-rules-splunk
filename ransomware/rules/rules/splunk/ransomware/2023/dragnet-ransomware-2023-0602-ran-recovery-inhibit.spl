| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0602 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: d69008cb-c0d0-5e8f-b786-5727b0dbb360"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
