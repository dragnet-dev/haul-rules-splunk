| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4802 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: bb10a1de-36be-568a-a533-97d56d68ebf2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
