| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1548 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 31fa98a7-c5db-59df-be56-3b30c8bcb01f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
