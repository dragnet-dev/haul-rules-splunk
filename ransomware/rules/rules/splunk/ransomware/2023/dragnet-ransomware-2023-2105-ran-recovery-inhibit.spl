| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2105 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: c78ea97b-5023-586a-93a1-fee21b129fe2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
