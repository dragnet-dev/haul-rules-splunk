| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4332 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 08890332-aac3-5af1-9a30-ab7fc1c25544"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
