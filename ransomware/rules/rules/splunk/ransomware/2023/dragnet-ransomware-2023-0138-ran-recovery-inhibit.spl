| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0138 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: b3bafd1f-c380-5de8-adf5-bf8a2d641bab"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
