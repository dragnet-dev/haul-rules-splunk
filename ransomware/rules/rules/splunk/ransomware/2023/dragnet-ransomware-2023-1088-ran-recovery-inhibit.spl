| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1088 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 98f50195-bc96-58a0-ba5f-738531fd3dff"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
