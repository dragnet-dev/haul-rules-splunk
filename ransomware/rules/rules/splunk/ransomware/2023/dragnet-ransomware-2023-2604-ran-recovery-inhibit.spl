| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2604 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 5f1dd958-a0a7-5f57-9baa-87975ca61df3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
