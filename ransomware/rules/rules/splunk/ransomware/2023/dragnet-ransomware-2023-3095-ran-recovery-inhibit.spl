| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3095 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 88f198a6-b772-5bf1-ae9a-388515b9fa1f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
