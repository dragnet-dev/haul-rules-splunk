| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1011 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: fef35bd2-71dd-5864-b1d5-98683e39d4c0"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
