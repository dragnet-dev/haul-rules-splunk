| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2797 — Recovery Inhibition (malas)"
| comment "Status: experimental | Level: high | ID: da0cf3d2-e7a2-5b1f-9db2-9e73720f075e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
