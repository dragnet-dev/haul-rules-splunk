| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2156 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: cac36cc4-a236-5aff-b6cc-60d6c7c53492"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
