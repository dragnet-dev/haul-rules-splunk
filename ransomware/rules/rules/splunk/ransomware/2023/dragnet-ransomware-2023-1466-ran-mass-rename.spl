| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1466 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 3c89beb0-d910-5baa-a715-ed7fdda00d91"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
