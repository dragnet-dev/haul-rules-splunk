| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3863 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: c1395ab2-37b3-519c-ace7-adb728914997"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
