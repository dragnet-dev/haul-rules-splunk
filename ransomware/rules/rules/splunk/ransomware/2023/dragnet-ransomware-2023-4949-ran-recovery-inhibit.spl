| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4949 — Recovery Inhibition (trigona)"
| comment "Status: experimental | Level: high | ID: 6a0bcaf3-38f5-52ce-9df8-032ba951a1e4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
