| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5368 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: da43c970-58bc-5fad-b24b-150eb5213794"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
