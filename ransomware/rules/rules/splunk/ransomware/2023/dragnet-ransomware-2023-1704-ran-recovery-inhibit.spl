| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1704 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 2a319a78-3528-5861-95d6-4f26cae2301b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
