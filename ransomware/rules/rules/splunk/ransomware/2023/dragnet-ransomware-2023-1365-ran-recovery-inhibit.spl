| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1365 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 672193f0-68c8-5f91-b57e-fd04657ac683"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
