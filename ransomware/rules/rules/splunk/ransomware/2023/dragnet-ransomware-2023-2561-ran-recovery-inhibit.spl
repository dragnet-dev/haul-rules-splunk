| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2561 — Recovery Inhibition (noescape)"
| comment "Status: experimental | Level: high | ID: 0873fa69-602a-58b0-b413-f1d8dd6b9c69"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
