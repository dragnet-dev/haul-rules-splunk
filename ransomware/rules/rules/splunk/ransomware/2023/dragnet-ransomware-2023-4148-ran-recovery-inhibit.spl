| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4148 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: e5597769-34e4-5808-98f0-60f2f027b87e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
