| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3286 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 29feefff-8787-5c3f-a445-482d22f06f1c"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
