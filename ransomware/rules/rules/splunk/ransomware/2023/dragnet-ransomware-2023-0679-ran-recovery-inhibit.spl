| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0679 — Recovery Inhibition (nokoyawa)"
| comment "Status: experimental | Level: high | ID: 87e5c8c6-ef95-59cd-b7b9-eb646b3e7f0f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
