| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4996 — Recovery Inhibition (royal)"
| comment "Status: experimental | Level: high | ID: 9111a22f-f45c-53a6-966f-787962ff1330"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
