| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3080 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 121bc9a8-d6fb-530a-95e2-5e3b62afa4d6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
