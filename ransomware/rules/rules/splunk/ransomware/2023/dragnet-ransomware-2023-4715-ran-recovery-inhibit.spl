| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4715 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 5dde5ea5-5872-5d9c-beea-40f01e111ebb"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
