| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1576 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 59b0d286-29fd-5c4d-9ef0-06d08d235ce4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
