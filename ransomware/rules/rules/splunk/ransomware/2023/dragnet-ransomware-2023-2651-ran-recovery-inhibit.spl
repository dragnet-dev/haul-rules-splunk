| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2651 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 1fc2bf0c-2362-58ee-bfe3-273638bfb94f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
