| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5166 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: bacd3609-6512-5abe-8b21-9b02790ea146"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
