| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1528 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 00621798-16a7-5051-a35d-d7da6088c05d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
