| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3010 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 908384a4-9e78-5da9-bb1f-bf6a201a41f2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
