| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5289 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 677da95e-7436-593c-8a44-299e5a16ddc7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
