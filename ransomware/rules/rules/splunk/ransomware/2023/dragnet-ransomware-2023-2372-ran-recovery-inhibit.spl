| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2372 — Recovery Inhibition (donutleaks)"
| comment "Status: experimental | Level: high | ID: ee37e4a5-a0fe-5dad-ab9a-f129e4e9cb6a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
