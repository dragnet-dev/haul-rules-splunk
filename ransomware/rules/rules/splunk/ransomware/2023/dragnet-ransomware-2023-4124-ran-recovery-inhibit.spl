| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4124 — Recovery Inhibition (threeam)"
| comment "Status: experimental | Level: high | ID: c016662f-1190-52d1-a736-9c9705974eb4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
