| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1331 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 82084e5d-bf33-5f2d-b33b-ae1c87524e2a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
