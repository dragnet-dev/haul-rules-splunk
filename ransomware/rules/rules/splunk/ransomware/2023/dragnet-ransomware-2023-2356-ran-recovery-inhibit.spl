| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2356 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 6d0d1891-0f84-57a4-bf64-a000368d5011"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
