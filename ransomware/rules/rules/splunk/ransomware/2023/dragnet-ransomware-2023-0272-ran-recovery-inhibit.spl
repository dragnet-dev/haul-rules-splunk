| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0272 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: d55f72bb-a011-5aca-a5c2-c45e8f44155e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
