| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1851 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 5686dc2d-5f79-5d4f-ac1f-fee8bb47d603"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
