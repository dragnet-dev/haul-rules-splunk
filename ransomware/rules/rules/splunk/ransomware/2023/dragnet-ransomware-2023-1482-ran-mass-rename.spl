| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1482 — Mass File Rename (monti)"
| comment "Status: experimental | Level: high | ID: adfc1c66-610d-53f3-86f9-3feeec51b3ca"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
