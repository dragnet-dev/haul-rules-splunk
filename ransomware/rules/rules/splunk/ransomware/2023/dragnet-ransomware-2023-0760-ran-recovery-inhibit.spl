| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0760 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 1ae1d8f2-ca59-5536-8a02-4f54cde8dab2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
