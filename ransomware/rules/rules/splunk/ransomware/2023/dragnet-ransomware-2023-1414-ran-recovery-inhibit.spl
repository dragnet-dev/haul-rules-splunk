| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1414 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 7d73f2d4-c5f4-5893-bfb0-e1dd7bef3834"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
