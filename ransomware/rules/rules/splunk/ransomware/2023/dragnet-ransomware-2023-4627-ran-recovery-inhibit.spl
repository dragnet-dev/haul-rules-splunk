| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4627 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 7e04389f-0762-5e7b-bb01-d1f9d8cafb55"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
