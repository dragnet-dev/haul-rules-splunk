| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5062 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: dcecf547-2fe7-5e32-b740-d80a1f85c5df"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
