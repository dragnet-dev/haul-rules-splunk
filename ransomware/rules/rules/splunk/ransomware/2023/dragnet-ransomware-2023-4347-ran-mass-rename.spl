| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4347 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 205d095a-d393-5cdf-875b-a56207d2f37d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
