| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4866 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 6bf76b61-7b7a-5fbf-9c80-338408d713e7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
