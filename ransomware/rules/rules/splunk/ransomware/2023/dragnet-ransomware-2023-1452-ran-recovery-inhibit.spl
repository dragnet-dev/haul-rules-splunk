| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1452 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 70f97a98-e1de-5ee9-9c90-41807390f394"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
