| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3330 — Recovery Inhibition (incransom)"
| comment "Status: experimental | Level: high | ID: 4ade9589-e4ca-5dce-850a-23c0a3f1fa8d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
