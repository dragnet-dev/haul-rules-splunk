| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0919 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: b9996ca2-ea10-548c-8bcb-c82cc5043d6b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
