| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0455 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 382dd7e7-8e7b-5749-acb5-e86d803e841d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
