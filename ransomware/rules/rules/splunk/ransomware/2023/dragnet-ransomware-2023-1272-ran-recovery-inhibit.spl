| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1272 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: ffbafc70-b501-5805-a41d-5c6ad1e4ce5b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
