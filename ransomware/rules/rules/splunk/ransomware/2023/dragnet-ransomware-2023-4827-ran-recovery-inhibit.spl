| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4827 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 5f02bc4c-ba7b-5750-9996-255dec5c3013"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
