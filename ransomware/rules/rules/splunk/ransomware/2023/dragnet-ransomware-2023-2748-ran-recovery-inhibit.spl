| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2748 — Recovery Inhibition (malas)"
| comment "Status: experimental | Level: high | ID: f6d80262-80d2-5e32-8c08-72d5b8fdb2be"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
