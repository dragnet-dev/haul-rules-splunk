| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2865 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 9df0a5ae-c057-5908-b3bd-869d75fc2a72"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
