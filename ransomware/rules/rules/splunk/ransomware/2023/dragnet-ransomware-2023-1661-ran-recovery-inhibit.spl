| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1661 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 86c2728f-4ac8-51d9-9216-689a1d5bbc4e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
