| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5025 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 85c50ddf-3a8d-55ba-bc28-267106b876f1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
