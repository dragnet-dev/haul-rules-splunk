| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2855 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 95573454-616f-5d96-9d2f-35e177b7fcf0"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
