| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2503 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 8774a4f7-d129-5126-8693-072884c3a22a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
