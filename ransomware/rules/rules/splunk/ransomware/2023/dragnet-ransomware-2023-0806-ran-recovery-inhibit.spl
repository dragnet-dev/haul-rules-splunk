| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0806 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: d9e68a2e-6ca7-5536-88e6-e94e5f44739a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
