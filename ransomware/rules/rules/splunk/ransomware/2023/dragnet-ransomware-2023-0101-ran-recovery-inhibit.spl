| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0101 — Recovery Inhibition (everest)"
| comment "Status: experimental | Level: high | ID: d2d8a077-93f6-5f7f-aa62-0b6011707f53"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
