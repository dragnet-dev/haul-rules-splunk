| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3514 — Recovery Inhibition (apt73)"
| comment "Status: experimental | Level: high | ID: d0981b8a-4aba-5078-9591-4acc8ebc7bf9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
