| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1921 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 0a3074bd-75ff-5a2e-a1fc-847e53bf36ef"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
