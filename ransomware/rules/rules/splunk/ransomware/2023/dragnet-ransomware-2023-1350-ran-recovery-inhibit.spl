| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1350 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: b02849e1-930e-5b87-b951-7ee420cfc971"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
