| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2840 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 50732a43-4b07-58f6-bd5a-aec58b889c05"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
