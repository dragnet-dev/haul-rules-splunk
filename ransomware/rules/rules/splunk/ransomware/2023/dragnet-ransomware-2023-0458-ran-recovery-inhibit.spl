| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0458 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: e8fa78a6-31d8-5b4f-a48d-fe13c70609d9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
