| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2171 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: bf482379-c1fa-52a0-8685-b8c4068f85d8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
