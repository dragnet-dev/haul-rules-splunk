| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2393 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: f1f7425d-8a2c-5a37-84be-8e2a7001803c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
