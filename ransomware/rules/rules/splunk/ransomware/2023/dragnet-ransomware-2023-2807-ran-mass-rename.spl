| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2807 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 163b852a-3071-513b-b3eb-a90507ed06e5"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
