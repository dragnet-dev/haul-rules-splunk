| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4139 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: cd8ce813-aa83-55b8-b9a4-4ddd1106b5d1"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
