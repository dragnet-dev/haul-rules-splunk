| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0420 — Recovery Inhibition (ransomexx)"
| comment "Status: experimental | Level: high | ID: f53eb53f-85ca-5d1f-ab3b-88375ce3b8e5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
