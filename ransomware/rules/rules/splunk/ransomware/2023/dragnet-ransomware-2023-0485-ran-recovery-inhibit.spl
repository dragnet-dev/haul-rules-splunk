| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0485 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 7aac7f92-6756-52f1-8619-13a283303b98"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
