| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1105 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: b97efcfb-838d-5c89-a420-186654f698d9"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
