| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0327 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 8f5b5768-006c-522a-bd00-54e9d3ebac22"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
