| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0379 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: c107d230-0f91-5607-b61d-a7af24e6c374"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
