| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2756 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 292d396f-6028-5772-9044-f4d816a1a227"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
