| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1285 — Recovery Inhibition (cryptnet)"
| comment "Status: experimental | Level: high | ID: f3a948ed-f9e7-5ef5-b34e-c2e9d4539a31"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
