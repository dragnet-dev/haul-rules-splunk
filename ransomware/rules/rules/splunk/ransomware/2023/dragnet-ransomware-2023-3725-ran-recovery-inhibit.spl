| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3725 — Recovery Inhibition (threeam)"
| comment "Status: experimental | Level: high | ID: e2520f2a-c9f7-5eb0-a202-9fb13e05bc78"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
