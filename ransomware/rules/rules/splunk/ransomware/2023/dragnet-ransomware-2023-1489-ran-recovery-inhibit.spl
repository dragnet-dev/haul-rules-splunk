| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1489 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 313767f8-3431-58f2-9928-4f8ae4c04535"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
