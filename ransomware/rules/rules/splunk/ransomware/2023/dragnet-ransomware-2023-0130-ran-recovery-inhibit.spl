| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0130 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 0ca17576-0c4b-53fd-9d64-62a163bf282a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
