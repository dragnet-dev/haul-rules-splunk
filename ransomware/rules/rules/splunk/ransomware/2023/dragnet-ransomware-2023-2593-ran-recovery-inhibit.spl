| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2593 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 7b286b39-0351-5be4-958c-bb2b73adb96d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
