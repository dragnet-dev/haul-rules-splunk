| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3420 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 74701f9f-b1be-5766-a175-b190a9ba0aa2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
