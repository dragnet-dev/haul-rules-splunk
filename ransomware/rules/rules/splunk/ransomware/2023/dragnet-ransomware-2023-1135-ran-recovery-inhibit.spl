| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1135 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 4025d539-17f3-554e-94d7-f76f92eb2220"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
