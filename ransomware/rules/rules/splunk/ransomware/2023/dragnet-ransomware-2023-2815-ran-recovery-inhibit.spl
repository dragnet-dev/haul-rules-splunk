| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2815 — Recovery Inhibition (malas)"
| comment "Status: experimental | Level: high | ID: e81a4ee7-1e07-5531-81c8-7f4145480734"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
