| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2852 — Recovery Inhibition (malas)"
| comment "Status: experimental | Level: high | ID: 1d8b366f-e293-53cd-b544-aa347abfbc89"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
