| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0481 — Recovery Inhibition (knight)"
| comment "Status: experimental | Level: high | ID: 12931b92-a2f3-589e-b092-a44340a5cb48"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
