| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0253 — Recovery Inhibition (noescape)"
| comment "Status: experimental | Level: high | ID: bd8a78a1-2c9f-5027-9bcc-694fe2b3ac17"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
