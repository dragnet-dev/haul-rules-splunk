| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2224 — Recovery Inhibition (knight)"
| comment "Status: experimental | Level: high | ID: 61726a6e-2ec0-58d7-94c4-586ca8499f0e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
