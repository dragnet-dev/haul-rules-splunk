| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4115 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 0829e35e-58a5-53a9-b5fe-63780c20eeee"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
