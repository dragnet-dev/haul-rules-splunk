| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3882 — Recovery Inhibition (darkpower)"
| comment "Status: experimental | Level: high | ID: 96d3b978-5236-5af8-9ca6-61949bda264a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
