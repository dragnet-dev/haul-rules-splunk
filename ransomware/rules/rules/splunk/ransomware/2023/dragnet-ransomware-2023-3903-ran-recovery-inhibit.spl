| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3903 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 91de7a9a-6199-5c69-8112-858526812c05"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
