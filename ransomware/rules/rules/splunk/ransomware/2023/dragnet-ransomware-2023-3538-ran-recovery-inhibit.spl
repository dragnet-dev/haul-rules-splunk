| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3538 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 8eebf4ac-811e-5f37-a710-dca551e7aff0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
