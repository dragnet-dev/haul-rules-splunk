| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4690 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: c0ec4917-4c98-50ba-87fa-f69a3142bd63"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
