| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0219 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 8bf54795-4bca-5930-afc7-d01134cb3f26"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
