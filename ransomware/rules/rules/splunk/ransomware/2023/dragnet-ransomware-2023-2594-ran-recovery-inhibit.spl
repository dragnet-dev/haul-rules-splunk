| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2594 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 0da01165-ade1-524c-807d-6bcc1922bb0e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
