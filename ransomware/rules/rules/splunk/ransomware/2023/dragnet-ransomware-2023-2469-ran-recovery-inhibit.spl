| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2469 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 44375bc0-877e-5aff-8244-0b8f24d3b8fa"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
