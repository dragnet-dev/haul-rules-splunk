| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5125 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 983b685e-4193-5d5e-8ca1-fb20e3fd4f2c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
