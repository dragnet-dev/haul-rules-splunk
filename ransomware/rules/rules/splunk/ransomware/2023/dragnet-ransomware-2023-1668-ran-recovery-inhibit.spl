| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1668 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 511741cd-20c7-5bd4-a1c6-297f7ede1f90"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
