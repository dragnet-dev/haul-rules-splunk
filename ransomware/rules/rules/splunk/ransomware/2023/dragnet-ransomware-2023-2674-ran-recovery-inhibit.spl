| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2674 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: ee63cd65-7727-5477-bf6d-1a5e782471e5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
