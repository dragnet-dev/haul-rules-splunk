| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2338 — Recovery Inhibition (darkrace)"
| comment "Status: experimental | Level: high | ID: 6278d793-e8f7-5eb4-8899-51fbd6a62693"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
