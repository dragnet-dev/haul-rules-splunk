| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2849 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 58eec869-731e-5193-ba67-9ed61bf4c7b9"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
