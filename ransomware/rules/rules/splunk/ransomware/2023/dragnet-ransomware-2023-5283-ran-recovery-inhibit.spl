| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5283 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 752445cd-6686-59c9-851c-5f6ffe0be297"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
