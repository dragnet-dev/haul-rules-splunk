| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1311 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 24fd1768-5f6f-552b-8de2-8339a1b3feb8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
