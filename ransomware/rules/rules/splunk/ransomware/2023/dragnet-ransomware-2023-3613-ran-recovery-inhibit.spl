| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3613 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 515450d5-bf1b-524d-b01c-4764488a6093"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
