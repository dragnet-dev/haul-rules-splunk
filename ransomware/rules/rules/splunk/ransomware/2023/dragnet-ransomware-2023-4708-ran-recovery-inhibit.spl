| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4708 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: afe8a0bd-977f-57cc-aa6e-f65b6d3dfb9d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
