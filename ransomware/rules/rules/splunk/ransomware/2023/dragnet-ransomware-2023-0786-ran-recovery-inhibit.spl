| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0786 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: e166c6a9-7533-5700-a184-28b61e78fcb6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
