| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5334 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: cc679a8e-f5b1-5207-ac9a-d81506994480"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
