| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2862 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: ea1e0849-ebf9-51b2-904a-d4cb866c95c7"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
