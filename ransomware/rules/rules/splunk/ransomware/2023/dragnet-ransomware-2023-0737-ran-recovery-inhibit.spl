| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0737 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 495c8d60-a246-5dcb-841b-5e8217521e1f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
