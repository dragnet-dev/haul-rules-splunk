| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0796 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: f4ced26c-fb71-5004-8237-756bb4731300"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
