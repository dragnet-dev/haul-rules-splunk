| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4878 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: eaa6b358-38c2-51ba-bdf2-b57c35f3afff"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
