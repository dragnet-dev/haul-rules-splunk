| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2569 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 446b78c2-f04c-5d24-8548-b3fdf08abb40"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
