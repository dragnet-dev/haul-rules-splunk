| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2990 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: e3088779-3811-5502-a60b-1c1d81300fbf"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
