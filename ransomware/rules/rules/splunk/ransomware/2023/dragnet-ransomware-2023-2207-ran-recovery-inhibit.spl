| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2207 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: d2e9fa6e-58e8-562a-a34d-4605b2b8fcf7"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
