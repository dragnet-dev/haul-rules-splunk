| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2852 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: e86cdefd-f740-5958-b0bf-16b4a9bb833c"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
