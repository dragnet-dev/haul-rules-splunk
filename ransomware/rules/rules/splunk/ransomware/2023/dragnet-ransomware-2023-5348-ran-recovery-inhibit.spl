| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5348 — Recovery Inhibition (meow)"
| comment "Status: experimental | Level: high | ID: 7c63852a-8592-5e5b-b51a-d7f41ddb15d2"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
