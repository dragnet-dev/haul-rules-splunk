| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2193 — Recovery Inhibition (monti)"
| comment "Status: experimental | Level: high | ID: c249e3e8-0321-532c-8d67-02498b69bec3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
