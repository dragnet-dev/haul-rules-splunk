| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0417 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: d1e50571-9936-5450-a0b0-755f669e61ae"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
