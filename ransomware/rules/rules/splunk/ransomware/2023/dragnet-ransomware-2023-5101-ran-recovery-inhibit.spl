| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5101 — Recovery Inhibition (royal)"
| comment "Status: experimental | Level: high | ID: 874639fc-fc11-5ccf-a651-9acb9afd0873"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
