| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2022 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 560a279b-c095-572e-b1d6-e6d13c25267e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
