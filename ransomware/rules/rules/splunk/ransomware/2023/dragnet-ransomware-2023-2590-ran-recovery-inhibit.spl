| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2590 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 59024ddb-39da-5fe1-8948-bafeac473e2d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
