| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3129 — Mass File Rename (threeam)"
| comment "Status: experimental | Level: high | ID: b07ba980-00ad-5954-a526-93e1d11e1a3b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
