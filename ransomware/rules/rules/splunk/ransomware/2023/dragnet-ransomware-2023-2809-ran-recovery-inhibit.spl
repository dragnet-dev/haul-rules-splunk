| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2809 — Recovery Inhibition (malas)"
| comment "Status: experimental | Level: high | ID: c66c13d9-84e9-58d8-a41a-8df0f1bc84d9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
