| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3072 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 93a53af9-9b82-56fc-ab69-805220bf3d96"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
