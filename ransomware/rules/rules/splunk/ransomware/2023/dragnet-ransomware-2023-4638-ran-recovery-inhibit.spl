| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4638 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 1faaa533-1119-53c8-af3b-acc08141e8ee"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
