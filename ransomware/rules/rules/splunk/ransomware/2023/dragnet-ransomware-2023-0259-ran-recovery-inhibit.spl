| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0259 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 2659d5f3-2d41-584b-b501-1f8f1ac93ce6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
