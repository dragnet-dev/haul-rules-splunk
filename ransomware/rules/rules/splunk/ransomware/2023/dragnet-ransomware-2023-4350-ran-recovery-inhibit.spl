| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4350 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 86790e1b-19ce-5f3f-a3b9-c7fa00a8e25d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
