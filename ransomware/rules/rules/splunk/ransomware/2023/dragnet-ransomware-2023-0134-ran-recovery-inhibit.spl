| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0134 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 14a8896d-9ac0-519e-84b2-dda31c4d9a05"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
