| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0225 — Recovery Inhibition (rhysida)"
| comment "Status: experimental | Level: high | ID: facef82a-0d0b-561e-8c63-efd9da24b0e3"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
