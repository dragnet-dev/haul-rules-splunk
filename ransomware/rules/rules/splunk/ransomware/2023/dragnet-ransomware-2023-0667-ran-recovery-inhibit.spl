| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0667 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 60ec23ac-c84c-512d-b5cc-f0cae344962d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
