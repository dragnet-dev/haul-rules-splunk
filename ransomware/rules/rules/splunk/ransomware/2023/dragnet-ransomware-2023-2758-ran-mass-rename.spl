| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2758 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 9375f527-7bdc-5a79-9e87-de680bc46de9"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
