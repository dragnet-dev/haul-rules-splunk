| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4511 — Recovery Inhibition (blackbasta)"
| comment "Status: experimental | Level: high | ID: 5068471f-1274-5153-a4ac-fd30986f356a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
