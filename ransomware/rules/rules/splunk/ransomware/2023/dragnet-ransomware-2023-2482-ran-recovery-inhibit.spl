| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2482 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: 71e06659-f4c1-5409-b6cb-585456175a2d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
