| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2913 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: a98badf6-49c0-51d7-8ee1-96621f2450ff"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
