| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3494 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 509a2842-b4f4-5ac7-970a-207e9695aa54"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
