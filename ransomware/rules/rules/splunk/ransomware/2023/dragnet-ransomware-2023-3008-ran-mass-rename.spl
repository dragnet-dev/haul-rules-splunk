| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3008 — Mass File Rename (lockbit3)"
| comment "Status: experimental | Level: high | ID: 10ddc3ba-2474-5034-a691-e2e422bdce69"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
