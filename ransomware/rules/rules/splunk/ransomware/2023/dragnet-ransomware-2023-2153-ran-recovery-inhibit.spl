| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2153 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: 366cb847-3a34-5241-8d53-03f78f1ef1f9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
