| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5318 — Recovery Inhibition (cactus)"
| comment "Status: experimental | Level: high | ID: 0ab522fc-f30e-5a5c-993f-df58244d819a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
