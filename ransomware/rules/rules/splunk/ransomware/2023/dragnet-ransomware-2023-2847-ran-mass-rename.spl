| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2847 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 881c4061-3473-5976-afca-ce5e89b3dfa3"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
