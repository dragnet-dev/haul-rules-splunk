| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3500 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: abef8779-fa23-5287-9558-6cecd29eff12"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
