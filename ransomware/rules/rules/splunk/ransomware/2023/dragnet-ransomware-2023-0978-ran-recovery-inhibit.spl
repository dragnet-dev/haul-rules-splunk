| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0978 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: ac64591d-1568-5ac0-a8e6-e0021a111287"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
