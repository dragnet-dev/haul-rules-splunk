| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3381 — Recovery Inhibition (metaencryptor)"
| comment "Status: experimental | Level: high | ID: 60225387-ecb9-5bef-a669-fc85fac176b4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
