| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1546 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: d7bb5dc0-a92a-57fe-83cf-031d89c6a5ec"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
