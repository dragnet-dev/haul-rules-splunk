| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3401 — Recovery Inhibition (bianlian)"
| comment "Status: experimental | Level: high | ID: cb600842-07de-5c0f-b873-0442f2c0ea1b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
