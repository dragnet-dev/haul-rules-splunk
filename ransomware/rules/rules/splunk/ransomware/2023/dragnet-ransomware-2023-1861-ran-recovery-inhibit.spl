| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1861 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: ddf22b01-73c1-5146-af16-5509b4e35656"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
