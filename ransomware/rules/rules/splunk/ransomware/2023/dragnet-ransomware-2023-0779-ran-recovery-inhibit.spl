| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0779 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 91247fc8-ccce-5406-bd3d-6b1bc58cd2ae"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
