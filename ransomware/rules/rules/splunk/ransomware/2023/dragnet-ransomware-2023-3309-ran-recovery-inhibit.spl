| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3309 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 00fd1318-4a5a-5960-a0e4-930dc578821d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
