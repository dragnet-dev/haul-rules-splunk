| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2599 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 1c4a7794-eeea-5014-99e9-553735022b46"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
