| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1497 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 7fedba18-9267-52ba-8a73-50b558ff33a6"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
