| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-5151 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 5be67c56-2b81-54e6-9c34-14effdb314f5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
