| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0213 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 86d180e7-6b15-5a01-8ab1-5ca61cdbdb83"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
