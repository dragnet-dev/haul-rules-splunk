| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4879 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 14e656d5-38e0-5479-9e7f-dffe405ca4aa"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
