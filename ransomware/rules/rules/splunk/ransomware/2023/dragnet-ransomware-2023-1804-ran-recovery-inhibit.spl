| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-1804 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 578ffb8a-432b-5f51-ac91-40c626f5ca26"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
