| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0553 — Recovery Inhibition (play)"
| comment "Status: experimental | Level: high | ID: f0040526-5943-57a7-9320-0d8b0b2638d9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
