| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4171 — Recovery Inhibition (noescape)"
| comment "Status: experimental | Level: high | ID: 43f9bad1-1c52-5932-8c5d-12a8d3f6ab2c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
