| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0444 — Recovery Inhibition (ElDorado)"
| comment "Status: experimental | Level: high | ID: 675d2095-717a-5a40-9194-0c7661b39957"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
