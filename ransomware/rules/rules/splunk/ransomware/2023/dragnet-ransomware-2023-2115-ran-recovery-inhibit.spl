| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2115 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 94818e9a-0a12-5cb3-8cbb-3d17b1f17c5a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
