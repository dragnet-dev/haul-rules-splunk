| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2268 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 6fd68b5f-e3e5-51cc-a06b-04b7fd26c1d5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
