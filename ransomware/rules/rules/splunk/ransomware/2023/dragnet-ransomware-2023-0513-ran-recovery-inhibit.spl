| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0513 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 63cbe282-186a-5e04-b6d2-9da9bb7d897e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
