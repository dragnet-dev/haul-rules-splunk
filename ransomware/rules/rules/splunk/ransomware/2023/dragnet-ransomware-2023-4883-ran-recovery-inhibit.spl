| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4883 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: db22b2e3-29c1-57cb-ae39-e057a33d4798"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
