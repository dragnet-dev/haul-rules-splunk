| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4872 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 251237a6-e18a-58ef-985f-cb710b1f968c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
