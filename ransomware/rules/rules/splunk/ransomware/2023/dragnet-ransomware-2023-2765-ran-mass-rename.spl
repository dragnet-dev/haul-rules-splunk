| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2765 — Mass File Rename (malas)"
| comment "Status: experimental | Level: high | ID: 652f8175-6261-578d-81bd-6001ccfe44e6"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
