| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-4870 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: ab0a15b6-c883-5981-af9a-90a677ffdf07"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
