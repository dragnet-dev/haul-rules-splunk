| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-2646 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 595e75b2-ee3b-5c6c-a2b4-a383c239a818"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
