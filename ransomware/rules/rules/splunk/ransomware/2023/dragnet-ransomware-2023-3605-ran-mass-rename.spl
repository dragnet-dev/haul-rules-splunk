| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3605 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: ffd4beeb-22ab-5238-80de-ed14cb0a0d6d"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
