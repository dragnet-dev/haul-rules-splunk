| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-3007 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: d6c537f0-80a2-577a-947d-60d2d53e78ed"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
