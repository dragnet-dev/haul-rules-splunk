| comment "Dragnet [Ransomware]: dragnet-ransomware-2023-0501 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 84ef1f30-1b30-55b0-bcc5-92e9c9f7950a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
