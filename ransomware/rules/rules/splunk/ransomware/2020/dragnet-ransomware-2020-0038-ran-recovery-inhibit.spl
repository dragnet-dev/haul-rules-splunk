| comment "Dragnet [Ransomware]: dragnet-ransomware-2020-0038 — Recovery Inhibition (netwalker)"
| comment "Status: deprecated | Level: high | ID: 767582e7-a786-55d6-aace-a8460fa4d6b1"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
