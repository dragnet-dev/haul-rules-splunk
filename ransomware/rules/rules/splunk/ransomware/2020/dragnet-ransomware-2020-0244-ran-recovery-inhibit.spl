| comment "Dragnet [Ransomware]: dragnet-ransomware-2020-0244 — Recovery Inhibition (revil)"
| comment "Status: deprecated | Level: high | ID: f1ee778b-ac77-5ab1-a631-2ea4dc110b2e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
