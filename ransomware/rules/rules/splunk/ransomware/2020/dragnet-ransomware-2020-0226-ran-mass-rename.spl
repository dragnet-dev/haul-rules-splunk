| comment "Dragnet [Ransomware]: dragnet-ransomware-2020-0226 — Mass File Rename (dispossessor)"
| comment "Status: experimental | Level: high | ID: b575bd15-dc74-563a-8deb-ce9ceafc56f7"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
