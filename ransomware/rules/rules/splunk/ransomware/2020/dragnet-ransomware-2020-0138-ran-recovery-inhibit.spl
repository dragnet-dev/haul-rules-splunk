| comment "Dragnet [Ransomware]: dragnet-ransomware-2020-0138 — Recovery Inhibition (netwalker)"
| comment "Status: deprecated | Level: high | ID: f3be04f5-2fd1-55c9-abab-99307d9aaca4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
