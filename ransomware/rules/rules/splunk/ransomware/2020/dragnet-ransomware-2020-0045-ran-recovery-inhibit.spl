| comment "Dragnet [Ransomware]: dragnet-ransomware-2020-0045 — Recovery Inhibition (ransomexx)"
| comment "Status: deprecated | Level: high | ID: b1f22ce6-d7cb-559d-a4a8-655bce9bdd74"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
