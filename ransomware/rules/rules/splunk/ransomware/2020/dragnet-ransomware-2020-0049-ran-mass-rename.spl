| comment "Dragnet [Ransomware]: dragnet-ransomware-2020-0049 — Mass File Rename (dispossessor)"
| comment "Status: experimental | Level: high | ID: fd6eb98d-6ae6-5605-baae-e30ac15d3913"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
