| comment "Dragnet [Ransomware]: dragnet-ransomware-2020-0246 — Recovery Inhibition (netwalker)"
| comment "Status: deprecated | Level: high | ID: 5d447a58-ab6e-54fe-8ea7-91636674e1a9"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
