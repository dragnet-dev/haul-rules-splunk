| comment "Dragnet [Ransomware]: dragnet-ransomware-2021-0230 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 76aed74f-cf03-58a8-9367-946267dccd73"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
