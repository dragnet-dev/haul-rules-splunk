| comment "Dragnet [Ransomware]: dragnet-ransomware-2021-1172 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 54b189ca-7fc3-5d43-aefe-dbfec7faf29f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
