| comment "Dragnet [Ransomware]: dragnet-ransomware-2021-0380 — Recovery Inhibition (lockbit3)"
| comment "Status: experimental | Level: high | ID: 358a4749-7886-5e79-9dbb-fadfd5bebb2e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
