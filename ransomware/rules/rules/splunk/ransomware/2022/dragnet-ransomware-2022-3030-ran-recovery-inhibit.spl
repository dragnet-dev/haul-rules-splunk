| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-3030 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: e9b32fa8-ec9d-5207-b226-e9250226926f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
