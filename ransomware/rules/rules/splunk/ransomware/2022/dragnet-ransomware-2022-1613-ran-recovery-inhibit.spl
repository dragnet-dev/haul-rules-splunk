| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1613 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: f70f34ff-d316-563e-bbe0-8d17d0e8fe56"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
