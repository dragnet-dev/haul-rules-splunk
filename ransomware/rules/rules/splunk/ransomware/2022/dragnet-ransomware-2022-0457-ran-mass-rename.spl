| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0457 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 0d5d07bb-48fc-526d-8f37-f76ee59d2fd4"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
