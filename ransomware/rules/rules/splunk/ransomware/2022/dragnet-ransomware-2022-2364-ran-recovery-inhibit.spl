| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2364 — Recovery Inhibition (qilin)"
| comment "Status: experimental | Level: high | ID: ee7a50dc-6c28-585c-bd16-31abde845e5f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
