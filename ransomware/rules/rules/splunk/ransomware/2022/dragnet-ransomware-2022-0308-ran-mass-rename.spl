| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0308 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: 39feb32b-a0ed-58de-a14d-ce3110ae4d85"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
