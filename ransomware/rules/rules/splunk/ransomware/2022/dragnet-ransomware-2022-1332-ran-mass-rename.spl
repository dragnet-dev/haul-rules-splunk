| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1332 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 29ebf053-0709-5c3c-a49d-c86b029767a0"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
