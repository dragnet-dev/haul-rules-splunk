| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2907 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: d928011b-a106-5ccc-ad82-66b0d3145857"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
