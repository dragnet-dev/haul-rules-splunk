| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0138 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 86c588a6-8171-5a8d-97e6-623b070a0262"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
