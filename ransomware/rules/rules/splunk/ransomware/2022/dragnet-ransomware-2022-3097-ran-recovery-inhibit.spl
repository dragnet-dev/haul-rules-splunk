| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-3097 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 64dd3b2b-3dd6-573d-a4eb-c66d0e96dde4"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
