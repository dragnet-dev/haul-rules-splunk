| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0222 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: c53c4e21-77e0-5f68-8098-81c4db8c7023"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
