| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-3162 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: aff35081-3a44-5e25-989d-99c96d6a52b8"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
