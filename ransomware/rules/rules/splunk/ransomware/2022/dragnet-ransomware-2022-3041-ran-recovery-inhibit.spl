| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-3041 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: e2f8e3f9-ed25-50bf-97a8-1a4cfcb336e0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
