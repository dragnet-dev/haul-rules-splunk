| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0673 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: f9469033-98df-5129-8473-e4e5458f23f1"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
