| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2639 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 42928ea7-5a23-5018-87f4-fe5fc20582af"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
