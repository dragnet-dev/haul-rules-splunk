| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0884 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 65dc3c35-90f6-5cb3-8b10-b699ca173602"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
