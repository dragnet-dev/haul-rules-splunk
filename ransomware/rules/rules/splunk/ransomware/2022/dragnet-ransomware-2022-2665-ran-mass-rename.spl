| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2665 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: c73e4894-2d7f-5c4a-a281-d053baa489ac"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
