| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1025 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 8cb1493e-51d6-5460-97d0-8e51148b6ace"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
