| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0025 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 3102842d-a53b-57b3-8b5c-8d5b8f193199"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
