| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0068 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 57b0a7a5-55e6-575f-abe4-f3bd5c4885ae"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
