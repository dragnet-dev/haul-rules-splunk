| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1267 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 41f08c90-9214-567e-b198-46fbbfc0db43"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
