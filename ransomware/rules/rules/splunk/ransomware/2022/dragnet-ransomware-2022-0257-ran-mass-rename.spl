| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0257 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: 0ff513f7-bd6b-562b-9d07-8a41c45fe405"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
