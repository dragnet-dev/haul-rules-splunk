| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0342 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: 103ebe61-0e6b-5788-b037-a87302e252bb"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
