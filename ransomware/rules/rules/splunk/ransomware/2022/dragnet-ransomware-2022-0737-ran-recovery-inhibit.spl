| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0737 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: c82205c4-89f0-54aa-8f74-f8a16400be3a"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
