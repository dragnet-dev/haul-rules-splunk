| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0090 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 0c983dee-b84a-5bc5-af33-0288be223734"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
