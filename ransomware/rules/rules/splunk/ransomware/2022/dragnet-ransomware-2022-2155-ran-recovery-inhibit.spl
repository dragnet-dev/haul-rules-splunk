| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2155 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 00c86762-3222-5a7e-9640-296516bb596b"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
