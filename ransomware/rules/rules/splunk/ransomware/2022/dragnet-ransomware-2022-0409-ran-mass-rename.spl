| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0409 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 103f0c5b-51dc-5c92-a478-04dd54015b9a"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
