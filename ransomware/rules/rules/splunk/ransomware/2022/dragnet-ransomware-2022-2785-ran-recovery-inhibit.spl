| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2785 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: 5b79d302-c28d-5b65-9ddd-f9f9655c6c96"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
