| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0766 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 522e41ab-9d4c-515d-a275-3e1d068c6609"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
| head 1000
