| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1501 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: b6bdaae4-97b5-5da6-a32e-cca2cdecb6fd"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
