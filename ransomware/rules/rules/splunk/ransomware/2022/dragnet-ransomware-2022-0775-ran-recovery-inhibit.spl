| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0775 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: a0d8af9f-0167-5fe7-9d3f-d14379bb782e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
