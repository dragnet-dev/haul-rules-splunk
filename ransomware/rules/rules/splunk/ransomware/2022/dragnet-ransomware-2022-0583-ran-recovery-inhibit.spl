| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0583 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: ec8b622c-07f5-52e6-b0da-6f213a76058c"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
