| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1884 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 66fac4f9-e143-51af-9e7a-b2cc14693c77"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
