| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1303 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: 694f2e93-a62f-5713-80e7-f7d8294160a0"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
