| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0064 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: fefcc7e3-a94f-58ac-a76e-54788ecbcbc5"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
