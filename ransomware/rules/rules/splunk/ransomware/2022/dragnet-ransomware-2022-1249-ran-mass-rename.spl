| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1249 — Mass File Rename (clop)"
| comment "Status: experimental | Level: high | ID: 465c0aa3-fcdb-5d50-b15b-06bed75b042f"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
