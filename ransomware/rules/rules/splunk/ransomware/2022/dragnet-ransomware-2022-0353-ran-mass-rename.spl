| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0353 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 93ed8278-c68f-5158-9550-8076e7df735a"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
| table _time, host
