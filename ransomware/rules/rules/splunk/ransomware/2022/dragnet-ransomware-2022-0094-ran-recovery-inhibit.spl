| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0094 — Recovery Inhibition (ragnarlocker)"
| comment "Status: experimental | Level: high | ID: 156a508f-1bba-598a-b378-6726c09e6c4e"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
