| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-2521 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: eef46a16-2fd3-528b-886a-3713afdb97de"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
