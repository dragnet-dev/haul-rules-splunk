| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-1990 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: f5c21f6c-f074-5d9c-8205-c4f7711a6b62"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
