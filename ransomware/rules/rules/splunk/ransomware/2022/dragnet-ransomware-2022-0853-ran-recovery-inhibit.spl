| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0853 — Recovery Inhibition (8base)"
| comment "Status: experimental | Level: high | ID: d016d53d-725a-5a95-9e75-caee70e53c40"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
