| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0910 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: dbca518d-f1fd-5b3b-a571-f666d47fa34d"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
