| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-3068 — Recovery Inhibition (dispossessor)"
| comment "Status: experimental | Level: high | ID: e47923b1-3bd5-5d82-bdaf-6b042ebd7653"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
