| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0616 — Recovery Inhibition (alphv)"
| comment "Status: experimental | Level: high | ID: 8f22363a-e8b6-5607-a27d-7090f30d6d4f"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
