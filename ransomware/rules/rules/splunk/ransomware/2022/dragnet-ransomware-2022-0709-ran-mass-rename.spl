| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0709 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 82138f30-eef1-564a-86de-cbe147e7a163"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
