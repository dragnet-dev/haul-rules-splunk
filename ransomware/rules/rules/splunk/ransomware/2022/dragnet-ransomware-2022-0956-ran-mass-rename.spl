| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-0956 — Mass File Rename (alphv)"
| comment "Status: experimental | Level: high | ID: 56b78afc-1fe1-50b0-8edf-d768800ee54b"
index=*
| where (file_path="*.encrypted" OR file_path="*.locked" OR file_path="*.ransom")
