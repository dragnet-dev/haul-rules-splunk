| comment "Dragnet [Ransomware]: dragnet-ransomware-2022-3023 — Recovery Inhibition (clop)"
| comment "Status: experimental | Level: high | ID: 26c9b6bb-1f9a-5a7a-bb4c-4ae3d47f82c8"
index=* sourcetype=endpoint*
| where (CommandLine="*recoveryenabled no*" OR CommandLine="*bootstatuspolicy ignoreallfailures*") AND (process="*\bcdedit.exe")
